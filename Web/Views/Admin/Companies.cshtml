@{
	Layout = "_LayoutAdmin";
	ViewData["Title"] = "Companies";
}

@model List<AdminCompanyListViewModel>

<div class="page-header">
	<h4><i class="fa-solid fa-building me-2 text-primary"></i> Companies</h4>
	<a href="/admin/companies/new" class="btn btn-primary btn-sm">
		<i class="fa-solid fa-plus me-1"></i> New Company
	</a>
</div>

<div class="card shadow-sm border-0">
	<div class="card-body p-0">
		@if (!Model.Any())
		{
			<div class="text-center py-5 text-muted">
				<i class="fa-solid fa-building fa-2x mb-3 d-block"></i>
				No companies yet. <a href="/admin/companies/new">Create the first one.</a>
			</div>
		}
		else
		{
			<table class="table table-hover mb-0 align-middle">
				<thead class="table-light">
					<tr>
						<th style="padding-left:1.25rem;width:52px;"></th>
						<th>Company</th>
						<th>Status</th>
						<th class="text-center">Users</th>
						<th class="text-center">Sites</th>
						<th>Created</th>
						<th class="text-end" style="padding-right:1.25rem;">Actions</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var c in Model)
					{
						<tr>
							<td style="padding-left:1.25rem;">
								@if (!string.IsNullOrEmpty(c.LogoFileName))
								{
									<img src="/img/logos/@c.LogoFileName" alt="@c.Name logo"
										  style="height:36px;width:36px;object-fit:contain;border:1px solid #e2e8f0;border-radius:6px;padding:3px;background:#fff;" />
								}
								else
								{
									<div
										style="height:36px;width:36px;border:1px solid #e2e8f0;border-radius:6px;background:#f8fafc;display:flex;align-items:center;justify-content:center;">
										<i class="fa-solid fa-building text-muted" style="font-size:.75rem;"></i>
									</div>
								}
							</td>
							<td>
								<div class="fw-600">@c.Name</div>
								@if (!string.IsNullOrEmpty(c.Description))
								{
									<small class="text-muted">@c.Description</small>
								}
							</td>
							<td>
								@if (c.IsActive)
								{
									<span class="badge bg-success-soft text-success">Active</span>
								}
								else
								{
									<span class="badge bg-secondary-soft text-secondary">Inactive</span>
								}
							</td>
							<td class="text-center">
								<span class="badge bg-light text-dark border">@c.UserCount</span>
							</td>
							<td class="text-center">
								<span class="badge bg-light text-dark border">@c.SiteCount</span>
							</td>
							<td>
								<small class="text-muted">@c.CreatedWhen.ToString("dd MMM yyyy")</small>
							</td>
							<td class="text-end" style="padding-right:1.25rem;">
								<a href="/admin/companies/@c.Id/settings" class="btn btn-sm btn-outline-info me-1" title="Settings">
									<i class="fa-solid fa-gear"></i>
								</a>
								<a href="/admin/companies/@c.Id/edit" class="btn btn-sm btn-outline-secondary me-1" title="Edit">
									<i class="fa-solid fa-pen-to-square"></i>
								</a>

								<form method="post" action="/admin/companies/@c.Id/toggle" class="d-inline"
										onsubmit="return confirm('@(c.IsActive ? "Deactivate" : "Activate") this company?')">
									@Html.AntiForgeryToken()
									<button type="submit"
											  class="btn btn-sm @(c.IsActive ? "btn-outline-warning" : "btn-outline-success")"
											  title="@(c.IsActive ? "Deactivate" : "Activate")">
										<i class="fa-solid @(c.IsActive ? "fa-ban" : "fa-check")"></i>
									</button>
								</form>

								<form method="post" action="/admin/companies/@c.Id/delete" class="d-inline ms-1"
										onsubmit="return confirm('Delete company \'@c.Name\'?')">
									@Html.AntiForgeryToken()
									<button type="submit" class="btn btn-sm btn-sm btn-outline-danger" title="Delete">
										<i class="fa-solid fa-trash"></i>
									</button>
								</form>
							</td>
						</tr>
					}
				</tbody>
			</table>
		}
	</div>
</div>

<div class="mt-3 text-muted" style="font-size:.8rem;">
	@Model.Count @(Model.Count == 1 ? "company" : "companies") total &bull;
	@Model.Count(c => c.IsActive) active &bull;
	@Model.Count(c => !c.IsActive) inactive
</div>
