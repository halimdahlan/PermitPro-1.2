@using PermitPro.Core.Entities
@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Settings / Workflow";
	ViewData["SubTitle"] = "Edit workflow";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model WorkflowEditViewModel

<div class="row g-3">
	<div class="col-12 col-lg-6">
		<div class="card shadow-sm workflow-edit me-0 me-md-3">
			<div class="card-body">
				<div id="div-panel">
					<ul class="nav nav-tabs" id="myTab" role="tablist">
						<li class="nav-item" role="presentation">
							<button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general-tab-pane" type="button" role="tab" aria-controls="general-tab-pane" aria-selected="true">Workflow Details</button>
						</li>
						<li class="nav-item" role="presentation">
							<button class="nav-link" id="steps-tab" data-bs-toggle="tab" data-bs-target="#steps-tab-pane" type="button" role="tab" aria-controls="steps-tab-pane" aria-selected="false">Steps</button>
						</li>
					</ul>
					<div class="tab-content" id="myTabContent">
						<div class="tab-pane fade show active" id="general-tab-pane" role="tabpanel" aria-labelledby="general-tab" tabindex="0">
							<div class="d-flex flex-column form-edit-workflow mt-3">
								<form id="frm" class="needs-validation" novalidate>
									<div class="form-group mb-3">
										<label class="form-label" for="workflowName">Name <span class="text-danger">*</span></label>
										<input type="text" id="workflowName" class="form-control" value="@Model.WorkflowName" required />
										<div class="invalid-feedback ms-2">Enter the workflow name</div>
									</div>
									<div class="form-group mb-3">
										<label class="form-label" for="workflowDescription">Description</label>
										<textarea id="workflowDescription" class="form-control">@Model.WorkflowDescription</textarea>
									</div>
									<div>
										<div class="form-group mb-3 d-flex flex-row align-items-center">
											<label class="form-label me-3 mb-0" for="workflowActive">Is active?</label>
											@(Html.Kendo()
												.Switch()
												.Name("workflowActive")
												.Size(ComponentSize.Small)
												.Messages(x => x
													.Checked("YES")
													.Unchecked("NO")
												)
											)
										</div>
									</div>
									<div>
										<div class="form-group mb-3 d-flex flex-row align-items-center">
											<label class="form-label me-3 mb-0" for="workflowCertificate">For PTW with certificate?</label>
											@(Html.Kendo()
												.Switch()
												.Name("workflowCertificate")
												.Size(ComponentSize.Small)
												.Messages(x => x
													.Checked("YES")
													.Unchecked("NO")
												)
											)
										</div>
									</div>

									<div id="plc"></div>

									<div class="d-flex flex-row justify-content-end mt-3">
										<button type="button" class="btn btn-sm btn-primary btn-save"><span class="px-3">Save changes</span></button>
									</div>
									<input type="hidden" id="workflowId" value="@Model.WorkflowId" />
								</form>
							</div>
						</div>
						<div class="tab-pane fade" id="steps-tab-pane" role="tabpanel" aria-labelledby="steps-tab" tabindex="0">
							<div class="form-edit-workflow d-flex flex-column">
								<div class="flex-grow-1">
									<table id="tbl" class="table table-striped display pt-3 mb-3" style="width: 100% !important;">
										<thead>
											<tr>
												<th data-orderable="false" style="width: 200px !important;">STEP NAME</th>
												<th data-orderable="false" data-class-name="desc-column">DESCRIPTION</th>
												<th data-orderable="false" data-class-name="text-center" style="width: 89px !important;">DURATION</th>
												<th data-orderable="false" data-class-name="action-column text-right" style="text-align: right;">ACTIONS</th>
											</tr>
										</thead>
									</table>
								</div>
								<div class="d-flex flex-row justify-content-end">
									<button class="btn btn-sm btn-primary mt-5" data-bs-toggle="modal" data-bs-target="#dlg"><span class="px-3">New workflow step</span></button>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="col-12 col-lg-6">
		<div class="workflow-edit ms-0 ms-md-3">
			<form id="frmEditStep" class="needs-validation" novalidate>
				<div class="card shadow-sm form-workflow-step" style="display: none;">
					<div class="card-header">
						<h6 class="mb-0">Edit workflow step</h6>
					</div>
					<div class="card-body">
						<ul class="nav nav-tabs" id="tabEditStep" role="tablist">
							<li class="nav-item" role="presentation">
								<button class="nav-link active" id="general-editStep-tab" data-bs-toggle="tab" data-bs-target="#general-editStep-tab-pane" type="button" role="tab" aria-controls="general-editStep-tab-pane" aria-selected="true">Step Details</button>
							</li>
							<li class="nav-item" role="presentation">
								<button class="nav-link" id="users-editStep-tab" data-bs-toggle="tab" data-bs-target="#users-editStep-tab-pane" type="button" role="tab" aria-controls="users-editStep-tab-pane" aria-selected="false">Approvers</button>
							</li>
						</ul>
						<div class="tab-content" id="editStepTabContent">
							<div class="tab-pane fade show active pt-3" id="general-editStep-tab-pane" role="tabpanel" aria-labelledby="general-editStep-tab" tabindex="0">
								<div class="form-group mb-3">
									<label class="form-label" for="editStepName">Name <span class="text-danger">*</span></label>
									<input type="text" id="editStepName" class="form-control" required />
									<div class="invalid-feedback ms-2">Enter the workflow step name</div>
								</div>
								<div class="form-group mb-3">
									<label class="form-label" for="editStepDescription">Description</label>
									<textarea id="editStepDescription" rows="2" class="form-control"></textarea>
								</div>
								<div class="form-group mb-3">
									<div class="d-flex flex-column flex-md-row justify-content-between">
										<div class="w-100 me-3">
											<label class="form-label" for="editStepDuration">Duration</label>
											@(Html.Kendo()
												.NumericTextBox()
												.Name("editStepDuration")
												.Format("0")
												.Value(0)
												.Min(0)
												.Max(500)
											)
										</div>
										<div class="w-100 ms-3">
											<label class="form-label" for="editStepDurationType">Duration Type</label>
											<select id="editStepDurationType" class="form-select" required>
												<option value="" selected disabled>(select)</option>
												<option value="0">MINUTE</option>
												<option value="1">HOUR</option>
												<option value="2">DAY</option>
											</select>
											<div class="invalid-feedback ms-2">Select the duration type</div>
										</div>
									</div>
								</div>
								<div class="d-flex flex-row justify-content-end mt-4">
									<button type="button" class="btn btn-sm btn-primary btn-save-edit-step"><span class="mx-3">Save Changes</span></button>
								</div>
							</div>
							<div class="tab-pane fade pt-3" id="users-editStep-tab-pane" role="tabpanel" aria-labelledby="users-editStep-tab" tabindex="0">
								<table id="tblApprovers" class="table table-striped display" style="width: 100% !important;">
									<thead>
										<tr>
											<th scope="col">NAME</th>
											<th scope="col">EMAIL</th>
											<th scope="col" data-class-name="text-center" style="width: 81px !important;">ACTIONS</th>
										</tr>
									</thead>
								</table>
								<div class="d-flex flex-row justify-content-end mt-4">
									<button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgUsers"><span class="mx-3">Add user</span></button>
								</div>
							</div>
						</div>
					</div>
				</div>
				<input type="hidden" id="editStepId" value="" />
			</form>
		</div>
	</div>
</div>

<div class="d-flex flex-row align-items-center justify-content-between mt-3">
	<a asp-controller="workflow" asp-action="index">
		<i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back
	</a>
</div>

<!-- Modal -->
<div class="modal fade" id="dlg" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<form id="frmStep" class="needs-validation" novalidate>
				<div class="modal-header bg-dark">
					<h6 class="modal-title w-100 text-white" id="dlgLabel">New workflow step</h6>
					<a href="#" class="no-loading text-white" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
				</div>
				<div class="modal-body">
					<div class="form-group mb-3">
						<label class="form-label" for="stepName">Step name <span class="text-danger">*</span></label>
						<input type="text" id="stepName" class="form-control" required />
						<div class="invalid-feedback ms-2">Enter the workflow step name</div>
					</div>
					<div class="form-group mb-3">
						<label class="form-label">Description</label>
						<textarea id="stepDescription" class="form-control"></textarea>
					</div>
					<div class="form-group">
						<label class="form-label" for="stepDuration">Duration</label>
						<div class="d-flex flex-row align-items-center">
							<div class="me-3">
								@(Html.Kendo()
									.NumericTextBox()
									.Name("stepDuration")
									.Format("0")
									.Value(0)
									.Min(0)
									.Max(500)
								)
							</div>
							<div>
								<select id="stepDurationType" class="form-select" required>
									<option value="" selected disabled>(select)</option>
									<option value="0">MINUTE</option>
									<option value="1">HOUR</option>
									<option value="2">DAY</option>
								</select>
								<div class="invalid-feedback ms-2">Select the duration type</div>
							</div>
						</div>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
					<button type="button" class="btn btn-sm btn-primary btn-save-step"><span class="mx-3">Save changes</span></button>
				</div>
				<input type="hidden" id="wrkId" value="@Model.WorkflowId" />
			</form>
		</div>
	</div>
</div>


<!-- Modal -->
<div class="modal fade" id="dlgUsers" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgUsersLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-dark">
				<h6 class="modal-title mb-0 w-100 text-white" id="dlgUsersLabel">Select user</h6>
				<a href="#" class="no-loading text-white" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<table id="tblUsers" class="table table-striped display" style="width: 100% !important;">
					<thead>
						<tr>
							<th scope="col" data-class-name="name-column" style="width: 200px !important;">NAME</th>
							<th scope="col">EMAIL</th>
							<th scope="col" data-class-name="text-center" style="width: 81px !important;">ACTIONS</th>
						</tr>
					</thead>
				</table>
			</div>
			<div class="modal-footer d-flex flex-row justify-content-between align-items-center">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"><span>Cancel</span></button>
				<button type="button" class="btn btn-sm btn-primary btn-add-selected-users" data-bs-dismiss="modal"><span class="mx-3">Add selected users</span></button>
			</div>
		</div>
	</div>
</div>

@Html.AntiForgeryToken()

@section CustomCss {
	<!-- DataTables -->
	<link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />
	<script src="~/lib/DataTables/datatables.min.js"></script>

	<link rel="stylesheet" href="~/css/workflow.css" />
}

@section Scripts {
	<script>
		var tbl = null;
		var tblApprovers = null;
		var tblUsers = null;
		var approvers = [];

		$(document).ready(() => {

			var isActive = ('@Model?.WorkflowIsActive' == 'True');
			var hasCertificate = ('@Model?.WorkflowHasCertificate' == 'True');

			$('#workflowActive').data('kendoSwitch').value(isActive);
			$('#workflowCertificate').data('kendoSwitch').value(hasCertificate);

			/**
			 * Button event handlers
			 */
			$('.btn-save').click(() => {
				$('#frmNew').removeClass('needs-validation').addClass('was-validated');

				if ($('#frm')[0].checkValidity()) {
					const workflowName = $('#workflowName').val();
					const workflowDescription = $('#workflowDescription').val();
					const workflowActive = $('#workflowActive').data('kendoSwitch').value();
					const workflowCertificate = $('#workflowCertificate').data('kendoSwitch').value();
					const workflowId = $('#workflowId').val();

					const postData = {
						id: workflowId,
						name: workflowName,
						description: workflowDescription,
						isActive: workflowActive,
						hasCertificate: workflowCertificate,
					};

					var formData = new FormData();
					formData.append('Id', workflowId);
					formData.append('Name', workflowName);
					formData.append('Description', workflowDescription);
					formData.append('IsActive', workflowActive);
					formData.append('HasCertificate', workflowCertificate);

					$('.loading').show();

					const xhr = $.ajax({
						method: 'PUT',
						url: '/@companyId/workflow/workflows/@Model?.WorkflowId/edit',
						data: formData,
						contentType: false,
						processData: false,
						cache: false,
						beforeSend: (xhr) => {
							xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
						},
					});

					xhr.done((response, status) => {
						if (!response.hasError) {
							let alertDiv = '<div class="alert alert-success alert-dismissible fade show text-center mt-4" role="alert">';
							alertDiv += 'Successfully saved workflow information.';
							alertDiv += '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>';
							alertDiv += '</div>';

							$('#plc').html(alertDiv);

							const timeOut = setTimeout(() => {
								$('#plc').fadeOut('slow', () => {
									$('#plc').empty();
									$('#plc').css('display', 'block');
								});
							}, 3000);

							//clearTimeout(timeOut);
						}
					});

					xhr.fail((response, status) => {
					});

					xhr.always(() => {
						$('.loading').hide();
					});
				}
			});


			/**
			 * Button event handlers
			 */
			$('.btn-save-step').click(() => {
				$('#frmStep').removeClass('needs-validation').addClass('was-validated');

				if ($('#frmStep')[0].checkValidity()) {
					const workflowId = $('#wrkId').val();
					const stepName = $('#stepName').val();
					const stepDescription = $('#stepDescription').val();
					const stepDurationType = $('#stepDurationType option:selected').val();
					const stepDuration = $('#stepDuration').data('kendoNumericTextBox').value();

					const postData = {
						workflowId,
						name: stepName,
						description: stepDescription,
						duration: stepDuration,
						durationType: stepDurationType,
					};

					var formData = new FormData();
					formData.append('WorkflowId', workflowId);
					formData.append('Name', stepName);
					formData.append('Description', stepDescription);
					formData.append('Duration', stepDuration);
					formData.append('DurationType', stepDurationType);

					$('.loading').show();

					const xhr = $.ajax({
						method: 'POST',
						url: '/@companyId/workflow/workflows/@Model?.WorkflowId/steps',
						data: formData,
						contentType: false,
						processData: false,
						cache: false,
						beforeSend: (xhr) => {
							xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
						},
					});

					xhr.done((response, status) => {
						if (!response.hasError) {
							$('#dlg').modal('hide');
							tbl.ajax.reload();
						}
					});

					xhr.fail((response, status) => {
					});

					xhr.always(() => {
						$('.loading').hide();
					});
				}

			});


			/**
			 * Button event handler
			 */
			$('.btn-save-edit-step').click(() => {
				$('#frmEditStep').removeClass('needs-validation').addClass('was-validated');

				if ($('#frmEditStep')[0].checkValidity()) {
					var stepId = $('#editStepId').val();

					if (stepId != null && stepId != '') {
						const stepName = $('#editStepName').val();
						const stepDesc = $('#editStepDescription').val();
						const stepDuration = $('#editStepDuration').data('kendoNumericTextBox');
						const stepDurationType = $('#editStepDurationType option:selected').val();

						const postData = {
							id: stepId,
							name: stepName,
							description: stepDesc,
							duration: stepDuration.value(),
							durationType: stepDurationType,
						};

						var formData = new FormData();
						formData.append('Id', stepId);
						formData.append('Name', stepName);
						formData.append('Description', stepDesc);
						formData.append('Duration', stepDuration.value());
						formData.append('DurationType', stepDurationType);

						$('.loading').show();

						const post = $.ajax({
							url: '/@companyId/workflow/workflows/steps',
							method: 'PUT',
							data: formData,
							contentType: false,
							processData: false,
							cache: false,
							beforeSend: (xhr) => {
								xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
							},
						});

						post.done((response, status) => {
							if (response.success) {
								tbl.ajax.reload();
							}
						});

						post.fail((response, status) => {
							alert('Unable to process your request at the moment. Please try again. If persists, please contact the system administrator.');
						});

						post.always(() => {
							$('.loading').hide();
						});
					}
				}
			});


			$('.btn-add-selected-users').click(() => {
				tblApprovers.clear().draw();
				tblApprovers.data = approvers;
				tblApprovers.rows.add(approvers).draw();

				let arrayOfIds = [];

				approvers.forEach((val) => {
					arrayOfIds.push(val.id);
				});

				const workflowStepId = $('#editStepId').val();
				const postData = {
					approvers: arrayOfIds,
				};

				var formData = new FormData();
				formData.append('Approvers', arrayOfIds);

				const xhr = $.ajax({
					method: 'PUT',
					url: '/@companyId/workflow/steps/' + workflowStepId + '/approvers',
					data: formData,
					contentType: false,
					processData: false,
					cache: false,
					beforeSend: (xhr) => {
						xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
					},
				});

				xhr.done((response, status) => {
					if (response.data == 'OK') {
					}
				});
			});


			/**
			 * Tab event handlers
			 */
			$('button[data-bs-toggle="tab"]').on('shown.bs.tab', (e) => {
				if (e.currentTarget.id == 'general-tab') {
					$('#frmEditStep').removeClass('was-validated').addClass('needs-validation');

					$('#editStepName').val(null);
					$('#editStepDescription').val(null);
					$('#editStepDuration').data('kendoNumericTextBox').value(0);
					$('#editStepDurationType option[value=""]').prop('selected', 'selected');

					$('.form-workflow-step').hide();
				}

				if (e.currentTarget.id == 'steps-tab') {
					if (tbl == null) {
						tbl = $('#tbl').DataTable({
							responsive: true,
							pageLength: 10,
							searching: false,
							paging: false,
							ordering: false,
							ajax: '/@companyId/workflow/workflows/@Model?.WorkflowId/steps',
							columns: [
								{ data: 'name' },
								{ data: 'description' },
								{
									data: 'duration',
									render: (data, type, row) => {
										if (!row.isFirst && !row.isLast) {
											return data + ' ' + row.durationType;
										}

										return '';
									}
								},
								{
									data: 'id', render: (data, type, row) => {
										var icons = '<div class="d-flex flex-row justify-content-end action-icons">';

										if (row.stepOrder > 0 && !row.isFirst && !row.isLast) {
											if (row.stepOrder > 1) {
												icons += '<a href="javascript:;" class="no-loading text-primary" data-up="true" data-workflow="@Model?.WorkflowId" data-id="' + data + '" data-current="' + row.stepOrder + '" data-prev="' + (row.stepOrder - 1) + '" data-next="' + (row.stepOrder + 1) + '" onclick="moveUpDown(this)">';
												icons += '<i class="fa-sharp fa-solid fa-chevron-up fa-lg"></i></a>';
											}

											if ((row.numOfSteps - 2) != row.stepOrder) {
												icons += '<a href="javascript:;" class="no-loading text-primary" data-up="false" data-workflow="@Model?.WorkflowId" data-id="' + data + '" data-current="' + row.stepOrder + '" data-prev="' + (row.stepOrder - 1) + '" data-next="' + (row.stepOrder + 1) + '" onclick="moveUpDown(this)">';
												icons += '<i class="fa-sharp fa-solid fa-chevron-down fa-lg"></i></a>';
											}

											icons += '<a href="javascript:;" class="no-loading text-secondary" onclick="editWorkflowStep(\'' + data + '\')"><i class="fa-solid fa-money-check-pen fa-lg"></i></a>';
											icons += '<a href="javascript:;" class="no-loading text-danger" onclick="deleteWorkflowStep(\'' + data + '\')"><i class="fa-solid fa-trash-xmark fa-lg"></i></a>';
										}

										icons += '</div>';

										return icons;
									}
								}
							]
						});
					}
				}

				if (e.currentTarget.id == 'general-editStep-tab') {
				}

				if (e.currentTarget.id == 'users-editStep-tab') {
					if (tblApprovers == null) {
						tblApprovers = $('#tblApprovers').DataTable({
							data: approvers,
							responsive: true,
							pageLength: 10,
							searching: false,
							paging: false,
							ordering: false,
							columns: [
								{
									data: 'id',
									render: (data, type, row) => {
										return row.firstName + ' ' + row.lastName;
									}
								},
								{ data: 'email' },
								{
									data: 'id',
									render: (data, type, row) => {
										return '<a href="javascript:;" class="no-loading text-danger" onclick="deleteUser(\'' + data + '\')"><i class="fa-solid fa-trash-xmark fa-lg"></i></a>';
									}
								},
							],
						});
					} else {
						reloadApprovers();
					}
				}

			});


			/**
			 * Modal event handlers: dlg
			 */
			$('#dlg').on('show.bs.modal', (e) => {
				$('#frmStep').removeClass('was-validated').addClass('needs-validation');
				$('#workflowId').val(null);
				$('#stepName').val(null);
				$('#stepDescription').val(null);
				$('#stepDurationType option[value=""]').prop('selected', 'selected');
				$('#stepDuration').data('kendoNumericTextBox').value(0);
			});


			/**
			 * Modal event handlers: dlgUsers
			 */
			$('#dlgUsers').on('show.bs.modal', (e) => {
				if (tblUsers == null) {
					tblUsers = $('#tblUsers').DataTable({
						ajax: '/@companyId/users/workflowusers/all',
						responsive: true,
						pageLength: 10,
						searching: false,
						paging: false,
						ordering: false,
						columns: [
							{
								data: 'id',
								render: (data, type, row) => {
									return row.firstName + ' ' + row.lastName;
								}
							},
							{ data: 'email' },
							{
								data: 'id',
								render: (data, type, row) => {
									return '<input type="checkbox" class="form-check-input select-user-check" data-user-id="' + data + '" data-email="' + row.email + '" data-first-name="' + row.firstName + '" data-last-name="' + row.lastName + '" onchange="selectUser($(this))">';
								}
							},
						],
					});
				}
			});


			/**
			 * Modal event handlers: dlgUsers
			 */
			$('#dlgUsers').on('hide.bs.modal', (e) => {
				$('.select-user-check').prop('checked', false);
			});
		});


		const moveUpDown = (e) => {
			const elem = $(e);
			const postData = {
				current: elem.data('current'),
				previous: elem.data('prev'),
				next: elem.data('next'),
				moveUp: elem.data('up'),
			};

			const xhr = $.ajax({
				method: 'PUT',
				url: '/@companyId/workflow/workflows/' + elem.data('workflow') + '/steps/' + elem.data('id') + '/move',
				data: JSON.stringify(postData),
				contentType: 'application/json; charset=utf-8',
				dataType: 'json',
			});

			$('.loading').show();

			xhr.done((response, status) => {
				if (!response.hasError) {
					tbl.ajax.reload();
				}
			});

			xhr.always(() => {
				$('.loading').hide();
			});
		};


		const editWorkflowStep = (e) => {
			$('#frmEditStep').removeClass('was-validated').addClass('needs-validation');

			$('#editStepId').val(null);
			$('#editStepName').val(null);
			$('#editStepDescription').val(null);
			$('#editStepDuration').data('kendoNumericTextBox').value(0);
			$('#editStepDurationType option[value=""]').prop('selected', 'selected');

			const xhr = $.ajax({
				method: 'GET',
				url: '/@companyId/workflow/steps/' + e,
			});

			$('.loading').show();

			xhr.done((data, status) => {
				if (data != null) {
					$('#editStepId').val(data.id);
					$('#editStepName').val(data.name);
					$('#editStepDescription').val(data.description);
					$('#editStepDuration').data('kendoNumericTextBox').value(data.duration);
					$('#editStepDurationType option[value="' + data.durationType + '"]').prop('selected', 'selected');

					approvers = data.approvers;

					$('.form-workflow-step').show();

					const btn = $('#general-editStep-tab');
					btn.click();

				}
			});

			xhr.always(() => {
				$('.loading').hide();
			});
		};


		const deleteWorkflowStep = (e) => {
			$('.loading').toggle();

			const xhr = $.ajax({
				method: 'DELETE',
				url: '/@companyId/workflow/workflows/@Model?.WorkflowId/steps/' + e,
			});

			xhr.done((response, status) => {
				if (!response.hasError) {
					tbl.ajax.reload();
				}
			});

			xhr.fail((response, status) => {
			});

			xhr.always(() => {
				$('.loading').hide();
			});
		};


		const selectUser = (e) => {
			const userId = e.data('userId');
			const firstName = e.data('firstName');
			const lastName = e.data('lastName');
			const email = e.data('email');
			const isChecked = e.is(':checked');
			let i = -1;

			approvers.findIndex((val, idx) => {
				if (val.id == userId) {
					i = idx;
				}
			});

			if (isChecked) {
				if (i == -1) {
					approvers.push({
						id: userId,
						email,
						firstName,
						lastName,
					});
				}
			} else {
				if (i > -1) {
					approvers.splice(i, 1);
				}
			}


		};


		const deleteUser = (e) => {
			let i = -1;

			approvers.findIndex((val, idx) => {
				if (val.id == e) {
					i = idx;

					const workflowStepId = $('#editStepId').val();
					const xhr = $.ajax({
						method: 'DELETE',
						url: '/@companyId/workflow/steps/' + workflowStepId + '/approvers/' + e,
					});
				}
			});

			if (i > -1) {
				approvers.splice(i, 1);
				reloadApprovers();
			}
		};


		const reloadTable = () => {
			tbl.ajax.reload();
			$.fn.dataTable
				.tables({ visible: true, api: true })
				.columns.adjust();
		};


		const reloadApprovers = () => {
			tblApprovers.clear().draw();
			tblApprovers.data = approvers;
			tblApprovers.rows.add(approvers).draw();
		};

	</script>
}