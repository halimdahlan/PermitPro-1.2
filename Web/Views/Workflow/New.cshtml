@{
	ViewData["Title"] = "Settings / Workflow";
	ViewData["SubTitle"] = "New workflow";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
	<nav aria-label="breadcrumb">
		<ol class="breadcrumb">
			<li class="breadcrumb-item"><a asp-asp-controller="workflow" asp-action="index">Workflow</a></li>
			<li class="breadcrumb-item active" aria-current="page">Span</li>
		</ol>
	</nav>
</div>

<div class="form-workflow">
	<div class="form-group">
		<label class="form-label">Workflow name</label>
		<input type="text" class="form-control" />
	</div>
	<div class="form-group">
		<label class="form-label">Description</label>
		<textarea class="form-control"></textarea>
	</div>
	<div class="form-group mb-3 d-flex flex-row align-items-center">
		<div class="form-check me-5">
			<input class="form-check-input" type="checkbox" id="ctrl04" name="ctrl04" checked>
			<label class="form-check-label" for="ctrl04">Is in use?</label>
		</div>
	</div>
	<div class="form-group mb-3 d-flex flex-row align-items-center">
		<div class="form-check me-5">
			<input class="form-check-input" type="radio" id="ctrl04" name="ctrl05" checked>
			<label class="form-check-label" for="ctrl05">Active</label>
		</div>
		<div class="form-check">
			<input class="form-check-input" type="radio" id="ctrl05" name="ctrl06">
			<label class="form-check-label" for="ctrl06">Inactive</label>
		</div>
	</div>

	<div class="d-flex flex-row align-items-center justify-content-between mt-5">
		<div>
			<a asp-controller="workflow" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
		</div>
		<button type="button" class="btn btn-primary"><span class="mx-3">Submit</span></button>
	</div>
</div>

@section CustomCss {
	<!-- DataTables -->
	<link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />
	<script src="~/lib/DataTables/datatables.min.js"></script>

	<link rel="stylesheet" href="~/css/workflows.css" />
}