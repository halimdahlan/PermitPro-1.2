@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Settings / Workflow";
	ViewData["SubTitle"] = "Summary";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model WorkflowViewModel

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
	<div class="d-flex flex-row align-items-center">
		<div class="me-3">View by</div>
		<button type="button" class="btn btn-sm btn-dark rounded-pill me-2 btn-filter">ALL</button>
		<button type="button" class="btn btn-sm btn-secondary rounded-pill me-2 btn-filter">ACTIVE</button>
		<button type="button" class="btn btn-sm btn-secondary rounded-pill me-2 btn-filter">INACTIVE</button>
		<!--
		<span class="badge rounded-pill text-bg-secondary me-2 active">ALL</span>
		<span class="badge rounded-pill text-bg-secondary me-2">ACTIVE</span>
		<span class="badge rounded-pill text-bg-secondary me-2">INACTIVE</span>
		-->
	</div>
	<div>
		<a href="#dlgNew" class="btn btn-primary no-loading" data-bs-toggle="modal" data-bs-target="#dlgNew">
			<span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New workflow</span>
		</a>
	</div>
</div>

<div class="mt-5">
	@Html.AntiForgeryToken()
	@(Html.Kendo()
		.Grid<WorkflowGridViewModel>()
		.Name("grid")
		.ToolBar(tb => tb.Search())
		.NoRecords()
		.Pageable()
		.Sortable()
		.DataSource(ds => ds
		.Custom()
		.Schema(s => s
		.Model(m =>
		{
			m.Id(i => i.Id);
		})
		)
		.Transport(t =>
		{
			t.Read(r => r.Url($"/{companyId}/workflow/grid").Type(HttpVerbs.Get));
		})
		.PageSize(20)
		)
		.Columns(c =>
		{
			c.Bound(f => f.Name).ClientTemplate(
			$"<a href=\"/{companyId}/workflow/edit/#=Id#\" class=\"text-info\">#=Name#</a>");

			c.Bound(f => f.Description);

			c.Bound(f => f.IsActive).Sortable(false).ClientTemplate(
			"# if (IsActive) { #" +
			"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
			"# } else { #" +
			"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-warning\"></i>" +
			"# } #").HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(120);

			c.Bound(f => f.HasCertificates).Sortable(false).ClientTemplate(
			"# if (HasCertificates) { #" +
			"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
			"# } else { #" +
			"    &nbsp;" +
			"# } #").HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(200);

			c.Bound(f => f.CreatedWhen).Format("{0:dd MMM, yyyy}").Width(150);
			c.Bound(f => f.ActionIcons).Sortable(false).Encoded(false).HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(110);
		})
		)
</div>

