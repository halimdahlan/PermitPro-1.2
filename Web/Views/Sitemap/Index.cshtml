@{
	ViewData["Title"] = "Permit";
	ViewData["SubTitle"] = "Site Map";
	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model SitemapViewModel

<div class="permit-map-page">

	@* ── Filter bar ──────────────────────────────────────── *@
	<div class="map-filter-bar">
		<div class="d-flex align-items-center gap-3 flex-wrap">
			<span class="map-section-label">Filter by status:</span>
			<div class="map-filter-chips">
				<button class="map-chip active" data-filter="active">
					<i class="fa-solid fa-circle-check me-1" style="font-size:.68rem;"></i>Active
				</button>
				<button class="map-chip chip-pending" data-filter="pending">
					<i class="fa-solid fa-clock me-1" style="font-size:.68rem;"></i>Pending
				</button>
				<button class="map-chip chip-approved" data-filter="approved">
					<i class="fa-solid fa-thumbs-up me-1" style="font-size:.68rem;"></i>Approved
				</button>
				<button class="map-chip chip-suspended" data-filter="suspended">
					<i class="fa-solid fa-pause me-1" style="font-size:.68rem;"></i>Suspended
				</button>
				<button class="map-chip" data-filter="all">All</button>
			</div>
		</div>
		<div class="d-flex align-items-center gap-2">
			<i class="fa-solid fa-location-dot" style="color:#e74c3c;font-size:.85rem;"></i>
			<span class="map-marker-count" id="markerCount">Loading…</span>
		</div>
	</div>

	@* ── Map ─────────────────────────────────────────────── *@
	<div class="map-container">
		<div id="map"></div>

		@* Legend *@
		<div class="map-legend">
			<div class="map-legend-title">Permit Types</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#f38001;">HW</span>
				<span class="map-legend-label">Hot Work</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#e74c3c;">CS</span>
				<span class="map-legend-label">Confined Space</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#e67e22;">RA</span>
				<span class="map-legend-label">Radiation</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#2c7be5;">EX</span>
				<span class="map-legend-label">Excavation</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#9b59b6;">IS</span>
				<span class="map-legend-label">Isolation</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#27ae60;">MS</span>
				<span class="map-legend-label">Method Statement</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#1abc9c;">LH</span>
				<span class="map-legend-label">Lifting &amp; Hoisting</span>
			</div>
			<div class="map-legend-item">
				<span class="map-legend-dot" style="background:#95a5a6;">OV</span>
				<span class="map-legend-label">Override</span>
			</div>
		</div>
	</div>

</div>

<input type="hidden" id="hidCompanyId" value="@companyId" />
<input type="hidden" id="hidLat" value="@Model.Latitude" />
<input type="hidden" id="hidLng" value="@Model.Longitude" />

@section CustomCss {
	<link href="~/css/sitemap.css" rel="stylesheet" />
}

@section Scripts {
<script>
(g => {
	var h, a, k, p = "The Google Maps JavaScript API", c = "google", l = "importLibrary", q = "__ib__", m = document, b = window;
	b = b[c] || (b[c] = {});
	var d = b.maps || (b.maps = {}), r = new Set, e = new URLSearchParams,
	u = () => h || (h = new Promise(async (f, n) => {
		await (a = m.createElement("script")); e.set("libraries", [...r] + "");
		for (k in g) e.set(k.replace(/[A-Z]/g, t => "_" + t[0].toLowerCase()), g[k]);
		e.set("callback", c + ".maps." + q); a.src = `https://maps.${c}apis.com/maps/api/js?` + e;
		d[q] = f; a.onerror = () => h = n(Error(p + " could not load.")); a.nonce = m.querySelector("script[nonce]")?.nonce || "";
		m.head.append(a);
	})); d[l] ? console.warn(p + " only loads once. Ignoring:", g) : d[l] = (f, ...n) => r.add(f) && u().then(() => d[l](f, ...n));
})({ key: "AIzaSyAvl1p58jpa2Nu_LVYK3gFdezNna4Puk8A", v: "weekly" });

// ── Permit type definitions ─────────────────────────────
const PERMIT_TYPES = [
	{ name: 'hotwork',         abbr: 'HW', label: 'Hot Work',           color: '#f38001' },
	{ name: 'confinedspace',   abbr: 'CS', label: 'Confined Space',     color: '#e74c3c' },
	{ name: 'radiation',       abbr: 'RA', label: 'Radiation',          color: '#e67e22' },
	{ name: 'excavation',      abbr: 'EX', label: 'Excavation',         color: '#2c7be5' },
	{ name: 'isolation',       abbr: 'IS', label: 'Isolation',          color: '#9b59b6' },
	{ name: 'methodStatement', abbr: 'MS', label: 'Method Statement',   color: '#27ae60' },
	{ name: 'liftingHoisting', abbr: 'LH', label: 'Lifting & Hoisting', color: '#1abc9c' },
	{ name: 'override',        abbr: 'OV', label: 'Override',           color: '#95a5a6' },
];

// ── Helpers ─────────────────────────────────────────────

function permitMatchesFilter(status, filter) {
	switch (filter) {
		case 'pending':   return status === 1;
		case 'approved':  return status === 2;
		case 'suspended': return status === 4;
		case 'all':       return true;
		default:          // active: exclude Draft(0), Suspended(4), KIV(5), Closed(6)
			return status !== 0 && status !== 4 && status !== 5 && status !== 6;
	}
}

function countTypes(permits, filter) {
	const counts = {};
	PERMIT_TYPES.forEach(t => { counts[t.name] = 0; });

	(permits || []).forEach(permit => {
		if (!permitMatchesFilter(permit.permitStatus, filter)) return;
		if (!permit.permitForm) return;
		try {
			const form = JSON.parse(permit.permitForm);
			(form?.general?.certificates || []).forEach(cert => {
				if (counts[cert.name] !== undefined) counts[cert.name]++;
			});
		} catch { /* skip malformed JSON */ }
	});

	return PERMIT_TYPES
		.filter(t => counts[t.name] > 0)
		.map(t => ({ ...t, count: counts[t.name] }));
}

// ── Pin HTML ────────────────────────────────────────────

function buildPinElement(site, filter) {
	const types = countTypes(site.permits, filter);
	const el = document.createElement('div');
	el.className = 'map-pin';

	let typesHtml = '';
	if (types.length > 0) {
		typesHtml = '<div class="map-pin-types">' +
			types.map(t =>
				`<div class="map-pin-row">
					<span class="map-pin-badge" style="background:${t.color};">${t.abbr}</span>
					<span class="map-pin-count">${t.count}</span>
				</div>`
			).join('') + '</div>';
	} else {
		typesHtml = '<div class="map-pin-no-permits">No permits</div>';
	}

	el.innerHTML =
		`<div class="map-pin-header">
			<i class="fa-solid fa-location-dot me-1" style="color:#2c7be5;font-size:8px;"></i>${site.name}
		</div>${typesHtml}`;

	return el;
}

// ── Info window HTML ─────────────────────────────────────

function buildInfoContent(site) {
	const allTypes = countTypes(site.permits, 'all');
	const total = (site.permits || []).length;

	const rows = allTypes.length > 0
		? allTypes.map(t =>
			`<tr>
				<td><span class="map-info-badge" style="background:${t.color};">${t.abbr}</span></td>
				<td>${t.label}</td>
				<td class="map-info-count">${t.count}</td>
			</tr>`
		).join('')
		: `<tr><td colspan="3" style="color:#a0aec0;text-align:center;padding:8px 0;">No permit data</td></tr>`;

	return `<div class="map-info-window">
		<div class="map-info-title">
			<i class="fa-solid fa-location-dot" style="color:#2c7be5;"></i>
			${site.name}
		</div>
		<table class="map-info-table">
			<thead>
				<tr>
					<th style="width:28px;"></th>
					<th>Type</th>
					<th style="text-align:right;">Count</th>
				</tr>
			</thead>
			<tbody>${rows}</tbody>
		</table>
		<div class="map-info-footer">
			<span>Total permits at this location</span>
			<strong>${total}</strong>
		</div>
	</div>`;
}

// ── Map state ────────────────────────────────────────────

let allSitesData = [];
let activeMarkers = [];
let currentFilter = 'active';
let mapInstance = null;
let infoWindowInstance = null;
let MarkerClass = null;

function renderMarkers() {
	if (!mapInstance || !MarkerClass) return;

	// Remove existing markers from map
	activeMarkers.forEach(m => { m.map = null; });
	activeMarkers = [];

	infoWindowInstance.close();

	let visible = 0;

	allSitesData.forEach(site => {
		if (!site.latitude || !site.longitude) return;

		const types = countTypes(site.permits, currentFilter);
		// Skip sites with no matching permits (except "all" filter)
		if (types.length === 0 && currentFilter !== 'all') return;

		const pinEl = buildPinElement(site, currentFilter);
		const marker = new MarkerClass({
			map: mapInstance,
			content: pinEl,
			position: {
				lat: parseFloat(site.latitude),
				lng: parseFloat(site.longitude),
			},
			title: site.name,
		});

		marker.addListener('click', () => {
			infoWindowInstance.setContent(buildInfoContent(site));
			infoWindowInstance.open({ anchor: marker, map: mapInstance });
		});

		activeMarkers.push(marker);
		visible++;
	});

	document.getElementById('markerCount').textContent =
		visible + ' location' + (visible !== 1 ? 's' : '');

	// Fit map to all visible markers
	if (activeMarkers.length > 0) {
		const bounds = new google.maps.LatLngBounds();
		activeMarkers.forEach(m => bounds.extend(m.position));
		mapInstance.fitBounds(bounds, { padding: 80 });
	}
}

// ── Init ─────────────────────────────────────────────────

async function initMap() {
	const { Map, InfoWindow } = await google.maps.importLibrary('maps');
	({ AdvancedMarkerElement: MarkerClass } = await google.maps.importLibrary('marker'));

	const lat = parseFloat(document.getElementById('hidLat').value) || 3.139;
	const lng = parseFloat(document.getElementById('hidLng').value) || 101.687;

	mapInstance = new Map(document.getElementById('map'), {
		zoom: 16,
		center: { lat, lng },
		mapId: 'dd60996d28e89f78',
		mapTypeId: google.maps.MapTypeId.SATELLITE,
		mapTypeControl: false,
		tilt: 0,
		zoomControl: true,
		fullscreenControl: true,
		streetViewControl: false,
	});

	infoWindowInstance = new InfoWindow({ maxWidth: 300 });

	// Close info window on map click
	mapInstance.addListener('click', () => infoWindowInstance.close());

	// Load site + permit data
	const companyId = document.getElementById('hidCompanyId').value;
	try {
		const resp = await fetch('/' + companyId + '/sites/map/locations');
		const data = await resp.json();
		if (data && data.length) {
			allSitesData = data;
			renderMarkers();
		} else {
			document.getElementById('markerCount').textContent = '0 locations';
		}
	} catch {
		document.getElementById('markerCount').textContent = 'Error loading data';
	}
}

// ── Filter chip click handler ─────────────────────────────

document.querySelectorAll('.map-chip').forEach(btn => {
	btn.addEventListener('click', function () {
		document.querySelectorAll('.map-chip').forEach(b => b.classList.remove('active'));
		this.classList.add('active');
		currentFilter = this.dataset.filter;
		renderMarkers();
	});
});

initMap();
</script>
}
