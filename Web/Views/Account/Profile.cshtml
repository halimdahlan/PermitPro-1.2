@using Kendo.Mvc.UI

@model ProfileViewModel

@{
	ViewData["Title"] = "Settings / User / Profile";
	ViewData["SubTitle"] = "User profile";

	var companyId = ViewContext.RouteData.Values["company"] as string;

	// var companyGuid = (ViewBag.CompanyGuid as string) ?? User.FindFirst("companyGuid")?.Value ?? "";
	var profileId = Model.UserId;
	var avatarSrc = Model.ProfileImageUrl;
	var isOwnProfile = profileId?.ToString() == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

@* ── Profile header ──────────────────────────────────────────────────────────── *@
<div class="d-flex align-items-center gap-4 mb-4">
	<div class="position-relative flex-shrink-0">
		<img src="@avatarSrc" id="avatarImg"
			  width="80" height="80" class="rounded-circle object-fit-cover border shadow-sm" />
		<label for="avatarInput"
				 class="btn btn-sm btn-primary position-absolute bottom-0 end-0 rounded-circle p-1"
				 style="width:26px;height:26px;line-height:1" title="Change photo">
			<i class="fa-regular fa-camera" style="font-size:.65rem"></i>
		</label>
		<input type="file" id="avatarInput" class="d-none" accept=".png,.jpg,.jpeg,.gif,.webp" />
	</div>
	<div>
		<h2 class="h4 fw-bold mb-1">@Model.FirstName @Model.LastName</h2>
		<div class="d-flex flex-wrap gap-1 mb-1">
			@if (Model.IsSuperAdmin)
			{
				<span class="badge bg-primary"><i class="fa-regular fa-shield-check me-1"></i>Super Admin</span>
			}
			@foreach (var role in Model.RoleNames)
			{
				<span class="badge bg-secondary-subtle text-secondary">@role</span>
			}
		</div>
		<div class="text-muted small">@Model.Email</div>
		<div id="avatarError" class="text-danger small d-none mt-1"></div>
		<div id="avatarSuccess" class="text-success small d-none mt-1"></div>
	</div>
</div>

<div class="row g-4">

	@* ── Personal information ─────────────────────────────────────────────────── *@
	<div class="col-12 col-lg-6">
		<div class="card shadow-sm">
			<div class="card-header h4 py-2 px-3">Personal Information</div>
			<div class="card-body p-4">
				<form method="post" action="/@companyId/account/profile">
					@Html.AntiForgeryToken()
					<div class="row g-3">
						<div class="col-6">
							<label class="form-label small fw-semibold">First Name <span class="text-danger">*</span></label>
							<input asp-for="FirstName" class="form-control" />
							<span asp-validation-for="FirstName" class="text-danger small"></span>
						</div>
						<div class="col-6">
							<label class="form-label small fw-semibold">Last Name <span class="text-danger">*</span></label>
							<input asp-for="LastName" class="form-control" />
							<span asp-validation-for="LastName" class="text-danger small"></span>
						</div>
						<div class="col-12">
							<label class="form-label small fw-semibold">Email</label>
							<input value="@Model.Email" class="form-control bg-light" readonly />
							<div class="form-text">Email cannot be changed here.</div>
						</div>
						<div class="col-6">
							<label class="form-label small fw-semibold">Designation</label>
							<input asp-for="Designation" class="form-control" />
							<span asp-validation-for="Designation" class="text-danger small"></span>
						</div>
						<div class="col-6">
							<label class="form-label small fw-semibold">Phone</label>
							<input asp-for="PhoneNumber" type="tel" class="form-control" />
							<span asp-validation-for="PhoneNumber" class="text-danger small"></span>
						</div>
					</div>
					<hr class="my-4" />
					<button type="submit" class="btn btn-sm btn-primary">
						<span class="px-3">Save Changes</span>
					</button>
					<input type="hidden" asp-for="UserId" />
				</form>
			</div>
		</div>
	</div>

	@* ── Change password ──────────────────────────────────────────────────────── *@
	<div class="col-12 col-lg-6">
		<div class="card shadow-sm">
			<div class="card-header h4 py-2 px-3">Change Password</div>
			<div class="card-body p-4">
				<form method="post" action="/@companyId/account/profile/change-password">
					@Html.AntiForgeryToken()
					<div class="mb-3">
						<label class="form-label small fw-semibold">Current Password <span class="text-danger">*</span></label>
						<input name="CurrentPassword" type="password" class="form-control"
								 autocomplete="current-password" placeholder="Enter current password" />
					</div>
					<div class="mb-3">
						<label class="form-label small fw-semibold">New Password <span class="text-danger">*</span></label>
						<input name="NewPassword" type="password" class="form-control"
								 autocomplete="new-password" placeholder="Min. 8 characters" />
					</div>
					<div class="mb-4">
						<label class="form-label small fw-semibold">Confirm New Password <span class="text-danger">*</span></label>
						<input name="ConfirmPassword" type="password" class="form-control"
								 autocomplete="new-password" placeholder="Repeat new password" />
					</div>
					<hr class="my-4" />
					<button type="submit" class="btn btn-sm btn-outline-primary">
						<span class="px-3">Change Password</span>
					</button>
					<input type="hidden" asp-for="UserId" />
				</form>
			</div>
		</div>
	</div>
</div>


@section CustomCss {
	<link href="~/css/profile.css" rel="stylesheet" />
	<style>
		.avatar-profile {
			position: relative;
			overflow: hidden;
			background-color: #f0f4f8;
			border-radius: 50%;
		}

		.avatar-profile::after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			background: radial-gradient(circle at top-left, rgba(255,255,255,0.3), transparent);
			pointer-events: none;
		}

		.card {
			transition: all 0.3s ease;
		}

		.card:hover {
			box-shadow: 0 8px 24px rgba(0,0,0,0.12) !important;
			transform: translateY(-2px);
		}

		.form-control, .k-input {
			border-color: #e0e0e0;
			transition: border-color 0.2s;
		}

		.form-control:focus, .k-input:focus {
			border-color: #0d6efd;
			box-shadow: 0 0 0 0.2rem rgba(13, 110, 253, 0.15);
		}

		.btn-primary {
			font-weight: 500;
			letter-spacing: 0.3px;
		}

		.modal-content {
			border-radius: 12px;
			overflow: hidden;
		}

		.alert-sm {
			padding: 0.75rem 1rem;
			border-radius: 8px;
			margin-bottom: 0;
			font-size: 0.9rem;
		}

		.fw-500 {
			font-weight: 500;
		}

		.toggle-password {
			cursor: pointer;
		}

		.toggle-password:hover {
			background-color: #e9ecef;
		}
	</style>
}

@section Scripts {
	<script>
		document.getElementById('avatarInput').addEventListener('change', async function () {
			const file = this.files[0];
			if (!file) return;

			$('.loading').show();

			const errEl = document.getElementById('avatarError');
			const okEl  = document.getElementById('avatarSuccess');
			errEl.classList.add('d-none');
			okEl.classList.add('d-none');

			const form = new FormData();
			form.append('file', file);

			const res = await fetch('/@companyId/account/profile/upload-avatar', {
				method: 'POST',
				headers: { 'RequestVerificationToken': document.querySelector('[name="__RequestVerificationToken"]').value },
				body: form
			});

			$('.loading').hide();

			if (!res.ok) {
				const err = await res.json().catch(() => ({ error: 'Upload failed.' }));
				errEl.textContent = err.error;
				errEl.classList.remove('d-none');
				return;
			}

			const { path } = await res.json();

			document.getElementById('avatarImg').src = '/img/profiles/' + path + '?t=' + Date.now();
			document.getElementById('topbarUserAvatar').src = '/img/profiles/' + path + '?t=' + Date.now(); // Update any other avatar images if present

			okEl.textContent = 'Photo updated.';
			okEl.classList.remove('d-none');
		});
	</script>
}
