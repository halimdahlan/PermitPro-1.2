@{
	Layout = "_LayoutAnon";
	ViewData["Title"] = "Sign In";
}

@model SignInViewModel

<div class="login-page">
	<div class="login-card">

		<!-- Logo -->
		<div class="login-logo">
			<div class="logo-icon">
				<i class="fa-solid fa-helmet-safety"></i>
			</div>
			<div class="logo-text">PermitPro</div>
			<div class="logo-sub">Permit-to-Work Management System</div>
		</div>

		<h5 class="login-heading">Welcome back</h5>
		<p class="login-sub">Sign in to continue to your dashboard</p>

		<form method="post" asp-controller="account" asp-action="login">

			@* Validation summary *@
			@if (!ViewData.ModelState.IsValid)
			{
				<div class="validation-summary-errors mb-3">
					@Html.ValidationSummary(false)
				</div>
			}

			<!-- Company -->
			<div class="mb-3">
				<label asp-for="CompanyId" class="form-label">@Html.DisplayNameFor(f => f.CompanyId)</label>
				<div class="input-group input-group-icon">
					<span class="input-group-text">
						<i class="fa-solid fa-building"></i>
					</span>
					<select class="form-control form-select" style="border-left:none;" required
					        asp-for="CompanyId"
					        asp-items="@(new SelectList(ViewBag.CompanyList, "Id", "Name"))">
						<option value="">Select your company…</option>
					</select>
				</div>
				<span asp-validation-for="CompanyId" class="text-danger"></span>
			</div>

			<!-- Email -->
			<div class="mb-3">
				<label asp-for="Email" class="form-label">@Html.DisplayNameFor(f => f.Email)</label>
				<div class="input-group input-group-icon">
					<span class="input-group-text">
						<i class="fa-regular fa-envelope"></i>
					</span>
					<input asp-for="Email" class="form-control" placeholder="you@company.com" required />
				</div>
				<span asp-validation-for="Email" class="text-danger"></span>
			</div>

			<!-- Password -->
			<div class="mb-3">
				<div class="d-flex justify-content-between align-items-center mb-1">
					<label asp-for="Password" class="form-label mb-0">@Html.DisplayNameFor(f => f.Password)</label>
					<a href="~/account/forgot" style="font-size:.72rem;color:#2c7be5;text-decoration:none;font-weight:600;">Forgot password?</a>
				</div>
				<div class="input-group input-group-icon">
					<span class="input-group-text">
						<i class="fa-solid fa-lock"></i>
					</span>
					<input asp-for="Password" id="passwordInput" class="form-control"
					       placeholder="••••••••••••" required />
					<button type="button" class="btn-pwd-toggle input-group-text"
					        onclick="togglePassword()" title="Show/hide password">
						<i class="fa-regular fa-eye" id="pwdToggleIcon"></i>
					</button>
				</div>
				<span asp-validation-for="Password" class="text-danger"></span>
			</div>

			<!-- Remember me -->
			<div class="mb-4 d-flex align-items-center">
				<input class="form-check-input me-2" asp-for="RememberMe" style="accent-color:#2c7be5;width:16px;height:16px;" />
				<label class="form-check-label" asp-for="RememberMe">
					@Html.DisplayNameFor(m => m.RememberMe) for 30 days
				</label>
			</div>

			<!-- Submit -->
			<button id="btnSubmit" type="submit" class="btn btn-login w-100">
				<i class="fa-solid fa-arrow-right-to-bracket me-2"></i> Sign In
			</button>

			<!-- Hidden fields -->
			<input type="hidden" asp-for="Token" />
			<input type="hidden" asp-for="ReturnUrl" />
			<input type="hidden" asp-for="Entity" />
			<input type="hidden" asp-for="EntityId" />
			<input type="hidden" asp-for="Origin" />

		</form>

		<p class="login-footer-note">
			Protected by PermitPro &bull; v1.2
		</p>

	</div>
</div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/login.css" />
}

@section Scripts {
	<script>
		function togglePassword() {
			var input = document.getElementById('passwordInput');
			var icon = document.getElementById('pwdToggleIcon');
			if (input.type === 'password') {
				input.type = 'text';
				icon.className = 'fa-regular fa-eye-slash';
			} else {
				input.type = 'password';
				icon.className = 'fa-regular fa-eye';
			}
		}
	</script>
}
