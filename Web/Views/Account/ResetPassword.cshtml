@{
	Layout = "_LayoutAnon";
	ViewData["Title"] = "Reset Password";
}

@model ResetPasswordViewModel

<div class="d-flex flex-row justify-content-center mt-5">
	<div class="flex-grow-1 pt-5" style="max-width: 400px;">
		@if (!Model.ResetOK)
		{
			<div class="d-flex flex-column align-items-center">
				<h1 class="mb-3">Reset Password</h1>
				<p class="text-secondary">Please enter your new password to proceed</p>
			</div>
			<div class="mt-3">
				<form method="post">
					<div class="mb-3">
						<label asp-for="Password" class="form-label">@Html.DisplayNameFor(f => f.Password)</label>
						<input asp-for="Password" class="form-control" />
						<span asp-validation-for="Password" class="text-danger"></span>
					</div>
					<div class="mb-3">
						<label asp-for="ConfirmPassword" class="form-label">@Html.DisplayNameFor(f => f.ConfirmPassword)</label>
						<input asp-for="ConfirmPassword" class="form-control" />
						<span asp-validation-for="ConfirmPassword" class="text-danger"></span>
					</div>
					<div class="mb-3">
						<button id="btnSubmit" type="submit" class="btn btn-primary w-100">Reset my password</button>
					</div>
					@if (Model.ErrorMessage != string.Empty)
					{
						<div class="mt-4 text-danger text-center">
							@Html.Raw(Model.ErrorMessage)
						</div>
					}
					<div asp-validation-summary="ModelOnly" class="text-danger"></div>
					<input type="hidden" asp-for="ResetToken" />
					<input type="hidden" asp-for="Id" />
					@Html.AntiForgeryToken()
				</form>
			</div>
		}
		else
		{
			<div class="d-flex flex-column align-items-center">
				<h1 class="mb-3">Reset Password</h1>
			</div>
			if (Model.Message != string.Empty)
			{
				<div class="text-center text-secondary">
					<h4>@Html.Raw(Model.Message)</h4>
				</div>
			}
		}
		<div class="text-center mt-5">
			<a href="~/">Back to login</a>
		</div>
	</div>
</div>