@{
	Layout = "_LayoutAnon";
	ViewData["Title"] = "Forgot Password";
}

@model ForgotPasswordViewModel

<div class="d-flex flex-row justify-content-center mt-5">
	<div class="flex-grow-1 pt-5" style="max-width: 400px;">
		<div class="d-flex flex-column align-items-center">
			<h1 class="mb-3">Forgot Password</h1>
			<p class="text-secondary">Enter your email to reset your password</p>
		</div>
		@if (!Model.EmailSent)
		{
			<div class="mt-3">
				<form method="post">
					<div class="mb-3">
						<label asp-for="Email" class="form-label">@Html.DisplayNameFor(f => f.Email)</label>
						<input asp-for="Email" class="form-control" />
						<span asp-validation-for="Email" class="text-danger"></span>
					</div>
					<div class="mb-3">
						<button id="btnSubmit" type="submit" class="btn btn-primary w-100">Send me the link</button>
					</div>
					@if (Model.ErrorMessage != string.Empty)
					{
						<div class="mt-4 text-danger text-center">
							@Html.Raw(Model.ErrorMessage)
						</div>
					}
					@Html.AntiForgeryToken()
				</form>
			</div>
		}
		else
		{
			if (Model.Message != string.Empty)
			{
				<div class="text-center text-secondary">
					<h4>@Html.Raw(Model.Message)</h4>
				</div>
			}
		}
		<div class="text-center mt-5">
			<a href="~/">Back to login</a>
		</div>
	</div>
</div>
