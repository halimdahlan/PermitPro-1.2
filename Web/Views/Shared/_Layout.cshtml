	<script nonce="3xecut3" src="~/lib/kendo-ui/js/jszip.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.all.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.pdf.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.pdfviewer.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/pako_deflate.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.aspnetmvc.min.js"></script>

	<!-- Web Awesome -->
