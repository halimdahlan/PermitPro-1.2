<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="description" content="PermitPro" />

	<!-- Favicon -->
	<link rel="shortcut icon" href="~/img/icons/favicon.ico" type="image/x-icon" />

	<!-- FontAwesome -->
	<link href="~/lib/fontawesome/css/all.min.css" rel="stylesheet">

	<!-- Bootstrap CSS -->
	<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />

	<!-- jQuery -->
	<script nonce="3xecut3" src="~/lib/jquery/jquery.min.js"></script>

	<!-- Numeral -->
	<script nonce="3xecut3" src="~/lib/numeral.js/numeral.min.js"></script>

	<!-- Moment -->
	<script nonce="3xecut3" src="~/lib/moment.js/moment-with-locales.min.js"></script>

	<!-- Bootstrap -->
	<!--
	<link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
	<script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
	-->
	
	<!-- Kendo UI -->
	<link href="~/lib/kendo-ui/styles/kendo.bootstrap-main.min.css" rel="stylesheet" type="text/css" />
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/jszip.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.all.min.js"></script>
	<script nonce="3xecut3" src="~/lib/kendo-ui/js/kendo.aspnetmvc.min.js"></script>

	@await RenderSectionAsync("CustomCss", required: false)

	<!-- Title -->
	<title>PermitPro / @ViewData["Title"]</title>
</head>
<body>
	<div class="loading">
		<div class="loading-icon">
			<div>
				<i class="fa-solid fa-loader fa-spin"></i>
			</div>
		</div>
	</div>
	<!-- NAVIGATION -->
	<nav class="navbar navbar-expand-md navbar-light" id="sidebar">
		<div class="container-fluid">

			<!-- Toggler -->
			<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse" aria-controls="sidebarCollapse" aria-expanded="false" aria-label="Toggle navigation">
				<span class="navbar-toggler-icon"></span>
			</button>

			<!-- Brand -->
			<div class="navbar-brand">
				<div>
					<div class="app-logo d-none d-md-block">
						<i class="fa-duotone fa-user-helmet-safety fa-2xl text-info"></i>
					</div>
					<div class="app-name">
						PermitPRO
					</div>
				</div>
			</div>

			<!-- User (xs) -->
			<div class="navbar-user d-md-none">
				<!-- Dropdown -->
				<!--
				<div class="dropdown">
					<a href="javascript:void(0)" id="sidebarIcon" class="dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
						<div class="avatar avatar-sm">
							<partial name="_UserAvatar" />
						</div>
					</a>
					<div class="dropdown-menu dropdown-menu-end" aria-labelledby="sidebarIcon">
						<a href="~/identity/account/manage" class="dropdown-item">Profile</a>
						<a href="~/account-general.html" class="dropdown-item">Settings</a>
						<hr class="dropdown-divider">
						<a href="/account/logout" class="dropdown-item">Logout</a>
					</div>
				</div>
				-->
			</div>

			<!-- Collapse -->
			<div class="collapse navbar-collapse" id="sidebarCollapse">

				<!-- Form -->
				<form class="mt-4 mb-3 d-md-none">
					<div class="input-group">
						<span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
						<input class="form-control" type="search" placeholder="Search" aria-label="Search">
					</div>
				</form>

				<!-- Navigation -->
				<partial name="_SideMenuPartial" />

				<!-- Push content down -->
				<div class="mt-auto"></div>


				<!-- User (md) -->
				<div class="navbar-user d-none d-md-flex" id="sidebarUser">
				</div>

			</div> <!-- / .navbar-collapse -->

		</div>
	</nav>

	<!-- MAIN CONTENT -->
	<div class="main-content">
		<!-- HEADER -->
		<div class="header">
			<div class="container-fluid">

				<div class="row justify-content-end">
					<div class="col">
						<partial name="_LoginPartial" />
					</div>
				</div>

				<partial name="_HeaderTitle" />

				@RenderBody()

			</div>
		</div> <!-- / .header -->
	</div><!-- / .main-content -->
	<!-- Bootstrap JS -->
	<script nonce="3xecut3" src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>

	<script nonce="3xecut3" src="~/js/loader.js"></script>

	@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
