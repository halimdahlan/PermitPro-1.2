@using PermitPro.App.Models
@model ErrorViewModel

@{
    Layout = "_LayoutAnon";
    ViewData["Title"] = $"Error {Model.StatusCode}";
}

<div class="d-flex align-items-center justify-content-center" style="min-height:70vh;">
    <div class="text-center" style="max-width:520px;">

        <div class="mb-4">
            @if (Model.StatusCode == 404)
            {
                <i class="fa-regular fa-magnifying-glass fa-4x text-muted"></i>
            }
            else if (Model.StatusCode == 403 || Model.StatusCode == 401)
            {
                <i class="fa-regular fa-lock fa-4x text-warning"></i>
            }
            else
            {
                <i class="fa-regular fa-triangle-exclamation fa-4x text-danger"></i>
            }
        </div>

        <h1 class="display-4 fw-bold text-dark mb-1">@Model.StatusCode</h1>
        <p class="lead text-muted mb-4">@Model.Message</p>

        <div class="d-flex justify-content-center gap-2">
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i> Go Back
            </a>
            <a href="/" class="btn btn-primary btn-sm">
                <i class="fa-solid fa-house me-1"></i> Home
            </a>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="mt-4 text-muted" style="font-size:.75rem;">
                Reference: <code>@Model.RequestId</code>
            </p>
        }

    </div>
</div>
