@{
	ViewData["Title"] = "Notifications";
	ViewData["SubTitle"] = "Inbox";
	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model NotificationsPageViewModel

<div class="notif-page col-12 col-lg-6">

	<div class="notif-toolbar">
		<div class="notif-toolbar-left">
			<span class="notif-count-badge @(Model.UnreadCount > 0 ? "" : "d-none")" id="pageUnreadCount">
				@Model.UnreadCount unread
			</span>
		</div>
		<div class="notif-toolbar-right">
			<button class="btn btn-sm btn-outline-secondary no-loading" id="btnMarkAllRead" @(Model.UnreadCount == 0 ? "disabled" : "")>
				<i class="fa-solid fa-check-double fa-sm me-1"></i> Mark all as read
			</button>
			<button class="btn btn-sm btn-outline-danger no-loading" id="btnDismissAll" @(Model.Notifications.Count == 0 ? "disabled" : "")>
				<i class="fa-solid fa-trash fa-sm me-1"></i> Clear all
			</button>
		</div>
	</div>

	<div id="notifList">
		@if (!Model.Notifications.Any())
		{
			<div class="notif-empty" id="emptyState">
				<i class="fa-regular fa-bell-slash fa-2x mb-3 text-muted"></i>
				<p class="text-muted mb-0">You have no notifications</p>
			</div>
		}

		@foreach (var item in Model.Notifications)
		{
			<div class="notif-item d-flex flex-row @(item.IsRead ? "is-read" : "is-unread")" id="notif-@item.Id" data-id="@item.Id">
				<div class="notif-icon-col">
					<div class="notif-dot @(item.IsRead ? "dot-read" : "dot-unread")"></div>
				</div>
				<div class="notif-body-col">
					<div class="notif-header-row">
						<span class="notif-title">@item.Title</span>
						<span class="notif-time">@item.CreatedWhen</span>
					</div>
					<div class="notif-message">
						@if (!string.IsNullOrEmpty(item.Url))
						{
							<a href="@item.Url" class="notif-link no-loading" onclick="markOneRead('@item.Id', event)">@item.Message</a>
						}
						else
						{
							@item.Message
						}
					</div>
				</div>
				<div class="notif-actions-col d-flex flex-row align-items-center">
					@if (!item.IsRead)
					{
						<button class="notif-action-btn no-loading" title="Mark as read" onclick="markOneRead('@item.Id', event)">
							<i class="fa-regular fa-circle-check"></i>
						</button>
					}
					<button class="notif-action-btn notif-dismiss-btn no-loading" title="Dismiss" onclick="dismissOne('@item.Id')">
						<i class="fa-regular fa-xmark"></i>
					</button>
				</div>
			</div>
		}
	</div>

</div>

<!-- Toast container -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999;" id="toastContainer"></div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/notifications.css" />
}

@section Scripts {
	<script>
		const COMPANY = '@companyId';

		function showToast(message, type) {
			const id = 'toast-' + Date.now();
			const bg = type === 'success' ? 'bg-success' : 'bg-danger';
			const html = `
									<div id="${id}" class="toast align-items-center text-white ${bg} border-0 mb-2" role="alert" aria-live="assertive" aria-atomic="true">
											<div class="d-flex">
													<div class="toast-body">${message}</div>
													<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
											</div>
									</div>`;
			document.getElementById('toastContainer').insertAdjacentHTML('beforeend', html);
			const el = document.getElementById(id);
			new bootstrap.Toast(el, { delay: 3000 }).show();
			el.addEventListener('hidden.bs.toast', () => el.remove());
		}

		function updatePageBadge() {
			const unread = document.querySelectorAll('.notif-item.is-unread').length;
			const badge = document.getElementById('pageUnreadCount');
			if (unread > 0) {
				badge.textContent = unread + ' unread';
				badge.classList.remove('d-none');
			} else {
				badge.classList.add('d-none');
			}
			// Also update the topbar bell badge if present
			const bellBadge = document.getElementById('bellBadge');
			if (bellBadge) {
				if (unread > 0) {
					bellBadge.textContent = unread > 99 ? '99+' : unread;
					bellBadge.style.display = '';
				} else {
					bellBadge.style.display = 'none';
				}
			}
		}

		function checkEmptyState() {
			const items = document.querySelectorAll('.notif-item');
			if (items.length === 0) {
				if (!document.getElementById('emptyState')) {
					document.getElementById('notifList').innerHTML =
						'<div class="notif-empty" id="emptyState"><i class="fa-regular fa-bell-slash fa-2x mb-3 text-muted"></i><p class="text-muted mb-0">You have no notifications</p></div>';
				}
				document.getElementById('btnDismissAll').disabled = true;
			}
			document.getElementById('btnMarkAllRead').disabled =
				document.querySelectorAll('.notif-item.is-unread').length === 0;
		}

		function markOneRead(id, e) {
			if (e) e.preventDefault();
			const item = document.getElementById('notif-' + id);
			if (!item || item.classList.contains('is-read')) {
				if (e && item) {
					const link = item.querySelector('.notif-link');
					if (link) window.location.href = link.href;
				}
				return;
			}

			$.ajax({
				url: '/' + COMPANY + '/notifications/read',
				method: 'PUT',
				contentType: 'application/json',
				data: JSON.stringify({ ids: [id] }),
			}).done(() => {
				item.classList.remove('is-unread');
				item.classList.add('is-read');
				item.querySelector('.notif-dot')?.classList.replace('dot-unread', 'dot-read');
				item.querySelector('.notif-action-btn:not(.notif-dismiss-btn)')?.remove();
				updatePageBadge();
				if (e) {
					const link = item.querySelector('.notif-link');
					if (link) window.location.href = link.href;
				}
			}).fail(() => showToast('Could not mark as read.', 'error'));
		}

		function dismissOne(id) {
			$.ajax({
				url: '/' + COMPANY + '/notifications/dismiss/' + id,
				method: 'DELETE',
			}).done(() => {
				const item = document.getElementById('notif-' + id);
				item?.remove();
				updatePageBadge();
				checkEmptyState();
				showToast('Notification dismissed.', 'success');
			}).fail(() => showToast('Could not dismiss notification.', 'error'));
		}

		$('#btnMarkAllRead').click(function () {
			$.ajax({
				url: '/' + COMPANY + '/notifications/read/all',
				method: 'PUT',
				contentType: 'application/json',
			}).done(() => {
				document.querySelectorAll('.notif-item.is-unread').forEach(el => {
					el.classList.replace('is-unread', 'is-read');
					el.querySelector('.notif-dot')?.classList.replace('dot-unread', 'dot-read');
					el.querySelector('.notif-action-btn:not(.notif-dismiss-btn)')?.remove();
				});
				updatePageBadge();
				checkEmptyState();
				showToast('All notifications marked as read.', 'success');
			}).fail(() => showToast('Could not mark all as read.', 'error'));
		});

		$('#btnDismissAll').click(function () {
			if (!confirm('Clear all notifications? This cannot be undone.')) return;
			$.ajax({
				url: '/' + COMPANY + '/notifications/dismiss/all',
				method: 'DELETE',
			}).done(() => {
				document.querySelectorAll('.notif-item').forEach(el => el.remove());
				updatePageBadge();
				checkEmptyState();
				showToast('All notifications cleared.', 'success');
			}).fail(() => showToast('Could not clear notifications.', 'error'));
		});
	</script>
}
