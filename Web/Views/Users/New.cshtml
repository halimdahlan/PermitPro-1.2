@using Kendo.Mvc.UI;

@{
	ViewData["Title"] = "Settings / Users";
	ViewData["SubTitle"] = "New user";
}

@model NewUserViewModel

@if (Model.NoRolesAvailable)
{
	<div class="d-flex flex-column align-items-center">
		<div class="alert alert-warning" role="alert">
			<div class="d-flex flex-column align-items-center">
				<div class="my-3">
					<i class="fa-regular fa-triangle-exclamation" style="font-size: 2.5rem;"></i>
				</div>
				<div class="text-center p-3 fs-6">
					You have reached the user creation limit of <strong>@Model.MaxNumOfUsers</strong> users.<br />
					If you would like to increase this limit, please contact the system administrator.
				</div>
			</div>
		</div>

		<a asp-controller="users" asp-action="index">
			<span class="mx-3"><i class="fa-solid fa-arrow-left me-3"></i> Back</span>
		</a>
	</div>
}
else
{
	<div class="row g-3">
		<div class="d-flex flex-column col-12 col-lg-6">
			@if (Model.HasExceededLimit)
			{
				<div class="alert alert-info d-flex mb-3" role="alert">
					<i class="fa-solid fa-circle-info me-3 fa-xl mt-3"></i>
					<div>
						You have reached the user creation limit of <strong>@Model.MaxNumOfUsers</strong> users. Only roles marked <strong>Unlimited users</strong> are available for new users.
					</div>
				</div>
			}
			<form method="post">
				@Html.AntiForgeryToken()
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="row g-3 mb-3">
							<div class="col-6">
								<label class="form-label">First Name <span class="text-danger">*</span></label>
								<input asp-for="FirstName" class="form-control" placeholder="John"/>
								<span asp-validation-for="FirstName" class="text-danger small"></span>
							</div>
							<div class="col-6">
								<label class="form-label">Last Name <span class="text-danger">*</span></label>
								<input asp-for="LastName" class="form-control" placeholder="Doe"/>
								<span asp-validation-for="LastName" class="text-danger small"></span>
							</div>
						</div>
						<div class="row g-3 mb-3">
							<div class="col">
								<label class="form-label">Email <span class="text-danger">*</span></label>
								<input asp-for="Email" class="form-control" placeholder="i.e. john.doe@email.com"/>
								<span asp-validation-for="Email" class="text-danger small"></span>
							</div>
						</div>
						<div class="row g-3 mb-3">
							<div class="col-6">
								<label class="form-label">Designation</label>
								<input asp-for="Designation" class="form-control" />
								<span asp-validation-for="Designation" class="text-danger small"></span>
							</div>
							<div class="col-6">
								<label class="form-label">User role <span class="text-danger">*</span></label>
								<select asp-for="UserRole" class="form-select" asp-items="@(new SelectList(Model.Roles, "Id", "Name"))">
									<option value="">(select a role)</option>
								</select>
								<span asp-validation-for="UserRole" class="text-danger small"></span>
							</div>
						</div>
						<div class="row g-3 mb-3">
							<div class="col">
								<label class="form-label">Locations</label>
								@(Html
									.Kendo()
										.DropDownTree()
											.Name("ddlLocations")
											.DataValueField("id")
											.DataTextField("name")
											.Placeholder("(select locations)")
											.Events(events => events
												.Change("onChangeSites")
											)
											.FillMode(FillMode.Outline)
											.Rounded(Rounded.Large)
											.CheckAll(false)
											.AutoClose(false)
											.Checkboxes(checkboxes => checkboxes
												.Name("checkedFiles")
												.CheckChildren(true)
											)
											.DataSource(ds => ds
												.Read(read => read
													.Url($"/api/data/{Model.CompanyID}/sites/hierarchical")
													.Type(HttpVerbs.Get)
												)
											)
									)
							</div>
						</div>
						<div class="row g-3 mb-3">
							<div class="col">
								<input asp-for="IsActive" class="form-check-input" type="checkbox"/>
								<label class="form-check-label ms-2" for="IsActive">Is Active?</label>
							</div>
						</div>
						<div class="row g-3">
							<h6 class="mb-0">Set Password</h6>
							<div class="col-6">
								<label class="form-label">New password <span class="text-danger">*</span></label>
								<input type="password" asp-for="NewPassword" class="form-control"/>
								<span asp-validation-for="NewPassword" class="text-danger small"></span>
							</div>
							<div class="col-6">
								<label class="form-label">Confirm password <span class="text-danger">*</span></label>
								<input type="password" asp-for="ConfirmPassword" class="form-control"/>
								<span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
							</div>
						</div>
						<div class="mt-5 text-body-secondary d-flex align-items-center justify-content-between">
							<a href="/@Model.CompanyID/@((Model.OriginFromContractors) ? "contractors" : "users")" role="button" class="btn btn-sm btn-outline-secondary">
								<span class="mx-3"><i class="fa-solid fa-arrow-left me-2"></i>Cancel</span>
							</a>
							<button type="submit" class="btn btn-sm btn-primary"><span class="mx-3">Save Changes</span></button>
						</div>
					</div>
				</div>
				<input id="hidLocations" type="hidden" asp-for="Locations" />
				<input id="hidOriginFromContractors" type="hidden" asp-for="OriginFromContractors" />
			</form>
		</div>
	</div>

	@section Scripts {
		<!-- Includes jQuery validation for instant client-side checks without reloading -->
		<partial name="_ValidationScriptsPartial" />

		<script>
			var selectedLocations = [];
			var isContractor = @Model.OriginFromContractors.ToString().ToLower();

			$(document).ready(() => {
				var dropDownTree = $('#ddlLocations').data('kendoDropDownTree');

				dropDownTree.dataSource.filter({});
				dropDownTree.value(selectedLocations);

				if (isContractor) {
					const selectElement = document.getElementById('UserRole');
					const textToFind = 'Permit Holder / Contractor';

					for (let i = 0; i < selectElement.options.length; i++) {
						if (selectElement.options[i].text === textToFind) {
							selectElement.selectedIndex = i; // Selects the item by its index
							break;
						}
					}

					selectElement.disabled = true;
				}
			});

			const onChangeSites = () => {
				var checkedNodes = [];
				var dropDownTree = $('#ddlLocations').data('kendoDropDownTree');

				checkedNodeIds(dropDownTree.dataSource.view(), checkedNodes);
				$('#hidLocations').val(JSON.stringify(checkedNodes));
			};

			const checkedNodeIds = (nodes, checkedNodes) => {
				for (var i = 0; i < nodes.length; i++) {
					if (nodes[i].checked) {
						checkedNodes.push(nodes[i].id);
					}

					if (nodes[i].hasChildren) {
						checkedNodeIds(nodes[i].children.view(), checkedNodes);
					}
				}
			};
		</script>
	}

}

@section CustomCss {
	<link rel="stylesheet" href="~/css/users.css" />
}

