				xhr.always(() => {
					$('#dlgConfirmDeleteItem').modal('hide');
					$('.loading').hide();
				});
			});

		});


		const onFilterChange = (e) => {
			var dropdownlist = e.sender;
			var search = dropdownlist.value();
			var grid = $("#grid").data("kendoGrid");

			if (!search) {
				grid.dataSource.filter(null);
				return;
			}

			var filter = search.split('|');

			if (filter[0] == 'all') {
				grid.dataSource.filter(null);
			} else {
				if (filter[0] == 'isActive') {
					var state = filter[1];
					grid.dataSource.filter({ field: 'IsActive', operator: 'eq', value: state == 'true' });
				} else {
					grid.dataSource.filter({ field: 'Roles', operator: 'eq', value: filter[1] });
				}
			}
		};


