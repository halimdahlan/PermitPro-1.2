@using Kendo.Mvc.UI;

@{
	ViewData["Title"] = "Settings / Users";
	ViewData["SubTitle"] = "Summary";

	//var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model UsersViewModel

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-3">
	<div class="d-flex flex-row align-items-center gap-3">
		<label for="filterDropdown" class="form-label mb-0">View by:</label>
		<div>

		@(Html.Kendo().DropDownList()
			.Name("filterDropdown")
			.Size(ComponentSize.Medium)
			.Rounded(Rounded.Medium)
			.FillMode(FillMode.Outline)
			.DataValueField("value")
			.DataTextField("text")
			.HtmlAttributes(new { style = "width: 280px" })
			.Events(e => e.Change("onFilterChange"))
			.DataSource(ds => ds
				.Read(r => r.Url($"/{Model.CompanyId}/users/filters").Type(HttpVerbs.Get))
			)
		)
		</div>
	</div>
	<div>
		@if (Model.LimitReached)
		{
			<a href="#dlgLimitReached" class="btn btn-sm btn-primary no-loading" data-bs-toggle="modal" data-bs-target="#dlgLimitReached"><span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New user</span></a>
		}
		else
		{
			<a href="#dlgUser" class="btn btn-sm btn-primary no-loading" data-bs-toggle="modal" data-bs-target="#dlgUser"><span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New user</span></a>
		}
		<a asp-controller="users" asp-action="userroles" class="btn btn-sm btn-primary"><span class="px-2">User roles</span></a>
	</div>
</div>

@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success alert-dismissible fade show" role="alert mb-3">
		@TempData["SuccessMessage"]
	</div>
}

<div>
	@Html.AntiForgeryToken()
	@(Html.Kendo()
		.Grid<UsersGridViewModel>()
		.HtmlAttributes(new { @class = "table-grid dropdown dropstart" })
		.Name("grid")
		.ToolBar(tb => tb.Search())
		.NoRecords()
		.Pageable()
		.Sortable()
		.DataSource(ds => ds
			.Custom()
			.Schema(s => s
				.Model(m =>
				{
					m.Id(i => i.Id);
				})
			)
			.Transport(t =>
			{
				t.Read(r => r.Url($"/{Model.CompanyId}/users/grid").Type(HttpVerbs.Get));
			})
			.PageSize(10)
		)
		.Columns(c =>
		{
			c.Bound(f => f.Name).ClientTemplate("<a href=\"javascript:;\" onclick=\"editUser('#=Id#')\" class=\"text-info no-loading\">#=Name#</a>").Width(250);

			c.Bound(f => f.Email);
			//c.Bound(f => f.Location);
			c.Bound(f => f.Designation).Width(250);
			c.Bound(f => f.Roles).Width(250);

			c.Bound(f => f.IsSecured).Sortable(false).ClientTemplate(
				"# if (IsSecured) { #" +
				"    <i class=\"fa-regular fa-user-lock fa-lg\"></i>" +
				"# } else { #" +
				"    <i class=\"fa-regular fa-user-unlock fa-lg\"></i>" +
				"# } #"
				).HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(120);

			c.Bound(f => f.IsActive).Sortable(false).ClientTemplate(
				"# if (IsActive) { #" +
				"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
				"# } else { #" +
				"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-warning\"></i>" +
				"# } #"
				).HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(120);

			c.Bound(f => f.CreatedWhen).Format("{0:dd MMM, yyyy}").Width(150);

			c.Bound(f => f.ActionIcons).Sortable(false).Encoded(false).HeaderHtmlAttributes(new { @class = "grid-header text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(110);
		})
		.Events(ev => ev.DataBound("onGridDataBound"))
		)
</div>

