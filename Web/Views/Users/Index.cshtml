				$('#dlgConfirmDeleteItem').modal('hide');
				$('.loading').show();

				var xhr = $.ajax({
					method: 'DELETE',
					url: `/@Model.CompanyId/users/${userId}`,
				});

				xhr.done((response, status) => {
					if (status == 'success') {
						if (response.data == 'OK') {
							grid.dataSource.read();
						}
					}

					//$('#dlgConfirmDeleteItem').modal('hide');
				});

				xhr.fail(() => {
					//$('#dlgConfirmDeleteItem').modal('hide');
