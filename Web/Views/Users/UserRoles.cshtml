@using Kendo.Mvc.UI;

@{
	ViewData["Title"] = "Settings / Users / Roles";
	ViewData["SubTitle"] = "Summary";
}

@model UsersViewModel

<div class="d-flex flex-row justify-content-between align-items-center mb-3">
	<div></div>
	<div>
		<button type="button" class="btn btn-sm btn-primary" onclick="addRole()"><span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New role</span></button>
	</div>
</div>

<div>
	@Html.AntiForgeryToken()
	@(Html.Kendo()
		.Grid<RolesGridViewModel>()
		.Name("grid")
		.NoRecords()
		.Pageable()
		.Sortable()
		.Columns(c =>
		{
			c.Bound(f => f.Name).Width(300);

			c.Bound(f => f.Description);

			c.Bound(f => f.IsSystemRole)
				.ClientTemplate(
					"# if (IsSystemRole) { #" +
					"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
					"# } #"
				)
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(110);

			c.Bound(f => f.NumOfUsers)
				.ClientTemplate("<span class=\"badge bg-secondary\">#= NumOfUsers #</span>")
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(120);

			c.Bound(f => f.CreatedWhen)
				.Format("{0:dd MMM, yyyy}")
				.Width(150);

			c.Bound(f => f.ActionIcons)
				.Title("ACTION")
				.Sortable(false)
				.Encoded(false)
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(80);
		})
		.DataSource(ds => ds
			.Custom()
			.Schema(s => s
				.Model(m =>
				{
					m.Id(i => i.Id);
				})
			)
			.Transport(t =>
			{
				t.Read(r => r.Url("/users/roles/grid").Type(HttpVerbs.Get));
			})
			.PageSize(20)
		)
	)
</div>

<div class="d-flex flex-row align-items-center justify-content-between mt-5">
	<div>
		<a asp-controller="users" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
	</div>
</div>


<!-- Modal: New / Edit role -->
<div class="modal fade" id="dlgRole" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgRoleLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-dark text-white">
				<h2 class="modal-title" id="dlgRoleLabel" style="font-weight:600;">New role</h2>
				<a href="#" class="no-loading text-white" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<form id="frmRole" class="needs-validation" onsubmit="return false" novalidate>
					<div class="form-group mb-3">
						<label class="form-label" for="frm-name">Name</label>
						<input type="text" id="frm-name" class="form-control" required />
						<div class="invalid-feedback">Please enter the role name</div>
					</div>
					<div class="form-group mb-3">
						<label class="form-label" for="frm-name">Description</label>
						<textarea id="frm-desc" class="form-control" />
					</div>
					<div class="form-group mb-3">
						<label class="form-label" for="frm-name">Is system role?</label>
					</div>
					<input type="hidden" id="frm-mode" value="new" />
					<input type="hidden" id="frm-id" value="" />
				</form>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-sm btn-primary btn-save"><span class="mx-3">Save Changes</span></button>
			</div>
		</div>
	</div>
</div>


<!-- Modal: Confirm delete -->
<div class="modal fade" id="dlgConfirm" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgConfirmLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h2 class="modal-title" id="dlgConfirmLabel" style="font-weight:600;">Confirm delete</h2>
				<a href="#" class="no-loading text-dark" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				Are you sure you want to delete this role? This action cannot be undone.
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-sm btn-danger btn-proceed" data-role-id="">Yes, proceed</button>
			</div>
		</div>
	</div>
</div>


@section CustomCss {
	<link rel="stylesheet" href="/css/user-roles.css" />
}


@section Scripts {
	<script>
		var grid;

		$(document).ready(() => {
			grid = $("#grid").data("kendoGrid");

			grid.dataSource.transport.options.read.beforeSend = (req) => {
				req.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
			};


			$('.btn-save').click(() => {
				$('#frmRole').removeClass('needs-validation').addClass('was-validated');

				var mode = $('#frm-mode').val();
				var roleName = $('#frm-name').val().trim();

				if (roleName === '') return;

				var formData = new FormData();
				formData.append('Name', roleName);

				if (mode === 'edit') {
					formData.append('Id', $('#frm-id').val());
				}

				$('.loading').show();

				var xhr = $.ajax({
					method: 'POST',
					url: '/users/roles/' + mode,
					data: formData,
					contentType: false,
					processData: false,
					cache: false,
					beforeSend: (xhr) => {
						xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
					},
				});

				xhr.done((response, status) => {
					if (status === 'success') {
						$('#dlgRole').modal('hide');
						grid.dataSource.read();
					}
				});

				xhr.fail((response) => {
					var data = response.responseJSON;
					alert(data?.errorMessage ?? 'An error occurred. Please try again.');
				});

				xhr.always(() => {
					$('.loading').hide();
				});
			});


			$('#dlgRole').on('show.bs.modal', () => {
				var mode = $('#frm-mode').val();

				if (mode === 'edit') {
					var roleId = $('#frm-id').val();
					if (!roleId) return;

					$('.loading').show();

					var xhr = $.ajax({
						method: 'GET',
						url: '/users/roles/' + roleId,
					});

					xhr.done((response) => {
						$('#frm-name').val(response.name);
					});

					xhr.always(() => {
						$('.loading').hide();
					});
				}
			});


			$('#dlgRole').on('hidden.bs.modal', () => {
				$('#frmRole').removeClass('was-validated').addClass('needs-validation');
				$('#dlgRoleLabel').html('New role');
				$('#frm-mode').val('new');
				$('#frm-name').val('');
				$('#frm-id').val('');
			});


			$('.btn-proceed').click(() => {
				var roleId = $('.btn-proceed').data('roleId');
				if (!roleId) return;

				$('.loading').show();

				var xhr = $.ajax({
					method: 'DELETE',
					url: '/users/roles/' + roleId,
					beforeSend: (xhr) => {
						xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
					},
				});

				xhr.done((response) => {
					if (response.data === 'OK') {
						$('#dlgConfirm').modal('hide');
						grid.dataSource.read();
					}
				});

				xhr.fail((response) => {
					var data = response.responseJSON;
					$('#dlgConfirm').modal('hide');
					alert(data?.errorMessage ?? 'An error occurred. Please try again.');
				});

				xhr.always(() => {
					$('.loading').hide();
				});
			});


			$('#dlgConfirm').on('hidden.bs.modal', () => {
				$('.btn-proceed').data('roleId', '');
			});
		});


		const addRole = () => {
			$('#frm-mode').val('new');
			$('#dlgRoleLabel').html('New role');
			$('#dlgRole').modal('show');
		};


		const editRole = (id) => {
			$('#frm-mode').val('edit');
			$('#frm-id').val(id);
			$('#dlgRoleLabel').html('Edit role');
			$('#dlgRole').modal('show');
		};


		const deleteRole = (id) => {
			$('.btn-proceed').data('roleId', id);
			$('#dlgConfirm').modal('show');
		};
	</script>
}
