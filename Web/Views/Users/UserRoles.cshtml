@using Kendo.Mvc.UI;

@{
	ViewData["Title"] = "Settings / Users / Roles";
	ViewData["SubTitle"] = "Summary";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model UsersViewModel

<div class="d-flex flex-row justify-content-between align-items-center mb-3">
	<div></div>
	<div>
		<a href="/@companyId/users/roles/new" class="btn btn-sm btn-primary"><span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New role</span></a>
	</div>
</div>

@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
		<i class="fa-solid fa-circle-check me-2"></i> @TempData["SuccessMessage"]
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}

<div>
	@Html.AntiForgeryToken()
	@(Html.Kendo()
		.Grid<RolesGridViewModel>()
		.Name("grid")
		.NoRecords()
		.Pageable()
		.Sortable()
		.Columns(c =>
		{
			c.Bound(f => f.Name).Width(250);

			c.Bound(f => f.Description);

			c.Bound(f => f.IsSystemRole)
				.ClientTemplate(
					"# if (IsSystemRole) { #" +
					"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
					"# } #"
				)
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(110);

			c.Bound(f => f.NumOfUsers)
				.ClientTemplate("<span class=\"badge bg-secondary\">#= NumOfUsers #</span>")
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(120);

			c.Bound(f => f.CreatedWhen)
				.Format("{0:dd MMM, yyyy}")
				.Width(130);

			c.Bound(f => f.ActionIcons)
				.Title("ACTION")
				.Sortable(false)
				.Encoded(false)
				.HeaderHtmlAttributes(new { @class = "grid-header text-center" })
				.HtmlAttributes(new { @class = "text-center" })
				.Width(80);
		})
		.DataSource(ds => ds
			.Custom()
			.Schema(s => s
				.Model(m =>
				{
					m.Id(i => i.Id);
				})
			)
			.Transport(t =>
			{
				t.Read(r => r.Url($"/{companyId}/users/roles/grid").Type(HttpVerbs.Get));
			})
			.PageSize(20)
		)
	)
</div>

<div class="d-flex flex-row align-items-center justify-content-between mt-5">
	<div>
		<a asp-controller="users" asp-action="index">
			<span class="mx-3"><i class="fa-solid fa-arrow-left me-3"></i> Back to Users</span>
		</a>
	</div>
</div>


<!-- Modal: Confirm delete -->
<div class="modal fade" id="dlgConfirm" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgConfirmLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning">
				<h6 class="modal-title w-100" id="dlgConfirmLabel" style="font-weight:600;">Confirm Delete</h6>
				<a href="#" class="no-loading text-dark" data-bs-dismiss="modal" aria-label="Close">
					<i class="fa-sharp fa-solid fa-xmark fa-xl"></i>
				</a>
			</div>
			<div class="modal-body mb-0">
				You are about to delete this role. Are you sure?
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
				<button type="button" class="btn btn-sm btn-danger btn-proceed" data-role-id="">Yes, proceed</button>
			</div>
		</div>
	</div>
</div>


@section CustomCss {
	<link rel="stylesheet" href="/css/user-roles.css" />
}


@section Scripts {
	<script>
		var grid;

		$(document).ready(() => {
			grid = $("#grid").data("kendoGrid");

			grid.dataSource.transport.options.read.beforeSend = (req) => {
				req.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
			};


			$('.btn-proceed').click(() => {
				var roleId = $('.btn-proceed').data('roleId');
				if (!roleId) return;

				$('.loading').show();

				var xhr = $.ajax({
					method: 'DELETE',
					url: '/users/roles/' + roleId,
					beforeSend: (xhr) => {
						xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
					},
				});

				xhr.done((response) => {
					if (response.data === 'OK') {
						$('#dlgConfirm').modal('hide');
						grid.dataSource.read();
					}
				});

				xhr.fail((response) => {
					var data = response.responseJSON;
					$('#dlgConfirm').modal('hide');
					alert(data?.errorMessage ?? 'An error occurred. Please try again.');
				});

				xhr.always(() => {
					$('.loading').hide();
				});
			});


			$('#dlgConfirm').on('hidden.bs.modal', () => {
				$('.btn-proceed').data('roleId', '');
			});
		});


		const deleteRole = (id) => {
			$('.btn-proceed').data('roleId', id);
			$('#dlgConfirm').modal('show');
		};
	</script>
}
