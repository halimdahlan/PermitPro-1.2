@{
	ViewData["Title"] = "Settings / Users / Roles";
	ViewData["SubTitle"] = Model.IsEdit ? "Edit Role" : "New Role";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model ManageRoleViewModel

<div class="row g-3">
	<div class="d-flex flex-column col-12 col-lg-6">
		<form method="post" action="/@companyId/users/roles/@((Model.IsEdit) ? $"{Model.Id}/edit" : "new")">
			@Html.AntiForgeryToken()
			<div class="card shadow-sm h-100">
				<div class="card-body">

					@if (Model.IsEdit && Model.IsSystemRole)
					{
						<div class="alert alert-warning d-flex align-items-center mb-3" role="alert">
							<i class="fa-solid fa-lock me-2"></i>
							This is a <strong class="ms-1 me-1">system role</strong>. It can be edited but cannot be deleted.
						</div>
					}

					<div class="row g-3 mb-3">
						<div class="col">
							<label class="form-label">Role Name <span class="text-danger">*</span></label>
							<input asp-for="Name" class="form-control" placeholder="i.e. Supervisor" />
							<span asp-validation-for="Name" class="text-danger small"></span>
						</div>
					</div>

					<div class="row g-3 mb-3">
						<div class="col">
							<label class="form-label">Normalized Name <span class="text-danger">*</span></label>
							@if (Model.IsEdit)
							{
								<input asp-for="NormalizedName" class="form-control bg-light" readonly />
							}
							else
							{
								<input asp-for="NormalizedName" class="form-control" placeholder="i.e. SUPERVISOR" maxlength="256" />
							}
							<span asp-validation-for="NormalizedName" class="text-danger small"></span>
							<div class="form-text text-muted">Uppercase letters only, no spaces, numbers, or special characters. Cannot be changed after the role is created.</div>
						</div>
					</div>

					<div class="row g-3 mb-3">
						<div class="col">
							<label class="form-label">Description</label>
							<textarea asp-for="Description" class="form-control" rows="3" placeholder="(optional)"></textarea>
							<span asp-validation-for="Description" class="text-danger small"></span>
						</div>
					</div>

					<div class="row g-3">
						<div class="col">
							<input asp-for="IsSystemRole" class="form-check-input" type="checkbox" />
							<label class="form-check-label ms-2" for="IsSystemRole">Is system role?</label>
						</div>
					</div>

					<div class="row g-3 mt-1">
						<div class="col">
							<input asp-for="IsUnlimitedUsers" class="form-check-input" type="checkbox" />
							<label class="form-check-label ms-2" for="IsUnlimitedUsers">Unlimited users</label>
							<div class="form-text text-muted">Users assigned this role are excluded from the company user limit count.</div>
						</div>
					</div>
					<div class="mt-4 d-flex align-items-center justify-content-between">
						<a href="/@companyId/users/roles" role="button" class="btn btn-sm btn-outline-secondary">
							<span class="mx-3"><i class="fa-solid fa-arrow-left me-2"></i> Cancel</span>
						</a>
						<button type="submit" class="btn btn-sm btn-primary">
							<span class="mx-3">Save Changes</span>
						</button>
					</div>
				</div>
			</div>
		</form>
	</div>

	@if (Model.IsEdit)
	{
		<div class="col-12 col-lg-6">
			<div class="card shadow-sm h-100">
				<div class="card-header fs-6 fw-medium text-uppercase">
					List of users in this role
				</div>
				<div class="card-body d-flex flex-column justify-content-between">
					<div style="overflow-y: auto; height: 100%;max-height: 430px;">
						<table class="table table-bordered table-striped">
							<thead>
								<th>NAME</th>
							</thead>
							<tbody>
								@if (Model.UsersInRole?.Any() == true)
								{
									@foreach (var name in Model.UsersInRole)
									{
										<tr>
											<td>@name</td>
										</tr>
									}
								}
								else
								{
									<tr>
										<td class="text-center text-muted fst-italic">No users assigned to this role.</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
					<div class="text-end">
						@if (Model.UsersInRole?.Any() == true)
						{
							<span>Total: <strong>@Model.UsersInRole.Count</strong> user@((Model.UsersInRole.Count > 1) ? "s" : "")</span>
						}
						</div>
					</div>
				</div>
			</div>
		}

	</div>


	@section Scripts {
		@{
			await Html.RenderPartialAsync("_ValidationScriptsPartial");
		}

		@if (!Model.IsEdit)
		{
			<script>
				(function () {
					var nameInput = document.querySelector('[name="Name"]');
					var normInput = document.querySelector('[name="NormalizedName"]');
					if (!nameInput || !normInput) return;

					var userEditedNormalizedName = false;

					normInput.addEventListener('input', function () {
						userEditedNormalizedName = true;
					});

					nameInput.addEventListener('input', function () {
						if (userEditedNormalizedName) return;
						normInput.value = nameInput.value.toUpperCase().replace(/[^A-Z]/g, '');
					});
				})();
			</script>
		}
	}
