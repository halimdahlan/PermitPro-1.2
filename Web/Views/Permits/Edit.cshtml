@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Permits";
	ViewData["SubTitle"] = "Edit permit";
}

@model EditPermitViewModel

<div class="d-flex flex-column flex-md-row mb-2">
	<div id="form-permit" class="flex-grow-1 mb-3">
		<div id="systemAlert" class="alert mb-2" role="alert" style="display: none;">
			<div class="d-flex align-items-center">
				<div class="alert-icon">
					<i class="fa-solid fa-triangle-exclamation"></i>
				</div>
				<div class="ms-3 alert-message"></div>
			</div>
		</div>

		<div class="alert alert-@Model.AlertBgColor" role="alert">
			<div class="d-flex flex-row align-items-center">
				<div>
					<a class="me-3 text-dark" href="/@Model.CompanyId/permits"><i class="fa-sharp fa-regular fa-chevron-left fa-xl"></i></a>
				</div>
				<h5 class="mb-0">@Model.PermitNo</h5>
				<div class="w-100 text-end">
					<span class="fw-semibold fs-6">@Model.PermitStatusDisplay</span>
				</div>
			</div>
		</div>
		<form id="formPermit" enctype="multipart/form-data">
			<div class="accordion permit-new" id="accordionPermit">
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_GeneralInfo.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_PermitHolderInfo.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_OperationalInfo.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_OperationalMeasures.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_PPEWorkArea.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_Precautions.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_Notes.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_FileAttachments.cshtml" model="Model" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_WorkflowHistory.cshtml" model="Model" />
				</div>
			</div>

			<div class="mx-2 my-2">
				<div><small>Created by: @Model.PermitCreatedByInfo</small></div>
				<div><small>Updated by: @Model.PermitUpdatedByInfo</small></div>
			</div>

			<div class="d-md-flex flex-row align-items-center justify-content-between mt-5 d-none mb-5">
				<div>
					<a asp-controller="permits" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
				</div>
				<div>
					@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Draft)
					{
						<button type="button" class="btn btn-secondary btn-draft me-2">
							<span class="mx-3"><i class="fa-sharp fa-light fa-floppy-disk me-2"></i>Save as draft</span>
						</button>
						<button type="button" class="btn btn-primary btn-approval me-4">
							<span class="mx-3"><i class="fa-sharp fa-light fa-check-to-slot me-2"></i>Submit for approval</span>
						</button>
						<button type="button" class="btn btn-outline-danger btn-delete" data-id="@Model.PermitId">
							<span class="mx-3"><i class="fa-sharp fa-light fa-trash-can me-2"></i>Delete</span>
						</button>
					}
				</div>
			</div>
			<input type="hidden" id="formJson" />
		</form>
	</div>

	<div class="ms-0 ms-md-5 attached-certs mt-5 mt-md-0">
		<div>
			<h6 class="fw-semibold">ATTACHED CERTIFICATES</h6>
			<ul class="list-group shadow-sm selected-certs">
				<li class="list-group-item fade show">
					<span>No associated certificate attached</span>
				</li>
			</ul>
		</div>

		@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Pending && Model.ExecuteWorkflowAction)
		{
			<div class="mt-5">
				<h6 class="fw-semibold">PERMIT APPROVAL</h6>
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="form-group mb-3">
							<label class="form-label" for="txtComments">Comments</label>
							@(
								Html.Kendo().TextArea()
									.Name("txtComments")
									.Rows(3)
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
							)
						</div>
						<div class="d-flex flex-row justify-content-evenly align-items-center">
							<div class="flex-grow-1 me-2">
								<button type="button" class="btn btn-sm btn-danger w-100 btn-workflow-action" data-mode="reject"><span class="mx-3">REJECT</span></button>
							</div>
							<div class="flex-grow-1 ms-2">
								<button type="button" class="btn btn-sm btn-primary w-100 btn-workflow-action" data-mode="approve"><span class="mx-3">APPROVE</span></button>
							</div>
						</div>
					</div>
				</div>
			</div>
		}

		@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Pending || 
			Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Suspended ||
			Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Approved)
		{
			<div class="mt-5">
				<h6 class="fw-semibold">SUSPEND PERMIT</h6>
				<div class="card shadow-sm">
					<div class="card-body">
						<div class="d-flex flex-row align-items-center" style="height:38px;">
							<div class="me-3">
								@(
									Html.Kendo().Switch()
										.Name("swSuspend")
										.Size(ComponentSize.Small)
										.Messages(x => x.Checked("YES").Unchecked("NO"))
										.Checked(false)
										.Events(ev => ev.Change("onSuspendChange"))
								)
							</div>
							<div class="flex-grow-1 suspend-date">
								<div class="d-flex flex-row align-items-center">
									<div class="me-3">until</div>
									<div class="flex-grow-1">
										@(
											Html.Kendo().DatePicker()
												.Name("suspendDate")
												.Format("{0:dd/MM/yyyy}")
												.Min(DateTime.Now)
												.Enable(false)
												.Size(ComponentSize.Small)
												.Rounded(Rounded.Large)
												.FillMode(FillMode.Outline)
												.AdaptiveMode(AdaptiveMode.Auto)
												.ComponentType("modern")
												.DateInput()
												.HtmlAttributes(new { @class = "", style = "width:100%" })
										)
									</div>
								</div>
							</div>
						</div>
						<div class="suspend-date mt-2">
							<div class="d-flex flex-row align-items-center">
								<div>
									@(
										Html.Kendo().CheckBox()
											.Name("suspendAutoResume")
											.Checked(false)
											.Enable(false)
											.Label("Auto-resume")
											.Events(ev => ev.Change("onAutoResumeChange"))
									)
								</div>
								<div class="flex-grow-1">
									<div class="d-flex flex-row align-items-center justify-content-end">
										<div>
											<a href="javascript:;" class="no-loading suspend-clear me-3">Clear</a>
										</div>
										<button type="button" class="btn btn-sm btn-secondary btn-suspend disable" disabled><span class="mx-3"></span></button>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		}


		@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Draft || Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Closed)
		{
			<div class="mt-5">
				<button class="btn btn-sm btn-primary shadow-sm btn-export" type="button">
					<span class="mx-3">Export to PDF <i class="fa-duotone fa-file-pdf fa-xl ms-2"></i></span>
				</button>
			</div>
		}

		
		@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Approved)
		{
			<div class="mt-5">
				<button class="btn btn-sm btn-primary shadow-sm btn-export" type="button">
					<span class="mx-3">Export to PDF <i class="fa-duotone fa-file-pdf fa-xl ms-2"></i></span>
				</button>
			</div>
			<hr />
			<div class="d-flex flex-row align-items-center">
				<div class="w-100">Mark permit as closed</div>
				<div>
					@(
						Html.Kendo().Switch()
							.Name("swMarkAsClosed")
							.Size(ComponentSize.Small)
							.Messages(x => x.Checked("YES").Unchecked("NO"))
							.Events(ev => ev.Change("onMarkAsClosedChange"))
					)
				</div>
			</div>
			<div class="mt-3 close-notes" style="display:none;">
				<div class="card border shadow-sm">
					<div class="card-body">
						<div>
							@(
								Html.Kendo().TextArea()
									.Name("txtNotes")
									.Label(lbl => lbl.Content("Notes"))
									.Rows(2)
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
							)
						</div>
						<div class="mt-3 d-flex flex-row justify-content-end">
							<button type="button" class="btn btn-sm btn-primary btn-mark-closed" data-id="@Model.PermitId"><span class="mx-3">Mark as closed</span></button>
						</div>
					</div>
				</div>
			</div>
		}
	</div>

	<div class="d-flex flex-row align-items-center justify-content-between mt-5 d-md-none mb-5">
		<div>
			<a asp-controller="permits" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
		</div>
		<div>
			@if (Model.PermitStatus == PermitPro.Core.Enums.PermitStatusEnum.Draft)
			{
				<button type="button" class="btn btn-secondary btn-draft me-2">
					<span class="mx-2"><i class="fa-sharp fa-light fa-floppy-disk me-2"></i>Save as draft</span>
				</button>
				<button type="button" class="btn btn-primary btn-approval me-4">
					<span class="mx-3"><i class="fa-light fa-check-to-slot me-2"></i>Submit for approval</span>
				</button>
				<button type="button" class="btn btn-outline-danger btn-delete" data-id="@Model.PermitId">
					<span class="mx-3"><i class="fa-sharp fa-light fa-trash-can me-2"></i>Delete</span>
				</button>
			}
		</div>
	</div>
</div>

@await Html.PartialAsync("~/Views/Permits/Forms/_HotWork.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_ConfinedSpace.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Radiation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Excavation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Isolation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormF.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormG.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormH.cshtml")

<!-- Modal: EXPORT PDF //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
<div class="modal fade" id="dlgExportPdf" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgExportPdfLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header bg-info-soft">
				<div class="modal-title" id="dlgExportPdfLabel">
					Export to PDF
				</div>
				<a href="#" class="no-loading text-dark" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				[FORM]
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"><span class="mx-3">Close</span></button>
				<button type="button" class="btn btn-sm btn-primary"><span class="mx-3">Export</span></button>
			</div>
		</div>
	</div>
</div>
<!-- ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->


<div class="modal fade" id="dlgInputError" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgInputErrorLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-danger">
				<div class="modal-title" id="dlgInputErrorLabel">
					<span class="text-white">Invalid Input</span>
				</div>
				<a href="#" class="no-loading text-white" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<p>Please note the following error(s):</p>
				<div id="divInputErrors"></div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"><span class="mx-3">Close</span></button>
			</div>
		</div>
	</div>
</div>

@Html.AntiForgeryToken()

@section CustomCss {
	<link rel="stylesheet" href="~/css/permits.css" />

	<!-- DataTables -->
	<link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />
	<script nonce="3xecut3" src="~/lib/DataTables/datatables.min.js"></script>

	<link rel="stylesheet" href="~/lib/DataTables/Responsive-2.5.0/css/responsive.dataTables.min.css" />
	<script nonce="3xecut3" src="~/lib/DataTables/Responsive-2.5.0/js/dataTables.responsive.min.js"></script>

	<script src="~/lib/FileSaver/FileSaver.min.js"></script>
}

@section Scripts {
	<script src="~/js/permit.module.js"></script>
	<script>
		const currentPermitStatus = '@Model.PermitStatus';
		const selectedCerts = [];
		var tblFiles = null;

		// Global data modification flag
		var hotWorkDataIsDirty = false;

		// Form A
		var tblLEL = null;
		var tblAtmos = null;
		var lelReadings = [];
		var atmosReadings = [];

		// Form B
		var tbl1FormB = null;
		var tbl2FormB = null;
		var formBGasReadings = [];
		var formBEntryRecords = [];

		// Form E
		var tbl1FormE = null;
		var tbl2FormE = null;
		var formEAuthIndividuals = [];
		var formEIsolationPointIds = [];

		var suspendPermit = {
			date: null,
			autoResume: @Model.SuspendAutoResume.ToString().ToLower(),
		};

		const permitJson = '@Html.Raw(Model.PermitJson.Replace("\\", "\\\\"))';

		PermitModule.companyId('@Model.CompanyId');
		PermitModule.permitId('@Model.PermitId.ToString().ToLower()');

		var _permitInfo = PermitModule.permitInfo();

		$(document).ready(() => {

			if (currentPermitStatus == 'Closed' || currentPermitStatus == 'Rejected') {
				$('#btnSaveFormA').css('display', 'none');
				$('#btnSaveFormB').css('display', 'none');
				$('#btnSaveFormC').css('display', 'none');
				$('#btnSaveFormD').css('display', 'none');
				$('#btnSaveFormE').css('display', 'none');
				$('#btnSaveFormF').css('display', 'none');
				$('#btnSaveFormG').css('display', 'none');
				$('#btnSaveFormH').css('display', 'none');
			}

			_permitInfo = JSON.parse(permitJson);

			//console.log(_permitInfo);

			var permitStartDateTime = moment(_permitInfo.general.startDateTime);
			var permitEndDateTime = moment(_permitInfo.general.endDateTime);

			//$('#ddtLocation').data('kendoDropDownTree').value('@Model.Location.Id.ToString().ToLower()');
			//$('#ddtLocation').data('kendoDropDownTree').text('@Model.Location.Name');

			const ddtLocation = $('#ddtLocation').data('kendoDropDownTree');
			//ddtLocation.dataSource.filter({});
			ddtLocation.value('@Model.Location.Id.ToString().ToLower()');
			ddtLocation.trigger("change");	

			//console.log($('#ddtLocation').data('kendoDropDownTree').value());

			$('#tbPermitDesc').data('kendoTextArea').value(_permitInfo.general.description);
			$('#startDateTime').data('kendoDatePicker').value(permitStartDateTime.format('DD/MM/YYYY'));
			$('#endDateTime').data('kendoDatePicker').value(permitEndDateTime.format('DD/MM/YYYY'));
			$('#tbPermitHolderInfo1').data('kendoTextBox').value(_permitInfo.permitHolder.name);

			//console.log(_permitInfo);

			/**
			 * Suspend permit settings
			 */
			var tempSuspendDate = '@(Model.SuspendDate != null ? Model.SuspendDate!.Value.ToString("yyyy-MM-dd") : "")';

			if (tempSuspendDate != '') {
				var suspendDateSw = $('#swSuspend').data('kendoSwitch');
				var suspendDate = $('#suspendDate').data('kendoDatePicker');
				var suspendAutoResume = $('#suspendAutoResume').data('kendoCheckBox');
				var dtmSuspendDate = moment(tempSuspendDate);

				suspendDateSw.enable(false);
				suspendDateSw.value(true);
				suspendDate.value(dtmSuspendDate.format('DD/MM/YYYY'));
				suspendAutoResume.check(suspendPermit.autoResume);

				$('.suspend-clear').hide();
				$('.btn-suspend').attr('disabled', null);
				$('.btn-suspend span').html('Cancel');
			} else {
				$('.btn-suspend span').html('Suspend');
			}

			//console.log(_permitInfo.general.certificates);

			if (_permitInfo.general.certificates.length > 0) {
				$('.selected-certs').empty();

				_permitInfo.general.certificates.forEach((item, index) => {
					if (item.name == 'hotwork') {
						var li = '<li id="item-hotwork" class="list-group-item d-flex flex-row justify-content-between align-items-center fade show">';

						li += '<div class="d-flex flex-row align-items-center justify-content-between">';
						//li += '  <div class="avatar avatar-xs">';
						//li += '    <span class="avatar-title rounded-circle bg-info">A</span>';
						//li += '  </div>';
						li += '  <img title=" (A) Hot Work " src="/img/icons/certs/hotwork.png" style="width:24px;height:24px;" />';
						li += '  <h6 class="ms-3 mb-0">HOT WORK</h6>';
						li += '</div>';
						li += '<div class="ms-5">';
						li += '  <a href="#dlgFormA" class="no-loading" data-bs-toggle="modal" data-bs-target="#dlgFormA"><i class="fa-sharp fa-solid fa-pen-to-square"></i></a>';
						li += '</div>';
						li += '</li>';

						$('.selected-certs').append(li);
						$('#chkCertHotWork').data('kendoCheckBox').value(true);

						try {

							lelReadings = item.lowExplosionLevel.readings;
							atmosReadings = item.atmosTestReadings;

							$('#tbFormAEmergencyContact').data('kendoTextBox').value(item.emergencyContact);

							item.workChecklist.forEach((v, i) => {
								$('#' + v.id).data('kendoCheckBox').value(v.value);
							});

							item.ignitionSources.forEach((v, i) => {
								let elemId = '#' + v.id;
								$(elemId).data('kendoCheckBox').value(v.value);

								//console.log(elemId);

								if (elemId == '#chkFormAIgnitionSource5') {
									$('#tbFormAIgnitionSource5').data('kendoTextBox').value(v.other);
								}
							});

							$('#tbFormAGasTestBy').data('kendoTextArea').value(item.gasTestPerformedBy.name);

							if (item.lowExplosionLevel.initialTestDateTime != null) {
								//$('#dtmFormA1').data('kendoDateTimePicker').value(new Date(item.lowExplosionLevel.initialTestDateTime));
							}

							$('#tbFormALelReading').data('kendoTextBox').value(item.lowExplosionLevel.initialReading);
							$('#tbLELFrequency').data('kendoTextBox').value(item.lowExplosionLevel.requiredFrequency);

							if (item.permitValidity != undefined) {
								const validityFrom = moment(item.permitValidity.from);
								const validityTo = moment(item.permitValidity.to);

								$('#tmpFormA-TimeAllowedFrom').data('kendoTimePicker').value(validityFrom.format('hh:mm A'));
								$('#tmpFormA-TimeAllowedTo').data('kendoTimePicker').value(validityTo.format('hh:mm A'));
							}

							$('#swHotworkWithdrawn').data('kendoSwitch').value(item.permitWithdrawn.status);
							$('#tbWithdrawnReason').data('kendoTextBox').value(item.permitWithdrawn.reason);

						} catch (e) { }

					}

					if (item.name == 'confinedspace') {
						var li = '<li id="item-confinedspace" class="list-group-item d-flex flex-row justify-content-between align-items-center fade show">';

						li += '<div class="d-flex flex-row align-items-center justify-content-between">';
						// li += '  <div class="avatar avatar-xs">';
						// li += '    <span class="avatar-title rounded-circle bg-info">B</span>';
						// li += '  </div>';
						li += '  <img title=" (B) Confined Space " src="/img/icons/certs/confinedspace.png" style="width:24px;height:24px;" />';
						li += '  <h6 class="ms-3 mb-0">CONFINED SPACE</h6>';
						li += '</div>';
						li += '<div class="ms-5">';
						li += '  <a href="#dlgFormB" class="no-loading" data-bs-toggle="modal" data-bs-target="#dlgFormB"><i class="fa-sharp fa-solid fa-pen-to-square"></i></a>';
						li += '</div>';
						li += '</li>';

						$('.selected-certs').append(li);
						$('#chkCertConfinedSpace').data('kendoCheckBox').value(true);

						try {

							formBGasReadings = item.gasTest.readings;
							formBEntryRecords = item.entryRecords;

							$('#tbFormBAttendantNames').data('kendoTextBox').value(item.attendants);
							$('#taFormBDescription').data('kendoTextArea').value(item.workDescription);
							$('#tbFormBGasTestBy').data('kendoTextBox').value(item.gasTest.performedBy);
							$('#dtmFormBInitialGasRead').data('kendoDateTimePicker').value(item.gasTest.initialTestWhen);
							$('#tbFormBInitialLELPercentage').data('kendoTextBox').value(item.gasTest.initialLEL);
							$('#tbFormBInitialO2Percentage').data('kendoTextBox').value(item.gasTest.initialO2);
							$('#tbFormBDesignatedRequiredFrequency').data('kendoTextBox').value(item.requiredFrequency);
							$('#tbFormBInitialToxic1').data('kendoTextBox').value(item.gasTest.others[0]);
							$('#tbFormBInitialToxic2').data('kendoTextBox').value(item.gasTest.others[1]);

							$('#chkFormBHazard-01-1').data('kendoCheckBox').value(item.potentialHazards.hydrogenSulphide.yes);
							$('#chkFormBHazard-01-2').data('kendoCheckBox').value(item.potentialHazards.hydrogenSulphide.no);
							$('#chkFormBHazard-01-3').data('kendoCheckBox').value(item.potentialHazards.hydrogenSulphide.na);
