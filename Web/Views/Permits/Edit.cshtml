			$('.btn-suspend').click(() => {
				var btnLabel = $('.btn-suspend span').html();
				var proceedOk = false;
				var suspendDate;

				var formData = new FormData();

				if (btnLabel == 'Suspend') {
					var datePicker = $('#suspendDate').data('kendoDatePicker');
					var autoResume = $('#suspendAutoResume').data('kendoCheckBox');

					if (datePicker.value() == null) {
						alert('Please enter a valid date.');
					} else {
						suspendDate = moment(datePicker.value());

						const selectedDate = {
							day: parseInt(suspendDate.format('DD')),
							month: parseInt(suspendDate.format('MM')),
							year: parseInt(suspendDate.format('YYYY')),
						};

						//formData.append('SuspendDateDD', suspendDate.format('DD/MM/YYYY'));
						formData.append('SuspendDate', JSON.stringify(selectedDate));
						formData.append('SuspendAutoResume', suspendPermit.autoResume);
						formData.append('SuspendState', 'suspend');

						proceedOk = true;
					}
				} else {
					proceedOk = true;
					formData.append('SuspendState', 'cancel');
				}

				if (proceedOk) {
					$('.loading').show();

					var ajaxPost = $.ajax({
						url: '/@Model.CompanyId/permits/@Model.PermitId.ToString().ToLower()/suspend',
						method: 'POST',
						data: formData,
						contentType: false,
						processData: false,
						cache: false,
						beforeSend: (xhr) => {
							xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
						},
					});

					ajaxPost.done((response, status) => {
						if (response.status == 'OK') {
							document.location.href = '/@Model.CompanyId/permits';
						}
						
						$('.loading').hide();
					});

					ajaxPost.fail((response, status) => {
						$('.loading').hide();
						//console.log(response);
					});

					ajaxPost.always(() => {
					});
				}

			});

