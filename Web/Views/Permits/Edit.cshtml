			//$('.attachment-list-loading').css('display', 'grid');

			const xhr = $.ajax({
				type: 'POST',
				url: '/@Model.CompanyId/permits/attachments/remove',
				data: formData,
				contentType: false,
				processData: false,
				cache: false,
			});

			xhr.done((response) => {
				tblFiles.ajax.reload();
			});

			xhr.always(() => {
				//$('.attachment-list-loading').css('display', 'none');
			});
		};


		const hotWorkOnChange = (e) => {
			hotWorkDataIsDirty = true;
		};

	</script>
