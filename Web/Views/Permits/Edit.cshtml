			$('#dlgLelReading').on('hidden.bs.modal', () => {
				const readTime = $("#dtmReadTime").data("kendoTimePicker");
				const readValue = $("#tbReadValue").data("kendoTextBox");

				if (readTime.value() != null && readValue.value() != null) {
					if (lelReadings.length == 0) {
						$('#tblLEL tbody').empty();
					}

					const m = moment(readTime.value());
					const n = moment().unix();

					lelReadings.push({
						id: n,
						timestamp: m.unix(),
						time: m.format('hh:mm A'),
						date: m.format('YYYY/MM/DD'),
						value: readValue.value(),
					});

					tblLEL.clear().draw();
					tblLEL.data = lelReadings;
					tblLEL.rows.add(lelReadings).draw();

					$('#dlgLelReading').modal('hide');

					hotWorkDataIsDirty = true;
