@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Permits";
	ViewData["SubTitle"] = "New permit";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model PermitViewModel

<div class="d-flex flex-column flex-md-row mb-2">
	<div id="form-permit" class="flex-grow-1 mb-3">
		<form id="formPermit" enctype="multipart/form-data">
			<div class="accordion permit-new" id="accordionPermit">
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_GeneralInfo.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_PermitHolderInfo.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_OperationalInfo.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_OperationalMeasures.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_PPEWorkArea.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_Precautions.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_Notes.cshtml" model="Model.EditPermitViewModel" />
				</div>
				<div class="accordion-item">
					<partial name="~/Views/Permits/Panels/_FileAttachments.cshtml" model="Model.EditPermitViewModel" />
				</div>

				<div class="d-md-flex flex-row align-items-center justify-content-between mt-5 d-none">
					<div>
						<a asp-controller="permits" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
					</div>
					<div>
						<button type="button" class="btn btn-sm btn-secondary btn-draft me-3"><span class="mx-3">Save as draft</span></button>
						<button type="button" class="btn btn-sm btn-primary btn-approval"><span class="mx-3">Submit for approval</span></button>
					</div>
				</div>
			</div>
			<input type="hidden" id="formJson" />
		</form>
	</div>

	<div class="ms-0 ms-md-5 attached-certs mt-5 mt-md-0">
		<h3>ATTACHED CERTIFICATES</h3>
		<ul class="list-group shadow-sm selected-certs">
			<li class="list-group-item fade show">
				<span>No associated certificate attached</span>
			</li>
		</ul>
	</div>

	<div class="d-flex flex-row align-items-center justify-content-between mt-5 d-md-none">
		<div>
			<a asp-controller="permits" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
		</div>
		<div>
			<button type="button" class="btn btn-sm btn-secondary btn-draft me-3"><span class="mx-3">Save as draft</span></button>
			<button type="button" class="btn btn-sm btn-primary btn-approval"><span class="mx-3">Submit for approval</span></button>
		</div>
	</div>
</div>

@await Html.PartialAsync("~/Views/Permits/Forms/_HotWork.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_ConfinedSpace.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Radiation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Excavation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_Isolation.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormF.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormG.cshtml")
@await Html.PartialAsync("~/Views/Permits/Forms/_FormH.cshtml")

<div class="modal fade" id="dlgInputError" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgInputErrorLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-danger">
				<div class="modal-title" id="dlgInputErrorLabel">
					<span class="text-white">Invalid Input</span>
				</div>
				<a href="#" class="no-loading text-white" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<p>Please note the following error(s):</p>
				<div id="divInputErrors"></div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal"><span class="mx-3">Close</span></button>
			</div>
		</div>
	</div>
</div>


@section CustomCss {
	<link rel="stylesheet" href="~/css/permits.css" />

	<!-- DataTables -->
	<link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />
	<script nonce="3xecut3" src="~/lib/DataTables/datatables.min.js"></script>

	<link rel="stylesheet" href="~/lib/DataTables/Responsive-2.5.0/css/responsive.dataTables.min.css" />
	<script nonce="3xecut3" src="~/lib/DataTables/Responsive-2.5.0/js/dataTables.responsive.min.js"></script>
}

@section Scripts {
	<script src="~/js/permit.module.js"></script>
	<script nonce="3xecut3">
		const UPLOAD_MAX_FILE_SIZE = parseInt('@Model.EditPermitViewModel.UploadFileSizeLimit');
		const UPLOAD_MAX_FILE_COUNT = parseInt('@Model.EditPermitViewModel.UploadMaxFileCount');

		const selectedCerts = [];
		var tblFiles = null;
		var selectedLocation = null;

		// Form A
		var tblLEL = null;
		var tblAtmos = null;
		var lelReadings = [];
		var atmosReadings = [];

		// Form B
		var tbl1FormB = null;
		var tbl2FormB = null;
		var formBGasReadings = [];
		var formBEntryRecords = [];

		// Form E
		var tbl1FormE = null;
		var tbl2FormE = null;
		var formEAuthIndividuals = [];
		var formEIsolationPointIds = [];

		PermitModule.companyId('@companyId');
		PermitModule.permitId(null);

		const _permitInfo = PermitModule.permitInfo();

		$(document).ready(() => {

			$('.btn-approval').click(() => {
				PermitModule.permitInfo(_permitInfo);
				if (!PermitModule.submit('approval')) {
					PermitModule.getErrorMessages();
				}
			});


			$('.btn-draft').click(() => {
				PermitModule.permitInfo(_permitInfo);

				//console.log(_permitInfo);

				if (!PermitModule.submit('draft')) {
					PermitModule.getErrorMessages();
				}
			});


			$('.collapse').on('shown.bs.collapse', (e) => {
				const elem = $(e.target);
				const panel = elem.data('panelName');

				if (panel == 'fileAttachments') {
					if (tblFiles == null) {
						tblFiles = $('#tblFiles').DataTable({
							responsive: true,
							order: [[2, 'desc']],
							columns: [
								{ 
									data: 'fileName',
									render: (data, type, row) => {
										return '<a href="/attachments/permits/' + row.permitId + '/' + data + '" target="_blank">' + data + '</a>';
									},
								},
								{ data: 'fileSize' },
								{ data: 'createdWhen' },
								{
									data: 'id',
									render: (data, type, row) => {
										return '';
									},
								}
							],
						});
					} else {
						tblFiles.draw();
					}
				}
			});


			/********************************************************************************************************/
			/* FORM A
			/********************************************************************************************************/
			$('#dlgFormA').on('shown.bs.modal', (e) => {
				try {
					if (tblLEL == null) {
						tblLEL = $('#tblLEL').DataTable({
							responsive: true,
							searching: false,
							paging: false,
							ordering: false,
							data: lelReadings,
							columns: [
								{ data: 'time' },
								{ data: 'value' },
								{ 
									data: 'id',
									render: (data, type, row) => {
										return '<a href="javascript:;" onclick="removeRow(\'' + data + '\', tblLEL, lelReadings)"><i class="fa-solid fa-trash-can"></i></a>';
									},
								},
							]
						});
					}

					if (tblAtmos == null) {
						tblAtmos = $('#tblAtmos').DataTable({
							responsive: true,
							searching: false,
							paging: false,
							ordering: false,
							data: atmosReadings,
							columns: [
								{ data: 'time' },
								{ data: 'value' },
								{
									data: 'id',
									render: (data, type, row) => {
										return '<a href="javascript:;" onclick="removeRow(\'' + data + '\', tblAtmos, atmosReadings)"><i class="fa-solid fa-trash-can"></i></a>';
									},
								},
							]
						});
					}
				} catch (e) { }
			});

			$('#dlgLelReading').on('show.bs.modal', () => {
				const readTime = $("#dtmReadTime").data("kendoTimePicker");
				const readValue = $("#tbReadValue").data("kendoTextBox");

				readTime.value(null);
				readValue.value(null);
			});

			$('#dlgLelReading').on('hidden.bs.modal', () => {
				const readTime = $("#dtmReadTime").data("kendoTimePicker");
				const readValue = $("#tbReadValue").data("kendoTextBox");

				if (readTime.value() != null && readValue.value() != null) {
					if (lelReadings.length == 0) {
						$('#tblLEL tbody').empty();
					}

					const m = moment(readTime.value());
					const n = moment().unix();

					lelReadings.push({
						id: n,
						timestamp: m.unix(),
						time: m.format('hh:mm A'),
						date: m.format('YYYY/MM/DD'),
						value: readValue.value(),
					});

					tblLEL.clear().draw();
					tblLEL.data = lelReadings;
					tblLEL.rows.add(lelReadings).draw();

					$('#dlgLelReading').modal('hide');
				}

				setTimeout(() => {
					$('#tblLEL')[0].scrollIntoView();
				}, 500);
			});

			$('#dlgAtmos').on('show.bs.modal', () => {
				const readTime = $("#dtmAtmosReadTime").data("kendoTimePicker");
				const readValue = $("#tbAtmosReadValue").data("kendoTextBox");

				readTime.value(null);
				readValue.value(null);
			});

			$('#dlgAtmos').on('hidden.bs.modal', () => {
				const readTime = $("#dtmAtmosReadTime").data("kendoTimePicker");
				const readValue = $("#tbAtmosReadValue").data("kendoTextBox");

				if (readTime.value() != null && readValue.value() != null) {
					if (lelReadings.length == 0) {
						$('#tblAtmos tbody').empty();
					}

					const m = moment(readTime.value());
					const n = moment().unix();

					atmosReadings.push({
						id: n,
						timestamp: m.unix(),
						time: m.format('hh:mm A'),
						date: m.format('YYYY/MM/DD'),
						value: readValue.value(),
					});

					tblAtmos.clear().draw();
					tblAtmos.data = atmosReadings;
					tblAtmos.rows.add(atmosReadings).draw();

					$('#dlgAtmos').modal('hide');
				}

				setTimeout(() => {
					$('#tblAtmos')[0].scrollIntoView();
				}, 500);
			});

			$('#btnSaveFormA').click((e) => {
				const hotWork = {
					name: 'hotwork',
					emergencyContact: $('#tbFormAEmergencyContact').data('kendoTextBox').value(),
					workChecklist: [
						{
							id: 'chkFormACheckList1',
							value: $('#chkFormACheckList1').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList2',
							value: $('#chkFormACheckList2').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList3',
							value: $('#chkFormACheckList3').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList4',
							value: $('#chkFormACheckList4').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList5',
							value: $('#chkFormACheckList5').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList6',
							value: $('#chkFormACheckList6').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormACheckList7',
							value: $('#chkFormACheckList7').data('kendoCheckBox').value(),
						},
					],
					ignitionSources: [
						{
							id: 'chkFormAIgnitionSource1',
							value: $('#chkFormAIgnitionSource1').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormAIgnitionSource2',
							value: $('#chkFormAIgnitionSource2').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormAIgnitionSource3',
							value: $('#chkFormAIgnitionSource3').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormAIgnitionSource4',
							value: $('#chkFormAIgnitionSource4').data('kendoCheckBox').value(),
						},
						{
							id: 'chkFormAIgnitionSource5',
							value: $('#chkFormAIgnitionSource5').data('kendoCheckBox').value(),
							other: $('#tbFormAIgnitionSource5').data('kendoTextBox').value(),
						},
					],
					gasTestPerformedBy: {
						id: '',
						name: $('#tbFormAGasTestBy').data('kendoTextArea').value(),
					},
					lowExplosionLevel: {
						initialTestDateTime: $('#dtmFormA1').data('kendoDateTimePicker').value(),
						initialReading: $('#tbFormALelReading').data('kendoTextBox').value(),
						requiredFrequency: $('#tbLELFrequency').data('kendoTextBox').value(),
						readings: lelReadings,
					},
					atmosTestReadings: atmosReadings,
					permitValidity: {
						from: $('#tmpFormA-TimeAllowedFrom').data('kendoTimePicker').value(),
						to: $('#tmpFormA-TimeAllowedTo').data('kendoTimePicker').value(),
					},
					permitWithdrawn: {
						status: $('#swHotworkWithdrawn').data('kendoSwitch').value(),
						reason: $('#tbWithdrawnReason').data('kendoTextBox').value(),
					},
				};

				var i = -1;

				_permitInfo.general.certificates.forEach((value, index) => {
					if (value.name == 'hotwork') {
						i = index;
					}
				});

				if (i > -1) {
					_permitInfo.general.certificates[i] = hotWork;
				} else {
					_permitInfo.general.certificates.push(hotWork);
				}

			});

			/********************************************************************************************************/


			/********************************************************************************************************/
			/* FORM B
			/********************************************************************************************************/
			$('#dlgFormB').on('shown.bs.modal', (e) => {
				try {

					if (tbl1FormB == null) {
						tbl1FormB = $('#tbl1FormB').DataTable({
							responsive: true,
							searching: false,
							paging: false,
							ordering: false,
							data: formBGasReadings,
							columns: [
								{ data: 'time' },
								{ data: 'gas' },
								{ data: 'oxygen' },
								{ data: 'toxic1' },
								{ data: 'toxic2' },
								{
									data: 'id',
									render: (data, type, row) => {
										var html = '<a href="javascript:;" onclick="removeRow(\'' + data + '\', tbl1FormB, formBGasReadings)"><i class="fa-solid fa-trash-can"></i></a>';
										return html;
									}
								}
							],
						});
					}

					if (tbl2FormB == null) {
						tbl2FormB = $('#tbl2FormB').DataTable({
							responsive: true,
							searching: false,
							paging: false,
							ordering: false,
							data: formBEntryRecords,
							columns: [
								{ data: 'workerName' },
								{ data: 'workerSignature' },
								{ data: 'reason' },
								{ data: 'timeEntry' },
								{ data: 'timeExit' },
								{
									data: 'id',
									render: (data, type, row) => {
										var html = '<a href="javascript:;" onclick="removeRow(\'' + data + '\', tbl2Form, formBEntryRecords)"><i class="fa-solid fa-trash-can"></i></a>';
										return html;
									}
								}
							],
						});
					}

				} catch (e) { }
			});

			$('#dlgFormBGasRead').on('show.bs.modal', () => {
				const readTime = $("#dtmFormBGasReadTime").data("kendoTimePicker");
				const gasPercentage = $("#tbFormBGasReadGasPercentageLEL").data("kendoTextBox");
				const oxyPercentage = $("#tbFormBGasReadOxyPercentage").data("kendoTextBox");
				const toxic1 = $("#tbFormBGasReadOxyToxic1").data("kendoTextBox");
				const toxic2 = $("#tbFormBGasReadOxyToxic2").data("kendoTextBox");

				readTime.value(null);
				gasPercentage.value(null);
				oxyPercentage.value(null);
				toxic1.value(null);
				toxic2.value(null);
			});

			$('#dlgFormBGasRead').on('hidden.bs.modal', () => {
				const readTime = $("#dtmFormBGasReadTime").data("kendoTimePicker");
				const gasPercentage = $("#tbFormBGasReadGasPercentageLEL").data("kendoTextBox");
				const oxyPercentage = $("#tbFormBGasReadOxyPercentage").data("kendoTextBox");
				const toxic1 = $("#tbFormBGasReadOxyToxic1").data("kendoTextBox");
				const toxic2 = $("#tbFormBGasReadOxyToxic2").data("kendoTextBox");

				if (readTime.value() != null && gasPercentage.value() != null && oxyPercentage.value() != null) {
					if (formBGasReadings.length == 0) {
						$('#tbl1FormB tbody').empty();
					}

					const m = moment(readTime.value());
					const n = moment().unix();

					formBGasReadings.push({
						id: n,
						timestamp: m.unix(),
						time: m.format('hh:mm A'),
						date: m.format('YYYY/MM/DD'),
						gas: gasPercentage.value(),
						oxygen: oxyPercentage.value(),
						toxic1: toxic1.value(),
						toxic2: toxic2.value(),
					});

					tbl1FormB.clear().draw();
					tbl1FormB.data = formBGasReadings;
					tbl1FormB.rows.add(formBGasReadings).draw();

					$('#dlgFormBGasRead').modal('hide');
				}

				setTimeout(() => {
					$('#tbl1FormB')[0].scrollIntoView();

					tbl1FormB.responsive.recalc();
					tbl1FormB.responsive.rebuild();

				}, 500);

			});

			$('#dlgFormB-Entry').on('show.bs.modal', (e) => {
				const workerName = $("#tbxFormB-Entry-WorkerName").data("kendoTextBox");
				const workerSignature = $("#tbxFormB-Entry-WorkerSignature").data("kendoTextBox");
				const entryReason = $("#txtFormB-Entry-Reason").data("kendoTextArea");
				const timeEntry = $("#tpkFormB-Entry-TimeEntry").data("kendoTimePicker");
				const timeExit = $("#tpkFormB-Entry-TimeExit").data("kendoTimePicker");

				workerName.value(null);
				workerSignature.value(null);
				entryReason.value(null);
				timeEntry.value(null);
				timeExit.value(null);
			});

			$('#dlgFormB-Entry').on('hidden.bs.modal', (e) => {
				const workerName = $("#tbxFormB-Entry-WorkerName").data("kendoTextBox");
				const workerSignature = $("#tbxFormB-Entry-WorkerSignature").data("kendoTextBox");
				const entryReason = $("#txtFormB-Entry-Reason").data("kendoTextArea");
				const timeEntry = $("#tpkFormB-Entry-TimeEntry").data("kendoTimePicker");
				const timeExit = $("#tpkFormB-Entry-TimeExit").data("kendoTimePicker");

				if (workerName.value() != null && workerSignature.value() != null && entryReason.value() != null && timeEntry.value() != null && timeExit.value() != null) {
					if (formBEntryRecords.length == 0) {
						$('#tbl2FormB tbody').empty();
					}

					const n = moment().unix();

					formBEntryRecords.push({
						id: n,
						//timestamp: m.unix(),
						workerName: workerName.value(),
						workerSignature: workerSignature.value(),
						reason: entryReason.value(),
						timeEntry: moment(timeEntry.value()).format('hh:mm A'),
						timeExit: moment(timeExit.value()).format('hh:mm A'),
						timeEntryTs: moment(timeEntry.value()).unix(),
						timeExitTs: moment(timeExit.value()).unix(),
					});

					tbl2FormB.clear().draw();
					tbl2FormB.data = formBEntryRecords;
					tbl2FormB.rows.add(formBEntryRecords).draw();

					$('#dlgFormB-Entry').modal('hide');
				}

				setTimeout(() => {
					$('#tbl2FormB')[0].scrollIntoView();

					tbl2FormB.responsive.recalc();
					tbl2FormB.responsive.rebuild();

				}, 500);
			});

			$('#btnSaveFormB').click((e) => {
				const confinedSpace = {
					name: 'confinedspace',
					attendants: $('#tbFormBAttendantNames').data('kendoTextBox').value(),
					workDescription: $('#taFormBDescription').data('kendoTextArea').value(),
					gasTest: {
						performedBy: $('#tbFormBGasTestBy').data('kendoTextBox').value(),
						initialTestWhen: $('#dtmFormBInitialGasRead').data('kendoDateTimePicker').value(),
						initialLEL: $('#tbFormBInitialLELPercentage').data('kendoTextBox').value(),
						initialO2: $('#tbFormBInitialO2Percentage').data('kendoTextBox').value(),
						others: [
							{
								id: 'tbFormBInitialToxic1',
								value: $('#tbFormBInitialToxic1').data('kendoTextBox').value(),
							},
							{
								id: 'tbFormBInitialToxic2',
								value: $('#tbFormBInitialToxic2').data('kendoTextBox').value(),
							},
						],
						requiredFrequency: $('#tbFormBDesignatedRequiredFrequency').data('kendoTextBox').value(),
						readings: formBGasReadings,
					},
					potentialHazards: {
						hydrogenSulphide: {
							yes: $('#chkFormBHazard-01-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-01-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-01-3').data('kendoCheckBox').value(),
						},
						oxygenDeficiency: {
							yes: $('#chkFormBHazard-02-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-02-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-02-3').data('kendoCheckBox').value(),
						},
						flammableGas: {
							yes: $('#chkFormBHazard-03-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-03-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-03-3').data('kendoCheckBox').value(),
						},
						flammableSolids: {
							yes: $('#chkFormBHazard-04-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-04-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-04-3').data('kendoCheckBox').value(),
						},
						electrical: {
							yes: $('#chkFormBHazard-05-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-05-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-05-3').data('kendoCheckBox').value(),
						},
						ionizingRadiation: {
							yes: $('#chkFormBHazard-06-1').data('kendoCheckBox').value(),
							no: $('#chkFormBHazard-06-2').data('kendoCheckBox').value(),
							na: $('#chkFormBHazard-06-3').data('kendoCheckBox').value(),
						},
