			html += '            <img title="(' + data[1] + ') ' + data[2] + '" src="/img/icons/certs/' + imgName + '.png" style="width:24px;height:24px" />';
			html += '				<h4 class="ms-3 mb-0">' + data[2] + '</h4>';
			html += '			</div>';
			html += '			<div class="ms-5">';
			html += '				<a href="#dlgForm' + data[1] + '" class="no-loading" data-bs-toggle="modal" data-bs-target="#dlgForm' + data[1] + '"><i class="fa-sharp fa-solid fa-pen-to-square"></i></a>';
			//html += '				<a href="javascript:;" class="no-loading mx-3" onclick="removeCert(\'' + data[0] + '\')"><i class="fa-solid fa-trash-can"></i></a>';
			html += '			</div>';
			html += '</li>';

			let tmpCertData = {
				name: data[0]
			};

			selectedCerts.push(tmpCertData);

			$('.selected-certs').append(html);

			_permitInfo.general.certificates = selectedCerts;
		};


		const removeCert = (item) => {
			const elem = $('ul.selected-certs li#item-' + item);

			if (elem.length > 0) {
				elem.remove();

				const n = selectedCerts.indexOf(item);

				if (n > -1) {
					selectedCerts.splice(n, 1);
				}

				if (selectedCerts.length == 0) {
					$('ul.selected-certs').append('<li class="list-group-item fade show"><span>No associated certificate attached</span></li>');
				}
			}
		};


		const entryRecordsOnChange = () => {
			const workerName = $("#tbxFormB-Entry-WorkerName").data("kendoTextBox");
			const workerSignature = $("#tbxFormB-Entry-WorkerSignature").data("kendoTextBox");
			const entryReason = $("#txtFormB-Entry-Reason").data("kendoTextArea");
			const timeEntry = $("#tpkFormB-Entry-TimeEntry").data("kendoTimePicker");
			const timeExit = $("#tpkFormB-Entry-TimeExit").data("kendoTimePicker");

			if (workerName.value() != null && workerSignature.value() != null && entryReason.value() != null && timeEntry.value() != null && timeExit.value() != null) {
				$('#dlgFormB-Entry .btn-primary').removeClass('disabled').prop('disabled', null);
			} else {
				$('#dlgFormB-Entry .btn-primary').addClass('disabled').prop('disabled', 'disabled');
			}
		};


		const onIgnitionSourceCheckBoxChange = (e) => {
			$('#tbFormAIgnitionSource5').data('kendoTextBox').enable(e.sender.value());

			if (e.sender.value()) {
				$('#tbFormAIgnitionSource5').data('kendoTextBox').focus();
			}
		};


		const onStartDateChange = (e) => {
			var dtm = new Date(e.sender.value());
			var endDate;
			var n = 0;

			while (n < 6) {
				endDate = new Date(dtm.setDate(dtm.getDate() + 1));

				//if (endDate.getDay() != 0 && endDate.getDay() != 6) {
				//	n++;
				//}

				n++;
			}

			$('#endDateTime').data('kendoDatePicker').min(e.sender.value());
			$('#endDateTime').data('kendoDatePicker').max(endDate);
		};


		const onChangeSites = () => {
			var checkedNodes = [];
			var dropDownTree = $('#ddtLocation').data('kendoDropDownTree');

			checkedNodeIds(dropDownTree.dataSource.view(), checkedNodes);
		};


		const checkedNodeIds = (nodes, checkedNodes) => {
			for (var i = 0; i < nodes.length; i++) {
				if (nodes[i].checked) {
					checkedNodes.push(nodes[i].id);
				}

				if (nodes[i].hasChildren) {
					checkedNodeIds(nodes[i].children.view(), checkedNodes);
				}
			}
		};


