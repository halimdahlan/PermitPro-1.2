@using Kendo.Mvc.UI

<!-- Modal: FORM C /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
<div class="modal fade" id="dlgFormC" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormCLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header bg-primary-soft">
				<div class="modal-title" id="dlgFormCLabel">
					<div class="d-flex flex-row align-items-center">
						<!--div-- class="avatar">
							<span class="avatar-title rounded-circle bg-info" style="font-size: 22.75px !important; font-weight: 700 !important;">C</span>
						</!--div-->
						<img title="(C) RADIATION" src="/img/icons/certs/radiation.png" style="width:40px;height:40px;" />
						<span class="ms-3 dialog-title">RADIATION</span>
					</div>
				</div>
				<a href="" class="text-dark no-loading" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">GENERAL INFORMATION</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						Only valid for routine activities ionise radiation source. (Only to be completed by authorised persons).
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">To be completed by the Permit Holder</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbxFormC-MaterialUsed")
								.Label(x => x.Content("Radioactive material being used, please specify"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div class="d-flex flex-row mb-3">
						<div class="flex-grow-1">
							@(Html.Kendo().TextBox()
									.Name("tbxFormC-MaterialActivity")
									.Label(x => x.Content("Activity of material"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
						<div class="ms-3 pt-5">
							<span>Bg/mCi</span>
						</div>
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbxFormC-ContainedWithin")
								.Label(x => x.Content("Contained within"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div class="mb-3">
						<div class="d-flex flex-column flex-md-row">
							<div class="me-5">
								<div style="padding-top: 4px;">
									@(Html.Kendo().CheckBox()
											.Name("chkFormC-XRayMachine")
											.Label("   X-ray machine")
											.Size(ComponentSize.Large)
											.Rounded(BasicRounded.Medium))
								</div>
							</div>
							<div class="mt-3 mt-md-0">
								<div class="d-flex flex-row align-items-center mb-2 ms-4 ms-md-0">
									<label style="min-width: 140px;">Manufacturer/model</label>
									<div class="ms-3">
										@(Html.Kendo().TextBox()
												.Name("tbxFormC-ManufacturerModel")
												.Size(ComponentSize.Medium)
												.Rounded(Rounded.Large)
												.FillMode(FillMode.Outline))
									</div>
								</div>
								<div class="d-flex flex-row align-items-center mb-2 ms-4 ms-md-0">
									<label style="min-width: 140px;">Max tube voltage</label>
									<div class="ms-3 me-3">
										@(Html.Kendo().TextBox()
												.Name("tbxFormC-MaxTubeVoltage")
												.Size(ComponentSize.Medium)
												.Rounded(Rounded.Large)
												.FillMode(FillMode.Outline))
									</div>
									<div>kV</div>
								</div>
								<div class="d-flex flex-row align-items-center ms-4 ms-md-0">
									<label style="min-width: 140px;">Max tube current</label>
									<div class="ms-3 me-3">
										@(Html.Kendo().TextBox()
												.Name("tbxFormC-MaxTubeCurrent")
												.Size(ComponentSize.Medium)
												.Rounded(Rounded.Large)
												.FillMode(FillMode.Outline))
									</div>
									<div>mA</div>
								</div>
							</div>
						</div>
					</div>
					<div class="mb-3">
						<div class="d-flex flex-column flex-md-row">
							<div class="me-5">
								<div style="padding-top: 4px;">
									@(Html.Kendo().CheckBox()
											.Name("chkFormC-OtherEquip")
											.Label("   Other equipment, specify")
											.Size(ComponentSize.Large)
											.Rounded(BasicRounded.Medium))
								</div>
							</div>
							<div class="mt-3 mt-md-0">
								<div class="d-flex flex-row align-items-center mb-2 ms-4 ms-md-0">
									<div style="margin-left: 83px;">
										@(Html.Kendo().TextBox()
												.Name("tbxFormC-OtherEquip")
												.Size(ComponentSize.Medium)
												.Rounded(Rounded.Large)
												.FillMode(FillMode.Outline))
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextArea()
								.Name("txtFormC-EquipAdditionalInfo")
								.Label(x => x.Content("Additional information about operation of equipment"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(2))
					</div>
					<div class="mb-3">
						<div class="mb-2">
							Radiation equipment will be used between
						</div>
						<div class="d-flex flex-column flex-md-row justify-content-evenly mb-3">
							<div class="w-100 me-0 me-md-3 mb-3 mb-md-0">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormC-TimeUseFrom")
										.Label(x => x.Content("From"))
										.DateInput())
							</div><div class="w-100 ms-0 ms-md-3">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormC-TimeUseTo")
										.Label(x => x.Content("To"))
										.DateInput())
							</div>
						</div>
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextArea()
								.Name("txtFormC-PreventMeasures")
								.Label(x => x.Content("Measures to prevent and mitigate exposure"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(2))
					</div>
					<div class="mb-4">
						@(Html.Kendo().TextArea()
								.Name("txtFormC-AdditionalControl")
								.Label(x => x.Content("Additional controls required"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(2))
					</div>
					<div class="text-center">
						<h2>ALL IRREGULARITIES DURING WORK MUST BE REPORTED IMMEDIATELY TO THE PERMIT HOLDER</h2>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Validity of the Radiation Permit</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						I certify that I have reviewed the proposed work and I am satisfied that it is adequately described on the
						Permit to Work documents and that the precautions detailed in this certificate are adequate and clearly defined.
					</div>
					<div class="mb-3">
						<div class="mb-2">
							Radiation Permit is allowed between
						</div>
						<div class="d-flex flex-column flex-md-row justify-content-evenly mb-3">
							<div class="w-100 me-0 me-md-3 mb-3 mb-md-0">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormC-TimeAllowedFrom")
										.Label(x => x.Content("From"))
										.DateInput())
							</div><div class="w-100 ms-0 ms-md-3">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormC-TimeAllowedTo")
										.Label(x => x.Content("To"))
										.DateInput())
							</div>
						</div>
					</div>
				</div>
				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Radiation Certificate is Withdrawn</h3>
				</div>
				<div class="px-2 mb-4">
					<div>
						<div class="d-flex flex-row align-items-center">
							<div class="me-5">
								@(Html.Kendo().Switch()
										.Name("swtFormC-Withdrawn")
										.Size(ComponentSize.Small)
										.Messages(x => x.Checked("YES").Unchecked("NO"))
										.Events(x => x.Change("onChangeWithdrawnFormC")))
							</div>
							<label class="form-label me-3" for="tbxFormD-Withdrawn-Reason">Reason</label>
							<div class="flex-grow-1">
								@(Html.Kendo().TextBox()
										.Name("tbxFormC-Withdrawn-Reason")
										.Enable(false)
										.Size(ComponentSize.Medium)
										.Rounded(Rounded.Large)
										.FillMode(FillMode.Outline))
							</div>
						</div>
					</div>
				</div>

			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary" id="btnSaveFormC" data-bs-dismiss="modal">Save changes</button>
			</div>
		</div>
	</div>
</div>
<!-- ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
