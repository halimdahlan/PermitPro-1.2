@using Kendo.Mvc.UI

<!-- Modal: FORM B /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
<div class="modal fade" id="dlgFormB" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormBLabel" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header bg-primary-soft">
				<div class="modal-title" id="dlgFormBLabel">
					<div class="d-flex flex-row align-items-center">
						<!--div class="avatar">
							<span class="avatar-title rounded-circle bg-info" style="font-size: 22.75px !important; font-weight: 700 !important;">B</span>
						</div-->
						<img title="(B) CONFINED SPACE" src="/img/icons/certs/confinedspace.png" style="width:40px;height:40px;" />
						<span class="ms-3 dialog-title">CONFINED SPACE</span>
					</div>
				</div>
				<a href="" class="text-dark no-loading" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">INSTRUCTIONS</h3>
				</div>
				<div class="px-2 mb-4">
					<ul>
						<li>
							This Certificate along with its base PTW is intended to assure identification and communication of potential
							hazards and threats along with the preventive and mitigating barrier plans to anyone who could impact or is impacted by the work activity.
						</li>
						<li>
							Prior to ANY WORKER ENTERING a confined space, the Permit Holder will review the potential hazards and controls
							to prevent harm to impacted workers.
						</li>
					</ul>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Attendant Name and Description of Work Information</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbFormBAttendantNames")
								.Label(x => x.Content("Designated attendant(s) name"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div>
						@(Html.Kendo().TextArea()
								.Name("taFormBDescription")
								.Label(x => x.Content("Description of the confined space"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(3))
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">GAS TEST PERFORMED BY (AGT name and signature)</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-4 text-secondary">
						Allowable atmospheres: Utilize MSDS and Shell Site Industrial Hygienist as needed for support for specifying
						respirator protection and assuring fitness to work when respirator protection used.
					</div>
					<div class="mb-4">
						<table class="table table-sm table-bordered table-gas-info">
							<thead>
								<tr>
									<th scope="col">&nbsp;</th>
									<th scope="col">Without Respiratory Protection</th>
									<th scope="col">With Respiratory Protection</th>
									<th scope="col">Inert Entry</th>
								</tr>
							</thead>
							<tbody>
								<tr>
									<td>Oxygen %</td>
									<td>20 to max. 21.5</td>
									<td>&gt;16 to max. 21.5</td>
									<td>&lt;4</td>
								</tr>
								<tr>
									<td>Toxics</td>
									<td>&lt; ½ OEL</td>
									<td>&lt; IDLH</td>
									<td>Not applicable</td>
								</tr>
								<tr>
									<td>Flammables % of LEL</td>
									<td>Not detectable (&lt;1)</td>
									<td>
										&lt;10; For hot work - not detectable
									</td>
									<td>&lt;10</td>
								</tr>
							</tbody>
						</table>
					</div>
					<div class="d-flex flex-row align-items-center">
						<label class="form-label me-3" for="tbFormBGasTestBy">AGT name</label>
						<div class="flex-grow-1">
							@(Html.Kendo().TextBox()
									.Name("tbFormBGasTestBy")
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">INITIAL GAS READINGS by AGT prior to Permit approval: Input applicable toxic below</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="d-flex flex-column flex-md-row align-items-center justify-content-evenly mb-3">
						<div class="w-100 mb-2 mb-md-0 me-0 me-md-3">
							@(Html.Kendo().DateTimePicker()
									.Name("dtmFormBInitialGasRead")
									.Label(x => x.Content("Date and time"))
									.Format("{0:dd/MM/yyyy hh:mm tt}")
									.Min(DateTime.Today)
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
									.AdaptiveMode(AdaptiveMode.Auto)
									.ComponentType("modern")
									.DateInput())
						</div>
						<div class="w-100 mb-2 mb-md-0 ms-0 ms-md-3 me-0 me-md-3">
							@(Html.Kendo().TextBox()
									.Name("tbFormBInitialLELPercentage")
									.Label(x => x.Content("Initial LEL %"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
						<div class="w-100 mb-2 mb-md-0 ms-0 ms-md-3 me-0 me-md-3">
							@(Html.Kendo().TextBox()
									.Name("tbFormBInitialO2Percentage")
									.Label(x => x.Content("Oxygen %"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
						<div class="w-100 mb-2 mb-md-0 ms-0 ms-md-3 me-0 me-md-3">
							@(Html.Kendo().TextBox()
									.Name("tbFormBInitialToxic1")
									.Label(x => x.Content("Toxic"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
						<div class="w-100 mb-0 ms-0 ms-md-3">
							@(Html.Kendo().TextBox()
									.Name("tbFormBInitialToxic2")
									.Label(x => x.Content("Toxic"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
					</div>
					<div class="mb-3 text-secondary">
						Monitoring while entrants are inside the confined space. Continuous gas monitoring is the preferred method.
						When non continuous testing is used, document the required interval and the gas monitoring results while workers
						are inside the confined space. Input below toxic gas to be monitored as applicable.
					</div>
					<div class="d-flex flex-row align-items-center mb-4">
						<label class="form-label" for="tbFormBDesignatedRequiredFrequency">Designated required frequency of testing</label>
						<div class="ms-3">
							@(Html.Kendo().TextBox()
									.Name("tbFormBDesignatedRequiredFrequency")
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
					</div>
					<div class="mb-4">
						<table id="tbl1FormB" class="table table-striped display responsive nowrap" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col" data-priority="1">Time of test</th>
									<th scope="col" class="text-center" data-priority="2">Flammable Gas % LEL</th>
									<th scope="col" class="text-center" data-priority="3">Oxygen %</th>
									<th scope="col" class="text-center">Toxic</th>
									<th scope="col" class="text-center">Toxic</th>
									<th scope="col">&nbsp;</th>
								</tr>
							</thead>
						</table>
						<div class="d-flex flex-row justify-content-end mt-3">
							<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgFormBGasRead"><span class="mx-3">Add reading</span></button>
						</div>
					</div>
					<div class="list-group list-group-flush">
						<div class="list-group-item bg-light px-3">
							<div class="d-flex flex-row justify-content-end">
								<div class="flex-grow-1"><h3 class="mb-0">POTENTIAL HAZARDS</h3></div>
