												.Size(ComponentSize.Large)
												.Rounded(BasicRounded.Medium))
									</div>
									<div class="hazard-option text-center mx-1">
										@(Html.Kendo().CheckBox()
												.Name("chkFormBRescueEquip-08-2")
												.Size(ComponentSize.Large)
												.Rounded(BasicRounded.Medium))
									</div>
									<div class="hazard-option text-center mx-1">
										@(Html.Kendo().CheckBox()
												.Name("chkFormBRescueEquip-08-3")
												.Size(ComponentSize.Large)
												.Rounded(BasicRounded.Medium))
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Validity of the Confined Space Permit</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						I certify that I have reviewed the proposed work and I am satisfied that the workers understand the hazards
						and that preventive measures are in place with adequate supervision to proceed.
					</div>
					<div class="mb-3">
						<div class="mb-2">
							Confined Space Permit is allowed between
						</div>
						<div class="d-flex flex-column flex-md-row justify-content-evenly mb-3">
							<div class="w-100 me-0 me-md-3 mb-3 mb-md-0">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormB-TimeAllowedFrom")
										.Label(x => x.Content("From"))
										.DateInput())
							</div>
							<div class="w-100 ms-0 ms-md-3">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormB-TimeAllowedTo")
										.Label(x => x.Content("To"))
										.DateInput())
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Confined Space Certificate is Withdrawn</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="d-flex flex-row align-items-center">
						<div class="me-5">
							@(Html.Kendo().Switch()
									.Name("swtFormB-Withdrawn")
									.Size(ComponentSize.Small)
									.Messages(x => x.Checked("YES").Unchecked("NO"))
									.Events(x => x.Change("onChangeWithdrawnFormB")))
						</div>
						<label class="form-label me-3" for="tbWithdrawnReason">Reason</label>
						<div class="flex-grow-1">
							@(Html.Kendo().TextBox()
									.Name("tbxFormB-Withdrawn-Reason")
									.Enable(false)
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline))
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Confined Space Entry Record</h3>
				</div>
				<div class="px-2 mb-4">
					<div>
						<table id="tbl2FormB" class="table table-striped display responsive" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col" class="">Worker Name</th>
									<th scope="col" class="">Worker Signature</th>
									<th scope="col" class="">Reason For Entry</th>
									<th scope="col" class="">Time Of Entry</th>
									<th scope="col" class="">Time Of Exit</th>
									<th scope="col" class="">&nbsp;</th>
								</tr>
							</thead>
						</table>

						<div class="d-flex flex-row justify-content-end mt-3">
							<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgFormB-Entry"><span class="mx-3">Add entry</span></button>
						</div>
					</div>
				</div>

			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary" id="btnSaveFormB" data-bs-dismiss="modal">Save changes</button>
			</div>
		</div>
	</div>
</div>
<!-- Modal: ADD GAS READING -->
<div class="modal fade" id="dlgFormBGasRead" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormBGasReadLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgFormBGasReadLabel">Add gas reading</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormB" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div>
					<div class="mb-3">
						@(Html.Kendo().TimePicker()
								.Name("dtmFormBGasReadTime")
								.Label(x => x.Content("Time of test"))
								.DateInput())
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbFormBGasReadGasPercentageLEL")
								.Label(x => x.Content("Flammable gas % LEL"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbFormBGasReadOxyPercentage")
								.Label(x => x.Content("Oxygen %"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbFormBGasReadOxyToxic1")
								.Label(x => x.Content("Toxic 1"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
					<div>
						@(Html.Kendo().TextBox()
								.Name("tbFormBGasReadOxyToxic2")
								.Label(x => x.Content("Toxic 2"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline))
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormB">Close</button>
				<button type="button" class="btn btn-primary btn-add-gas-reading" data-bs-toggle="modal" data-bs-target="#dlgFormB">Save changes</button>
			</div>
		</div>
	</div>
</div>
<!-- Modal: ADD ENTRY RECORD -->
<div class="modal fade" id="dlgFormB-Entry" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormB-EntryLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgFormB-EntryLabel">Add entry record</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormB" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbxFormB-Entry-WorkerName")
								.Label(x => x.Content("Worker name"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Events(x => x.Change("entryRecordsOnChange")))
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextBox()
								.Name("tbxFormB-Entry-WorkerSignature")
								.Label(x => x.Content("Worker signature"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Events(x => x.Change("entryRecordsOnChange")))
					</div>
					<div class="mb-3">
						@(Html.Kendo().TextArea()
								.Name("txtFormB-Entry-Reason")
								.Label(x => x.Content("Reason for entry"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(2)
								.Events(x => x.Change("entryRecordsOnChange")))
					</div>
					<div class="mb-3">
						@(Html.Kendo().TimePicker()
								.Name("tpkFormB-Entry-TimeEntry")
								.Label(x => x.Content("Time of entry"))
								.DateInput()
								.Events(x => x.Change("entryRecordsOnChange")))
					</div>
					<div>
						@(Html.Kendo().TimePicker()
								.Name("tpkFormB-Entry-TimeExit")
								.Label(x => x.Content("Time of exit"))
								.DateInput()
								.Events(x => x.Change("entryRecordsOnChange")))
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormB">Close</button>
				<button type="button" class="btn btn-primary disabled" data-bs-toggle="modal" data-bs-target="#dlgFormB" disabled>Save changes</button>
			</div>
		</div>
	</div>
</div>
