@using Kendo.Mvc.UI

<!-- Modal: FORM A /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
<div class="modal fade" id="dlgFormA" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormALabel" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header bg-primary-soft">
				<div class="modal-title" id="dlgFormALabel">
					<div class="d-flex flex-row align-items-center">
						<!--div class="avatar">
							<span class="avatar-title rounded-circle bg-info" style="font-size: 22.75px !important; font-weight: 700 !important;">A</span>
						</div-->
						<img title="(A) HOT WORK" src="/img/icons/certs/hotwork.png" style="width:40px;height:40px;" />
						<span class="ms-3 dialog-title">HOT WORK</span>
					</div>
				</div>
				<a href="" class="text-dark no-loading" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">GENERAL INFORMATION</h3>
				</div>
				<div class="d-flex flex-column flex-md-row justify-content-evenly mb-4 px-2">
					<div class="w-100 me-md-3">
						@(Html.Kendo().TextBox()
								.Name("tbFormAEmergencyContact")
								.Label(x => x.Content("Emergency Contact"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Events(e => e.Change("hotWorkOnChange")))
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">HOT WORK CHECKLIST</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList1")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList1" style="margin-top: 4px;">
								Communication link has been established with Operations control room
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList2")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList2" style="margin-top: 4px;">
								Calibrated gas tester to be used by AGT
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList3")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList3" style="margin-top: 4px;">
								The working area is defined with barriers or signs to prevent un-authorized entry
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList4")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList4" style="margin-top: 4px;">
								Designated fire watch is assigned and understands their role
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList5")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList5" style="margin-top: 4px;">
								Area within 15 meters of ignition sources are free of flammable materials or such materials are covered with fire
								retardant material
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList6")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList6" style="margin-top: 4px;">
								Sewer and drain systems and other low lying areas are protected against sparks within 15 meters
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-md-center">
						<div class="mt-1 mt-md-0">
							@(Html.Kendo().CheckBox()
									.Name("chkFormACheckList7")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormACheckList7" style="margin-top: 4px;">
								Fire fighting materials are present and ready for use
							</label>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">HOT WORK IGNITION SOURCES (mark the applicable sources for the work performed)</h3>
				</div>
				<div class="px-2 mb-4 d-flex flex-column flex-md-row">
					<div class="d-flex flex-md-row align-items-center ignition-source">
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormAIgnitionSource1")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormAIgnitionSource1" style="margin-top: 4px;">
								Welding
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-center ignition-source">
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormAIgnitionSource2")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormAIgnitionSource2" style="margin-top: 4px;">
								Burning
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-center ignition-source">
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormAIgnitionSource3")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormAIgnitionSource3" style="margin-top: 4px;">
								Gas Cutting
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-center ignition-source">
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormAIgnitionSource4")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="ms-3">
							<label class="form-label" for="chkFormAIgnitionSource4" style="margin-top: 4px;">
								Grinding
							</label>
						</div>
					</div>
					<div class="d-flex flex-row align-items-center ignition-source">
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormAIgnitionSource5")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium)
									.Events(e => e.Change("onIgnitionSourceCheckBoxChange")))
						</div>
						<div class="ms-3">
							<div class="d-flex flex-row align-items-center">
								<label class="form-label" for="chkFormAIgnitionSource5" style="margin-top: 4px;">
									Other
								</label>
								<div class="ms-5 ms-md-3">
									@(Html.Kendo().TextBox()
											.Size(ComponentSize.Small)
											.Enable(false)
											.Rounded(Rounded.Large)
											.FillMode(FillMode.Outline)
											.Name("tbFormAIgnitionSource5")
											.Events(e => e.Change("hotWorkOnChange")))
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">GAS TEST PERFORMED BY (AGT name and signature)</h3>
				</div>
				<div class="px-2 mb-4">
					@(Html.Kendo().TextArea()
							.Name("tbFormAGasTestBy")
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Rows(2)
							.Events(e => e.Change("hotWorkOnChange")))
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">INITIAL LEL READING by AGT: Hot Work not to commence unless LEL reading is 0% (&lt; 1% considered negligible and OK)</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="d-flex flex-column flex-md-row justify-content-evenly">
						<div class="w-100 me-md-3 mt-3 mt-md-0">
							@(Html.Kendo().DateTimePicker()
									.Name("dtmFormA1")
									.Label(x => x.Content("Date and Time"))
									.Format("{0:dd/MM/yyyy hh:mm tt}")
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
									.AdaptiveMode(AdaptiveMode.Auto)
									.ComponentType("modern")
									.DateInput()
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
						<div class="w-100 ms-md-3 mt-3 mt-md-0">
							@(Html.Kendo().TextBox()
									.Name("tbFormALelReading")
									.Label(x => x.Content("Initial LEL % reading"))
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
					</div>
					<div class="my-2">
						If non continuous testing is done specify testing frequency required and record results below:
					</div>
					<div class="d-flex flex-row align-items-center">
						<label class="form-label">Enter required frequency</label>
						<div class="ms-3">
							@(Html.Kendo().TextBox()
									.Name("tbLELFrequency")
									.Size(ComponentSize.Small)
									.Rounded(Rounded.Medium)
									.FillMode(FillMode.Outline)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
					</div>
					<div class="mt-3">
						<table id="tblLEL" class="table table-striped display" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col">Time of reading</th>
									<th scope="col" class="text-center" style="width: 110px;">LEL reading</th>
									<th scope="col" style="width: 50px;">&nbsp;</th>
								</tr>
							</thead>
						</table>

						<div class="d-flex flex-row justify-content-end mt-3">
							<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgLelReading"><span class="mx-3">Add reading</span></button>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Other Atmospheric Testing results if required: enter any potentially toxic gases to be monitored below</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mt-3">
						<table id="tblAtmos" class="table table-striped display" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col">Time of reading</th>
									<th scope="col" class="text-center" style="width: 110px;">O<sub>2</sub> reading</th>
									<th scope="col" style="width: 50px;">&nbsp;</th>
								</tr>
							</thead>
						</table>
						<div class="d-flex flex-row justify-content-end mt-3">
							<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgAtmos"><span class="mx-3">Add reading</span></button>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">
						VALIDITY OF THE HOT WORK PERMIT
					</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						I certify that I have reviewed the proposed work and I am satisfied that the workers
						understand the hazards and that preventive measures are in place with adequate supervision to proceed.
					</div>
					<div class="mb-3">
						<div class="mb-2">
							Hot Work Permit is allowed between
						</div>
						<div class="d-flex flex-column flex-md-row justify-content-evenly mb-3">
							<div class="w-100 me-0 me-md-3 mb-3 mb-md-0">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormA-TimeAllowedFrom")
										.Label(x => x.Content("From"))
										.DateInput()
										.Events(e => e.Change("hotWorkOnChange")))
							</div><div class="w-100 ms-0 ms-md-3">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormA-TimeAllowedTo")
										.Label(x => x.Content("To"))
										.DateInput()
										.Events(e => e.Change("hotWorkOnChange")))
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Hot Work Certificate is Withdrawn</h3>
				</div>
				<div class="px-2">
					<div class="d-flex flex-row align-items-center">
						<div class="me-5">
							@(Html.Kendo().Switch()
									.Name("swHotworkWithdrawn")
									.Size(ComponentSize.Small)
									.Messages(x => x.Checked("YES").Unchecked("NO"))
									.Events(x => x.Change("onChangeWithdrawnFormA")))
						</div>
						<label class="form-label me-3" for="tbWithdrawnReason">Reason</label>
						<div class="flex-grow-1">
							@(Html.Kendo().TextBox()
									.Name("tbWithdrawnReason")
									.Enable(false)
									.Size(ComponentSize.Medium)
									.Rounded(Rounded.Large)
									.FillMode(FillMode.Outline)
									.Events(e => e.Change("hotWorkOnChange")))
						</div>
					</div>
				</div>

			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary" id="btnSaveFormA" data-bs-dismiss="modal">Save changes</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal: ADD LEL READING -->
<div class="modal fade" id="dlgLelReading" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgLelReadingLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgLelReadingLabel">Add LEL reading</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormA" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div>
					<div class="mb-3">
						@(Html.Kendo().TimePicker()
								.Name("dtmReadTime")
								.Label(x => x.Content("Time of reading"))
								.DateInput()
								.Events(e => e.Change("hotWorkOnChange")))
					</div>
					<div>
						@(Html.Kendo().TextBox()
								.Name("tbReadValue")
								.Label(x => x.Content("LEL reading"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Events(e => e.Change("hotWorkOnChange")))
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormA">Close</button>
				<button type="button" class="btn btn-primary btn-add-reading" data-bs-toggle="modal" data-bs-target="#dlgFormA">Add</button>
			</div>
		</div>
	</div>
</div>

<!-- Modal: ADD O2 LEVEL -->
<div class="modal fade" id="dlgAtmos" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgAtmosLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgAtmosLabel">Add O<sub>2</sub> reading</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormA" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div>
					<div class="mb-3">
						@(Html.Kendo().TimePicker()
								.Name("dtmAtmosReadTime")
								.Label(x => x.Content("Time of reading"))
								.DateInput()
								.Events(e => e.Change("hotWorkOnChange")))
					</div>
					<div>
						@(Html.Kendo().TextBox()
								.Name("tbAtmosReadValue")
								.Label(x => x.Content("O<sub>2</sub> reading"))
								.Size(ComponentSize.Medium)
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Events(e => e.Change("hotWorkOnChange")))
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormA">Close</button>
				<button type="button" class="btn btn-primary btn-add-o2" data-bs-toggle="modal" data-bs-target="#dlgFormA">Add</button>
			</div>
		</div>
	</div>
</div>
<!-- ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
