@using Kendo.Mvc.UI

<!-- Modal: FORM E /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
<div class="modal fade" id="dlgFormE" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormELabel" aria-hidden="true">
	<div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
		<div class="modal-content">
			<div class="modal-header bg-primary-soft">
				<div class="modal-title" id="dlgFormDLabel">
					<div class="d-flex flex-row align-items-center">
						<!--div-- class="avatar">
							<span class="avatar-title rounded-circle bg-info" style="font-size: 22.75px !important; font-weight: 700 !important;">E</span>
						</!--div-->
						<img title="(E) ISOLATION" src="/img/icons/certs/isolation.png" style="width:40px;height:40px;" />
						<span class="ms-3 dialog-title">SAFE ISOLATION LOCK OUT/TAG OUT</span>
					</div>
				</div>
				<a href="" class="text-dark no-loading" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">IDENTIFICATION OF EQUIPMENT BEING WORKED ON AND THE EQUIPMENT THAT IS LOCKED/TAGGED</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						(specific valves, pumps, motors, switch gears, etc.)
					</div>
					<div>
						@(Html.Kendo().TextArea()
								.Name("txtFormE-EquipmentUsed")
								.Label(x => x.Content("Equipment Being worked on and verified to be at a zero energy state prior to work starting (describe or sketch to make clear)"))
								.Rounded(Rounded.Large)
								.FillMode(FillMode.Outline)
								.Rows(8))
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">TYPE OF LOCK OUT / TAG OUT (LO/TO) USED</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="d-flex flex-column flex-md-row">
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-LOTOType1")
									.Label("  Each authorized individual will apply LO/TO to each isolation device")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div>
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-LOTOType2")
									.Label("  Use of Group LO/TO Using Lock Box")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Energy Type Isolated</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						Mark below (√) the type of energy to be isolated:
					</div>
					<div class="d-flex flex-column flex-md-row">
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-EnergyType1")
									.Label("  Electrical")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-EnergyType2")
									.Label("  Steam")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-EnergyType3")
									.Label("  Hydraulic")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-EnergyType4")
									.Label("  Mechanical")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-EnergyType5")
									.Label("  Pneumatic")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div>
							<div class="d-flex flex-row align-items-center">
								<div>
									@(Html.Kendo().CheckBox()
											.Name("chkFormE-EnergyType6")
											.Label("  Other")
											.Size(ComponentSize.Large)
											.Rounded(BasicRounded.Medium)
											.Events(x => x.Change("onChangeFormEEnergyType")))
								</div>
								<div class="ms-5 ms-md-3">
									@(Html.Kendo().TextBox()
											.Name("tbxFormE-EnergyType6")
											.Size(ComponentSize.Small)
											.Rounded(Rounded.Medium)
											.FillMode(FillMode.Outline)
											.Enable(false))
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Method of Isolation</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						Mark below (√) isolation being used:
					</div>
					<div class="d-flex flex-column flex-md-row align-items-center">
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-IsolationMethod1")
									.Label("  Lock & Tag")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-IsolationMethod2")
									.Label("  Tag Only")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-IsolationMethod3")
									.Label("  Blinds")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div class="me-0 me-md-5">
							@(Html.Kendo().CheckBox()
									.Name("chkFormE-IsolationMethod4")
									.Label("  Double Block & Bleed")
									.Size(ComponentSize.Large)
									.Rounded(BasicRounded.Medium))
						</div>
						<div>
							<div class="d-flex flex-row align-items-center">
								<div>
									@(Html.Kendo().CheckBox()
											.Name("chkFormE-IsolationMethod5")
											.Label("  Other")
											.Size(ComponentSize.Large)
											.Rounded(BasicRounded.Medium)
											.Events(x => x.Change("onChangeFormEIsolationMethod")))
								</div>
								<div class="ms-3">
									@(Html.Kendo().TextBox()
											.Name("tbxFormE-IsolationMethod5")
											.Size(ComponentSize.Medium)
											.Rounded(Rounded.Large)
											.FillMode(FillMode.Outline)
											.Enable(false))
								</div>
							</div>
						</div>
					</div>
					<div class="mt-3 d-flex flex-row justify-content-start">
						<div class="card bg-light mb-0">
							<div class="card-body">
								<div>
									<h2>Sequence of Lockout</h2>
								</div>
								<ol>
									<li>Prepare for shutdown</li>
									<li>Equipment shut down</li>
									<li>Identify all equipment isolation points</li>
									<li>Apply L/O-T/O device(s)</li>
									<li>Release stored energy</li>
									<li>Verify equipment will not start</li>
									<li>Perform work</li>
									<li>Clear tools, inspect equipment</li>
									<li>Clear personnel from area</li>
									<li>Remove lock out/tag out devices</li>
									<li>Restart equipment</li>
								</ol>
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">AUTHORIZED INDIVIDUALS</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						Individuals doing the Lock Out/Tag Out including verification of zero energy state:
					</div>
					<div>
						<table id="tbl1FormE" class="table table-striped display responsive" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col" style="width: 120px;">Date</th>
									<th scope="col">Name</th>
									<th scope="col">Company</th>
									<th scope="col" style="width: 50px;">&nbsp;</th>
								</tr>
							</thead>
						</table>
						<div class="d-flex flex-row justify-content-end mt-3">
							<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgFormE-AuthPersons"><span class="mx-3">Add individual</span></button>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">Validity of the Safe Isolation Lock Out Tag Out Permit</h3>
				</div>
				<div class="px-2 mb-4">
					<div class="mb-3">
						I certify that I have reviewed the proposed work and I am satisfied that the workers understand the hazards
						and that preventive measures are in place with adequate supervision to proceed.
					</div>
					<div class="mb-3">
						<div class="mb-2">
							The isolation work is allowed between
						</div>
						<div class="d-flex flex-column flex-md-row justify-content-evenly mb-3">
							<div class="w-100 me-0 me-md-3 mb-3 mb-md-0">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormE-TimeAllowedFrom")
										.Label(x => x.Content("From"))
										.DateInput())
							</div><div class="w-100 ms-0 ms-md-3">
								@(Html.Kendo().TimePicker()
										.Name("tmpFormE-TimeAllowedTo")
										.Label(x => x.Content("To"))
										.DateInput())
							</div>
						</div>
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">RECONNECTION</h3>
				</div>
				<div class="px-2 mb-4">
					<div>
						I have verified that the equipment under Lockout/Tagout is no longer locked or tagged, has been re-connected and is in safe working condition.
					</div>
				</div>

				<div class="bg-light p-2 mb-3 border-top border-bottom border-secondary">
					<h3 class="mb-0">ISOLATION POINT IDENTIFICATION</h3>
				</div>
				<div class="px-2 mb-4">
					<div>
						<table id="tbl2FormE" class="table table-striped display responsive" style="width: 100%;">
							<thead>
								<tr>
									<th scope="col">Isolation Point Identification</th>
									<th scope="col">Tag Installed?</th>
									<th scope="col">Lock Installed?</th>
									<th scope="col">Blind Installed?</th>
									<th scope="col">Normal Operating Position</th>
									<th scope="col">Date Installed</th>
									<th scope="col">Date Removed</th>
									<th scope="col" style="width: 50px;">&nbsp;</th>
								</tr>
							</thead>
						</table>
						<div class="d-flex flex-row justify-content-end mt-3">
							<button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#dlgFormE-IsolationPointID"><span class="mx-3">Add entry</span></button>
						</div>
					</div>
				</div>

			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary" id="btnSaveFormE" data-bs-dismiss="modal">Save changes</button>
			</div>
		</div>
	</div>
</div>
<div class="modal fade" id="dlgFormE-AuthPersons" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormE-AuthPersonsLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgFormE-AuthPersonsLabel">Add authorized person</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormE" aria-label="Close"></button>
			</div>
			<div class="modal-body">

				<div class="mb-3">
					@(Html.Kendo().DatePicker()
							.Name("ddpFormE-AuthPerson-Date")
							.Label(x => x.Content("Date"))
							.Format("{0:dd/MM/yyyy}")
							.Min(DateTime.Today)
							.Value(DateTime.Now)
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.AdaptiveMode(AdaptiveMode.Auto)
							.ComponentType("modern")
							.DateInput()
							.Events(x => x.Change("onChangeFormETbl1")))
				</div>
				<div class="mb-3">
					@(Html.Kendo().TextBox()
							.Name("tbxFormE-AuthPerson-Name")
							.Label(x => x.Content("Name"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormETbl1")))
				</div>
				<div class="mb-3">
					@(Html.Kendo().TextBox()
							.Name("tbxFormE-AuthPerson-Company")
							.Label(x => x.Content("Company"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormETbl1")))
				</div>

			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormE">Close</button>
				<button type="button" class="btn btn-primary disabled" data-bs-toggle="modal" data-bs-target="#dlgFormE" disabled>Save changes</button>
			</div>
		</div>
	</div>
</div>
<div class="modal fade" id="dlgFormE-IsolationPointID" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgFormE-IsolationPointIDLabel" aria-hidden="true">
	<div class="modal-dialog modal-sm modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning-soft">
				<h2 class="modal-title" id="dlgFormE-IsolationPointIDLabel">Add isolation point</h2>
				<button type="button" class="btn-close" data-bs-toggle="modal" data-bs-target="#dlgFormE" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div class="mb-3">
					@(Html.Kendo().TextBox()
							.Name("tbxFormE-IsolationPoint-ID")
							.Label(x => x.Content("Isolation point ID"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormEIsolationPointID")))
				</div>
				<div class="mb-3">
					<div class="d-flex flex-row align-items-center">
						<label>Tag installed?</label>
						<div class="ms-3">
							@(Html.Kendo().Switch()
									.Name("swtFormE-IsolationPoint-TagInstalled")
									.Size(ComponentSize.Small)
									.Messages(x => x.Checked("YES").Unchecked("NO"))
									.Events(x => x.Change("onChangeFormEIsolationPointID")))
						</div>
					</div>
				</div>
				<div class="mb-3">
					<div class="d-flex flex-row align-items-center">
						<label>Lock installed?</label>
						<div class="ms-3">
							@(Html.Kendo().Switch()
									.Name("swtFormE-IsolationPoint-LockInstalled")
									.Size(ComponentSize.Small)
									.Messages(x => x.Checked("YES").Unchecked("NO"))
									.Events(x => x.Change("onChangeFormEIsolationPointID")))
						</div>
					</div>
				</div>
				<div class="mb-3">
					<div class="d-flex flex-row align-items-center">
						<label>Blind installed?</label>
						<div class="ms-3">
							@(Html.Kendo().Switch()
									.Name("swtFormE-IsolationPoint-BlindInstalled")
									.Size(ComponentSize.Small)
									.Messages(x => x.Checked("YES").Unchecked("NO"))
									.Events(x => x.Change("onChangeFormEIsolationPointID")))
						</div>
					</div>
				</div>
				<div class="mb-3">
					@(Html.Kendo().TextBox()
							.Name("tbxFormE-IsolationPoint-NormalOperatePosition")
							.Label(x => x.Content("Normal operating position"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormEIsolationPointID")))
				</div>
				<div class="mb-3">
					@(Html.Kendo().DatePicker()
							.Name("ddpFormE-IsolationPoint-DateInstalled")
							.Label(x => x.Content("Date installed"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormEIsolationPointID")))
				</div>
				<div>
					@(Html.Kendo().DatePicker()
							.Name("ddpFormE-IsolationPoint-DateRemoved")
							.Label(x => x.Content("Date removed"))
							.Size(ComponentSize.Medium)
							.Rounded(Rounded.Large)
							.FillMode(FillMode.Outline)
							.Events(x => x.Change("onChangeFormEIsolationPointID")))
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#dlgFormE">Close</button>
				<button type="button" class="btn btn-primary disabled" data-bs-toggle="modal" data-bs-target="#dlgFormE" disabled>Save changes</button>
			</div>
		</div>
	</div>
</div>
<!-- ///////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////// -->
