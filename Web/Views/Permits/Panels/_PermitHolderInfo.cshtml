@using Kendo.Mvc.UI

@model EditPermitViewModel

<h2 class="accordion-header">
	<button class="accordion-button fw-semibold text-uppercase collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse3" aria-expanded="false" aria-controls="collapse3">
		Permit Holder Information
	</button>
</h2>
<div id="collapse3" class="accordion-collapse collapse" data-bs-parent="#accordionPermit">
	<div class="accordion-body" style="position: relative;">
		@if (Model.PermitStatus != PermitPro.Core.Enums.PermitStatusEnum.Draft)
		{
			<div class="edit-disable"></div>
		}
		<div class="form-group mb-3">
			@(Html.Kendo().TextBox()
				.Label(x => x.Content("Name"))
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Large)
				.FillMode(FillMode.Outline)
				.Name("tbPermitHolderInfo1"))
		</div>
		<div class="form-group mb-3">
			@(Html.Kendo().TextBox()
				.Label(x => x.Content("Company"))
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Large)
				.FillMode(FillMode.Outline)
				.Name("tbPermitHolderInfo2"))
		</div>
		<div class="form-group mb-3">
			@(Html.Kendo().NumericTextBox()
				.Name("tbPermitHolderInfo3")
				.Label(x => x.Content("Number of staff present"))
				.Format("0")
				.Value(0)
				.Min(0)
				.Max(500))
		</div>
		<div class="form-group mb-5">
			@(Html.Kendo().TextArea()
				.Name("tbPermitHolderInfo4")
				.Label(x => x.Content("Additional staff"))
				.Rounded(Rounded.Large)
				.FillMode(FillMode.Outline)
				.Rows(5))
		</div>
		<div class="text-danger">
			<h6 class="fw-semibold">INSTRUCTIONS FOR HOLDER</h6>
			<div class="text-danger">
				Work must be performed according to <strong>ALL</strong> safety instructions. Mobile phones are strictly prohibited from the terminal area.
			</div>
		</div>
	</div>
</div>