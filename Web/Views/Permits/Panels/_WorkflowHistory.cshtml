@using Kendo.Mvc.UI

@model EditPermitViewModel

<h2 class="accordion-header">
	<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapse9" aria-expanded="false" aria-controls="collapse9">
		<h3 class="mb-0">Workflow History</h3>
	</button>
</h2>
<div id="collapse9" class="accordion-collapse collapse" data-bs-parent="#accordionPermit">
	<div class="accordion-body" style="position: relative;">
		@if (Model.PermitStatus != PermitPro.Core.Enums.PermitStatusEnum.Draft)
		{
			<div class="edit-disable"></div>
		}
		<div class="list-group list-group-flush">
			@if (Model.WorkflowHistories.Count() > 0)
			{
				@foreach (var item in Model.WorkflowHistories)
				{
					<div class="list-group-item d-flex flex-row">
						<div class="flex-grow-1">
							<div>@item.Comments</div>
							<div class="fs-4 text-secondary">
								@item.DateCreated | @item.UserDisplayName
							</div>
						</div>
						<div>
							<span class="badge fs-4 fw-bold bg-@item.StatusBgColor">@item.Status.ToUpper()</span>
						</div>
					</div>
				}
			}
		</div>
	</div>
</div>
