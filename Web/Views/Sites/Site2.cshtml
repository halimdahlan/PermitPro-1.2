@{
	ViewData["Title"] = "Settings / Locations";
	ViewData["SubTitle"] = "IOTM";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

<div class="data-table">
	<div class="d-flex flex-row justify-content-between align-items-center mb-5">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb">
				<li class="breadcrumb-item"><a asp-asp-controller="sites" asp-action="index">IOTM</a></li>
				<li class="breadcrumb-item active" aria-current="page">Carroll, Smitham and Carroll</li>
			</ol>
		</nav>
		<a href="#dlgNewSite" data-bs-toggle="modal" data-bs-target="#dlgNewSite" class="btn btn-primary no-loading"><span class="mx-3"><i class="fa-sharp fa-solid fa-plus me-2"></i> New location</span></a>
	</div>
	<table id="tbl" class="table table-striped display pt-5 mb-3">
		<thead>
			<tr>
				<td>LOCATION NAME</td>
				<td style="width: 400px;">DESCRIPTION</td>
				<td style="width: 200px;">CONTACT NAME</td>
				<td style="width: 200px;">EMAIL</td>
				<td data-class-name="text-center" style="width: 73px;">IS ACTIVE?</td>
				<td style="width: 78px;" data-orderable="false">&nbsp;</td>
			</tr>
		</thead>
	</table>
</div>

<div class="d-flex flex-row align-items-center justify-content-between mt-3">
	<div>
		<a asp-controller="sites" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
	</div>
</div>

<!-- Modal -->
<div class="modal fade" id="dlgNewSite" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgNewSiteLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h1 class="modal-title" id="dlgNewSiteLabel">New location</h1>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body">
				<div class="form-group">
					<label class="form-label">Parent location</label>
					<select class="form-select">
						<option>(select parent location)</option>
						<option selected>IOTM, Main site</option>
					</select>
				</div>
				<div class="form-group">
					<label class="form-label">Location name</label>
					<input type="text" class="form-control" value="Carroll, Smitham and Carroll" />
				</div>
				<div class="form-group">
					<label class="form-label">Description</label>
					<textarea class="form-control">est et tempus semper est</textarea>
				</div>
				<div class="form-group">
					<label class="form-label">Contact name</label>
					<input type="text" class="form-control" value="Geri Scully" />
				</div>
				<div class="form-group">
					<label class="form-label">Contact email</label>
					<input type="email" class="form-control" value="gscully1@mayoclinic.com" />
				</div>
				<div class="form-group mb-3 d-flex flex-row align-items-center">
					<div class="form-check me-5">
						<input class="form-check-input" type="radio" id="ctrl04" name="ctrl04" checked>
						<label class="form-check-label" for="ctrl04">Active</label>
					</div>
					<div class="form-check">
						<input class="form-check-input" type="radio" id="ctrl05" name="ctrl04">
						<label class="form-check-label" for="ctrl05">Inactive</label>
					</div>
				</div>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save changes</button>
			</div>
		</div>
	</div>
</div>

@section CustomCss {
	<!-- DataTables -->
	<link rel="stylesheet" href="~/lib/DataTables/datatables.min.css" />
	<script src="~/lib/DataTables/datatables.min.js"></script>

	<link rel="stylesheet" href="~/css/sites.css" />
}

@section Scripts {
	<script>
		$(document).ready(function () {
			var tbl = $('#tbl').DataTable({
				pageLength: 10,
				responsive: true,
				ajax: '/js/data/sites2.json',
				columns: [
					{
						data: 'siteName'
					},
					{
						data: 'siteDesc',
					},
					{
						data: 'contactName',
					},
					{
						data: 'contactEmail',
					},
					{
						data: 'isActive',
						render: function (data, type, row) {
							if (data) {
								return '<i class="fa-sharp fa-solid fa-circle-check fa-lg text-success"></i>';
							}

							return '<i class="fa-sharp fa-solid fa-circle-xmark fa-lg text-warning"></i>';
						}
					},
					{
						data: 'id',
						render: function (data, type, row) {
							var icons = '<div class="d-flex flex-row action-icons">';
							icons += '<a href="/@companyId/sites/edit" class="no-loading text-secondary"><i class="fa-solid fa-money-check-pen fa-lg"></i></a>';
							icons += '<a href="#" class="no-loading text-danger"><i class="fa-solid fa-trash-xmark fa-lg"></i></a>';
							icons += '<a href="#" class="no-loading text-secondary"><i class="fa-solid fa-gear fa-lg"></i></a>';
							icons += '</div>';

							return icons;
						}
					},
				]
			});
		});
	</script>
}