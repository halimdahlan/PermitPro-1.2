@{
	ViewData["Title"] = "Settings / Locations";
	ViewData["SubTitle"] = "Edit location";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

<div class="form-site">
	<div class="form-group">
		<label class="form-label">Parent site</label>
		<select class="form-select">
			<option>(select parent site)</option>
			<option selected>IOTM, Main site</option>
		</select>
	</div>
	<div class="form-group">
		<label class="form-label">Site name</label>
		<input type="text" class="form-control" value="Carroll, Smitham and Carroll" />
	</div>
	<div class="form-group">
		<label class="form-label">Description</label>
		<textarea class="form-control">est et tempus semper est</textarea>
	</div>
	<div class="form-group">
		<label class="form-label">Contact name</label>
		<input type="text" class="form-control" value="Geri Scully" />
	</div>
	<div class="form-group">
		<label class="form-label">Contact email</label>
		<input type="email" class="form-control" value="gscully1@mayoclinic.com" />
	</div>
	<div class="form-group mb-3 d-flex flex-row align-items-center">
		<div class="form-check me-5">
			<input class="form-check-input" type="radio" id="ctrl04" name="ctrl04" checked>
			<label class="form-check-label" for="ctrl04">Active</label>
		</div>
		<div class="form-check">
			<input class="form-check-input" type="radio" id="ctrl05" name="ctrl04">
			<label class="form-check-label" for="ctrl05">Inactive</label>
		</div>
	</div>

	<div class="d-flex flex-row align-items-center justify-content-between mt-5">
		<div>
			<a asp-controller="sites" asp-action="index"><i class="fa-sharp fa-solid fa-chevrons-left me-2"></i> Back</a>
		</div>
		<button type="button" class="btn btn-primary"><span class="mx-3">Submit</span></button>
	</div>
</div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/sites.css" />
}