@using PermitPro.App.ViewModels
@model SitesNewViewModel

@{
  var isEdit = ViewBag.SiteId != null;


	ViewData["Title"] = "Settings / Sites";
	ViewData["SubTitle"] = isEdit ? "Edit site" : "New site";

	var companyId = ViewBag.CompanyId;
}

<div class="row g-4">
  <div class="col-12 col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <form method="post">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label small fw-semibold">Site Name <span class="text-danger">*</span></label>
            <input asp-for="Name" class="form-control"/>
            <span asp-validation-for="Name" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label class="form-label small fw-semibold">Description</label>
            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label small fw-semibold">Contact Name <span class="text-danger">*</span></label>
              <input asp-for="ContactName" class="form-control" placeholder="Full name"/>
              <span asp-validation-for="ContactName" class="text-danger small"></span>
            </div>
            <div class="col-6">
              <label class="form-label small fw-semibold">Contact Email <span class="text-danger">*</span></label>
              <input asp-for="ContactEmail" class="form-control" placeholder="Email address"/>
              <span asp-validation-for="ContactEmail" class="text-danger small"></span>
            </div>
          </div>
          <div class="row g-3 mb-3">
            <div class="col-6">
              <label class="form-label small fw-semibold">Latitude</label>
              <input asp-for="Latitude" id="latInput" class="form-control" type="number" step="0.000001" placeholder="e.g. 3.1390"/>
            </div>
            <div class="col-6">
              <label class="form-label small fw-semibold">Longitude</label>
              <input asp-for="Longitude" id="lngInput" class="form-control" type="number" step="0.000001" placeholder="e.g. 101.6869"/>
            </div>
          </div>
          <div class="mb-4">
            <div class="site-map" id="pickMap"></div>
            <p class="text-muted x-small mt-1">Click the map to set the location pin.</p>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
              <label class="form-check-label ms-2" for="IsActive">Is Active</label>
            </div>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input asp-for="ShowInMap" class="form-check-input" type="checkbox"/>
              <label class="form-check-label ms-2" for="ShowInMap">Show in Map</label>
            </div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary">Save Changes</button>
            <a href="/@companyId/sites/@Model.ParentId" class="btn btn-sm btn-outline-secondary">Cancel</a>
          </div>
          <input type="hidden" asp-for="CompanyId"/>
          <input type="hidden" asp-for="ParentId"/>
        </form>
      </div>
    </div>
  </div>
</div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/sites.css" />
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
	<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
	<script>
		const map = L.map('pickMap').setView([3.1390, 101.6869], 7);

		L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
			attribution: '© OpenStreetMap'
		}).addTo(map);

		let marker = null;
		const latInput = document.getElementById('latInput');
		const lngInput = document.getElementById('lngInput');

		const initLat = parseFloat(latInput.value);
		const initLng = parseFloat(lngInput.value);

		if (!isNaN(initLat) && !isNaN(initLng)) {
			marker = L.marker([initLat, initLng]).addTo(map);
			map.setView([initLat, initLng], 14);
		}

		map.on('click', e => {
			const { lat, lng } = e.latlng;
			latInput.value = lat.toFixed(6);
			lngInput.value = lng.toFixed(6);
			if (marker) marker.setLatLng([lat, lng]);
			else marker = L.marker([lat, lng]).addTo(map);
		});

	</script>
}