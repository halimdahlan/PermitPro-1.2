@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Contractors";
	ViewData["SubTitle"] = "Summary";
}

@model ContractorsViewModel

<div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
	<div class="d-flex flex-row align-items-center">
		<div class="me-3">View by</div>
		<button type="button" class="btn btn-sm btn-dark btn-filter rounded-pill me-2" data-search="">
			ALL
		</button>
		<button type="button" class="btn btn-sm btn-secondary btn-filter rounded-pill me-2" data-search="true">
			ACTIVE
		</button>
		<button type="button" class="btn btn-sm btn-secondary btn-filter rounded-pill me-2" data-search="false">
			INACTIVE
		</button>
	</div>
	<div>
		<a href="#dlgUser" class="btn btn-primary no-loading" data-bs-toggle="modal" data-bs-target="#dlgUser"><span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New contractor</span></a>
	</div>
</div>

<div class="mt-5">
	@(
		Html.Kendo().Grid<ContractorListViewModel>()
		.Name("grid")
		.ToolBar(tb => { tb.Search(); })
		.NoRecords(true)
		.Pageable()
		.Sortable()
		.Columns(c =>
		{
			c.Bound(p => p.Name).Width(250);
			c.Bound(p => p.Email);
			c.Bound(p => p.IsSecured).Encoded(false).HeaderHtmlAttributes(new { @class = "text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(140);

			c.Bound(p => p.IsActive)
			.ClientTemplate(
				"# if (IsActive) { #" +
				"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-success\"></i>" +
				"# } else { #" +
				"    <i class=\"fa-sharp fa-solid fa-circle-check fa-lg text-warning\"></i>" +
				"# } #"
				)
				.HeaderHtmlAttributes(new { @class = "text-center" }).HtmlAttributes(new { @class = "text-center" }).Width(130);

			c.Bound(p => p.CreatedWhen).Format("{0:dd MMM, yyyy}").Width(150);
			c.Bound(p => p.ActionIcons).Sortable(false).Exportable(false).Encoded(false).HeaderHtmlAttributes(new { @class = "text-center" }).Width(100);
		})
		.DataSource(ds => ds
		.Custom()
		.Transport(t =>
		{
			t.Read(r => r.Url($"/{Model.CompanyId}/contractors/grid").Type(HttpVerbs.Get));
		})
		.Schema(s => s
		.Model(m =>
		{
			m.Id(i => i.Id);
		})
		)
		.PageSize(20)
		)
	)
	@Html.AntiForgeryToken()
</div>

