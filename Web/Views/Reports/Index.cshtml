@using Kendo.Mvc.UI
@using PermitPro.App.Models.Reports

@{
	ViewData["Title"] = "Reports";
	ViewData["SubTitle"] = "Summary";

	var companyId = ViewContext.RouteData.Values["company"] as string;
}

@model ReportsViewModel

<div>
	<div class="d-flex flex-row align-items-center mb-2">
		<div class="me-3 label-width">
			@(Html.Kendo().RadioButton()
				.Name("option1")
				.Checked(true)
				.HtmlAttributes(new { @name = "filterOption" })
				.Label("Month/Year")
				.Events(events => events
					.Change("onOptionChange")
				)
			)
		</div>
		<div>
			@(Html.Kendo().DropDownList()
				.Name("ddlMonth")
				.AutoWidth(true)
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Medium)
				.FillMode(FillMode.Solid)
				.DataTextField("text")
				.DataValueField("value")
				.DataSource(ds => ds
					.Read(read => read
						.Action("GetDropdownMonths", "Reports")
					)
				)
			)
		</div>
		<div class="ms-2">
			@(Html.Kendo().DropDownList()
				.Name("ddlYear")
				.AutoWidth(true)
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Medium)
				.FillMode(FillMode.Solid)
				.DataTextField("text")
				.DataValueField("value")
				.DataSource(ds => ds
					.Read(read => read
						.Action("GetDropdownYears", "Reports")
					)
				)
			)
		</div>
	</div>

	<div class="d-flex flex-row align-items-center mb-2">
		<div class="me-3 label-width">
			@(Html.Kendo().RadioButton()
				.Name("option2")
				.HtmlAttributes(new { @name = "filterOption" })
				.Label("Date range")
				.Events(events => events
					.Change("onOptionChange")
				)
			)
		</div>
		<div>
			@(Html.Kendo().DateRangePicker()
				.Name("dateRange")
				.Labels(false)
				.Format("{0:dd/MM/yyyy}")
				.DisableDates(DayOfWeek.Saturday, DayOfWeek.Sunday)
			)
		</div>
		<div class="ms-3">
			<a href="javascript:;" class="clear-range no-loading">Clear</a>
		</div>
	</div>

	<div class="d-flex flex-row align-items-center mb-2">
		<div class="me-3 label-width">Location</div>
		<div>
			@(Html.Kendo().DropDownTree()
				.Name("ddtLocation")
				.Filter(FilterType.Contains)
				.DataValueField("id")
				.DataTextField("name")
				.Placeholder("(select)")
				.FillMode(FillMode.Solid)
				.Rounded(Rounded.Medium)
				.CheckAll(false)
				.AutoClose(true)
				.DataSource(ds => ds
					.Read(read => read
						.Url($"/{companyId}/sites/hierarchical").Type(HttpVerbs.Get)
					)
				)
				.HtmlAttributes(new { @style = "width:380px" })
			)
		</div>
	</div>

	<div class="d-flex flex-row align-items-center mb-2">
		<div class="me-3 label-width">Permit holder</div>
		<div>
			@(Html.Kendo().DropDownList()
				.Name("ddlPermitHolder")
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Medium)
				.FillMode(FillMode.Solid)
				.DataTextField("text")
				.DataValueField("value")
				.DataSource(ds => ds
					.Read(read => read
						.Action("GetDropdownPermitHolders", "Reports")
					)
				)
				.HtmlAttributes(new { @style = "width:380px" })
			)
		</div>
	</div>

	<div class="d-flex flex-row align-items-center mb-2">
		<div class="me-3 label-width">Certificate type</div>
		<div>
			@(Html.Kendo().DropDownList()
				.Name("ddlCertificate")
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Medium)
				.FillMode(FillMode.Solid)
				.DataTextField("text")
				.DataValueField("value")
				.DataSource(ds => ds
					.Read(read => read
						.Action("GetDropdownCertificates", "Reports")
					)
				)
				.HtmlAttributes(new { @style = "width:380px" })
			)
		</div>
	</div>

	<div class="d-flex flex-row align-items-center mb-4">
		<div class="me-3 label-width">Permit status</div>
		<div>
			@(Html.Kendo().DropDownList()
				.Name("ddlPermitStatus")
				.Size(ComponentSize.Medium)
				.Rounded(Rounded.Medium)
				.FillMode(FillMode.Solid)
				.DataTextField("text")
				.DataValueField("value")
				.DataSource(ds => ds
					.Read(read => read
						.Action("GetDropdownPermitStatus", "Reports").Type(HttpVerbs.Get)
					)
				)
				.HtmlAttributes(new { @style = "width:380px" })
			)
		</div>
	</div>
</div>

<div class="d-flex flex-row align-items-center">
	<button class="btn btn-sm btn-primary view-report" type="button"><span class="mx-3">View report</span></button>
	<div class="ms-3">
		<a href="javascript:;" class="clear-filter no-loading">Clear filter</a>
	</div>
</div>

<hr />

<!-- Inline loading state for the stats area -->
<div id="reportLoading" class="text-center py-5" style="display:none">
	<i class="fa-solid fa-loader fa-spin text-secondary" style="font-size:2rem"></i>
	<p class="text-secondary mt-2 mb-0 small">Loading statistics…</p>
</div>

<!-- KPI Summary Cards -->
<div id="kpiSection" class="mb-4" style="display:none">
	<div class="row g-3">
		<div class="col">
			<div class="card border-0 shadow-sm text-center kpi-card">
				<div class="card-body py-3">
					<div class="kpi-value text-primary" id="kpiTotal">—</div>
					<div class="kpi-label">Total Permits</div>
				</div>
			</div>
		</div>
		<div class="col">
			<div class="card border-0 shadow-sm text-center kpi-card">
				<div class="card-body py-3">
					<div class="kpi-value" style="color:#f6c343" id="kpiPending">—</div>
					<div class="kpi-label">Pending</div>
				</div>
			</div>
		</div>
		<div class="col">
			<div class="card border-0 shadow-sm text-center kpi-card">
				<div class="card-body py-3">
					<div class="kpi-value text-success" id="kpiApproved">—</div>
					<div class="kpi-label">Approved</div>
				</div>
			</div>
		</div>
		<div class="col">
			<div class="card border-0 shadow-sm text-center kpi-card">
				<div class="card-body py-3">
					<div class="kpi-value text-secondary" id="kpiClosed">—</div>
					<div class="kpi-label">Closed</div>
				</div>
			</div>
		</div>
		<div class="col">
			<div class="card border-0 shadow-sm text-center kpi-card" id="kpiOverdueCard">
				<div class="card-body py-3">
					<div class="kpi-value text-danger" id="kpiOverdue">—</div>
					<div class="kpi-label">Overdue</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Charts Row -->
<div id="chartsSection" class="mb-4" style="display:none">
	<div class="row g-3">
		<div class="col-md-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="chart-section-title">Status Distribution</div>
					<div class="chart-wrap">
						<canvas id="statusChart"></canvas>
					</div>
				</div>
			</div>
		</div>
		<div class="col-md-6">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="chart-section-title">Monthly Trend <span class="fw-normal text-secondary">(last 12 months)</span></div>
					<div class="chart-wrap">
						<canvas id="monthlyChart"></canvas>
					</div>
				</div>
			</div>
		</div>
		<div class="col-md-3">
			<div class="card border-0 shadow-sm h-100">
				<div class="card-body">
					<div class="chart-section-title">Top Locations</div>
					<div class="chart-wrap">
						<canvas id="locationChart"></canvas>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Report Tabs -->
<ul class="nav nav-tabs mt-3 mb-0" id="reportTabs" role="tablist">
	<li class="nav-item" role="presentation">
		<button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-permits" type="button" role="tab">All Permits</button>
	</li>
	<li class="nav-item" role="presentation">
		<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-overdue" type="button" role="tab">
			Overdue <span class="badge bg-danger ms-1 d-none" id="badgeOverdue"></span>
		</button>
	</li>
	<li class="nav-item" role="presentation">
		<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-by-holder" type="button" role="tab">By Holder</button>
	</li>
	<li class="nav-item" role="presentation">
		<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-by-location" type="button" role="tab">By Location</button>
	</li>
</ul>
<div class="tab-content border border-top-0 rounded-bottom" id="reportTabContent">

	<div class="tab-pane fade show active p-3" id="tab-permits" role="tabpanel">
		<div class="grid-result">
	@(Html.Kendo().Grid<ReportGridModel>()
		.Name("gridResult")
		.ToolBar(toolbar =>
		{
			toolbar.Excel();
			toolbar.Search();
		})
		.Groupable(g =>
		{
			g.Enabled(true);
			g.ShowFooter(true);
			g.Messages(msg => msg.Empty("No data"));
		})
		.NoRecords(f => f
			.Template("<div class=\"my-3 text-center w-100 text-danger\">No data available at the moment</div>"))
		.Pageable()
		.Sortable()
		.Excel(e =>
		{
			e.AllPages(true);
			e.Filterable(true);
		})
		.Columns(c =>
		{
			c.Bound(p => p.PermitHolderName)
				.HideOnGroup(true)
				.ClientGroupFooterTemplate("Num. of permits: #=count#")
				.ClientFooterTemplate("Total permits: #=count#")
				.Width(150);

			c.Bound(p => p.Location)
				.Width(150);

			c.Bound(p => p.PermitNo)
				.ClientTemplate($"<a href=\"/{Model.CompanyId}/permits/edit/#= Id #\" class=\"text-info\">#= PermitNo #</a>")
				.Width(150);
			
			c.Bound(p => p.PermitStatus)
				.Width(130);

			c.Bound(p => p.StartDate)
				.Format("{0:dd MMM, yyyy}")
				.Width(120);

			c.Bound(p => p.EndDate)
				.Format("{0:dd MMM, yyyy}")
				.Width(120);

			c.Bound(p => p.DurationDays)
				.ClientTemplate("# if (DurationDays !== null && DurationDays !== undefined) { # #= DurationDays # d # } else { # — # } #")
				.Width(100);

			c.Bound(p => p.Certificates)
				.Groupable(false)
				.Width(150);
			
			c.Bound(p => p.CreatedWhen)
				.Hidden(true)
				.ClientGroupHeaderTemplate("DATE: #=kendo.toString(value, 'dd MMM, yyyy')#")
				.Format("{0:dd MMM, yyyy}")
				.Width(130);
		})
		.DataSource(ds => ds
			.Custom()
			.Group(grp =>
			{
				grp.AddDescending(f => f.CreatedWhen);
			})
			.Aggregates(agg =>
			{
				agg.Add(g => g.PermitHolderName).Count();
			})
			.Schema(s => s
				.Model(m =>
				{
					m.Id(i => i.Id);
				})
			)
			.Transport(t =>
			{
				t.Read(r => r
					.Action("GetReportGrid", "Reports", Model.GridParamaters)
					.Type(HttpVerbs.Get)
				);
			})
			.PageSize(25)
		)
	)
		</div>
	</div>

	<!-- Overdue permits -->
	<div class="tab-pane fade p-3" id="tab-overdue" role="tabpanel">
		<div id="overdueContainer">
			<p class="text-secondary text-center py-4 mb-0 small">Apply a filter and click <strong>View report</strong> to see overdue permits.</p>
		</div>
	</div>

	<!-- By permit holder -->
	<div class="tab-pane fade p-3" id="tab-by-holder" role="tabpanel">
		<div id="holderContainer">
			<p class="text-secondary text-center py-4 mb-0 small">Apply a filter and click <strong>View report</strong> to see a breakdown by permit holder.</p>
		</div>
	</div>

	<!-- By location -->
	<div class="tab-pane fade p-3" id="tab-by-location" role="tabpanel">
		<div id="locationContainer">
			<p class="text-secondary text-center py-4 mb-0 small">Apply a filter and click <strong>View report</strong> to see a breakdown by location.</p>
		</div>
	</div>

</div>
@Html.AntiForgeryToken()

@section CustomCss {
	<link rel="stylesheet" href="~/css/reports.css" />
}

@section Scripts {
	<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
	<script>
		var companyId = '@companyId';
		var useDateRange = false;
		var dateRange;
		var gridResult;
		var statusChart = null, monthlyChart = null, locationChart = null;

		const chartColors = {
			approved: '#00d97e',
			pending:  '#f6c343',
			other:    '#b2c1d6',
			blue:     '#2c7be5',
			white:    '#ffffff',
			statusPalette: ['#b2c1d6', '#f6c343', '#00d97e', '#e63757', '#fd7e14', '#6f42c1', '#6e84a3'],
		};

		const chartFont = { family: "'Poppins', sans-serif", size: 11 };

		const renderOverdueTable = (permits) => {
			if (!permits || permits.length === 0)
				return '<p class="text-secondary text-center py-4 mb-0 small">No overdue permits found for the selected filters.</p>';
			const rows = permits.map(p => `
				<tr>
					<td><a href="/${companyId}/permits/edit/${p.id}" class="text-info fw-semibold">${p.permitNo}</a></td>
					<td>${p.holderName}</td>
					<td>${p.location}</td>
					<td class="text-danger">${p.endDate}</td>
					<td class="text-center">${p.daysOverdue} day${p.daysOverdue !== 1 ? 's' : ''}</td>
					<td><span class="badge bg-warning text-dark">${p.status}</span></td>
				</tr>`).join('');
			return `<div class="table-responsive"><table class="table table-sm table-hover align-middle report-table">
				<thead class="table-light"><tr>
					<th>Permit No.</th><th>Permit Holder</th><th>Location</th>
					<th>End Date</th><th class="text-center">Days Overdue</th><th>Status</th>
				</tr></thead><tbody>${rows}</tbody>
			</table></div>`;
		};

		const renderHolderTable = (holders) => {
			if (!holders || holders.length === 0)
				return '<p class="text-secondary text-center py-4 mb-0 small">No data for the selected filters.</p>';
			const rows = holders.map(h => {
				const rate = h.total > 0 ? Math.round(h.approved / h.total * 100) : 0;
				return `<tr>
					<td>${h.name}</td>
					<td class="text-center">${h.total}</td>
					<td class="text-center text-success">${h.approved}</td>
					<td class="text-center" style="color:#f6c343">${h.pending}</td>
					<td class="text-center text-secondary">${h.other}</td>
					<td class="text-center">
						<div class="d-flex align-items-center gap-2">
							<div class="progress flex-grow-1" style="height:6px">
								<div class="progress-bar bg-success" style="width:${rate}%"></div>
							</div>
							<span class="text-secondary" style="font-size:0.75rem;min-width:30px">${rate}%</span>
						</div>
					</td>
				</tr>`;
			}).join('');
			return `<div class="table-responsive"><table class="table table-sm table-hover align-middle report-table">
				<thead class="table-light"><tr>
					<th>Permit Holder</th>
					<th class="text-center">Total</th>
					<th class="text-center text-success">Approved</th>
					<th class="text-center" style="color:#f6c343">Pending</th>
					<th class="text-center text-secondary">Other</th>
					<th>Approval Rate</th>
				</tr></thead><tbody>${rows}</tbody>
			</table></div>`;
		};

		const renderLocationTable = (locations) => {
			if (!locations || locations.length === 0)
				return '<p class="text-secondary text-center py-4 mb-0 small">No data for the selected filters.</p>';
			const rows = locations.map(l => {
				const rate = l.count > 0 ? Math.round(l.approved / l.count * 100) : 0;
				return `<tr>
					<td>${l.label}</td>
					<td class="text-center">${l.count}</td>
					<td class="text-center text-success">${l.approved}</td>
					<td class="text-center" style="color:#f6c343">${l.pending}</td>
					<td class="text-center text-secondary">${l.other}</td>
					<td>
						<div class="d-flex align-items-center gap-2">
							<div class="progress flex-grow-1" style="height:6px">
								<div class="progress-bar bg-success" style="width:${rate}%"></div>
							</div>
							<span class="text-secondary" style="font-size:0.75rem;min-width:30px">${rate}%</span>
						</div>
					</td>
				</tr>`;
			}).join('');
			return `<div class="table-responsive"><table class="table table-sm table-hover align-middle report-table">
				<thead class="table-light"><tr>
					<th>Location</th>
					<th class="text-center">Total</th>
					<th class="text-center text-success">Approved</th>
					<th class="text-center" style="color:#f6c343">Pending</th>
					<th class="text-center text-secondary">Other</th>
					<th>Approval Rate</th>
				</tr></thead><tbody>${rows}</tbody>
			</table></div>`;
		};

		const loadChartData = (params) => {
			$.ajax({
				url: `/${companyId}/reports/getchartdata`,
				data: params,
				method: 'GET',
				success: (data) => {
					// KPI cards
					$('#kpiTotal').text(data.summary.total);
					$('#kpiPending').text(data.summary.pending);
					$('#kpiApproved').text(data.summary.approved);
					$('#kpiClosed').text(data.summary.closed);
					$('#kpiOverdue').text(data.summary.overdue);
					$('#kpiOverdueCard').toggleClass('kpi-card-danger', data.summary.overdue > 0);

					$('#kpiSection, #chartsSection').show();

					// Tab tables
					$('#overdueContainer').html(renderOverdueTable(data.overduePermits));
					$('#holderContainer').html(renderHolderTable(data.byHolder));
					$('#locationContainer').html(renderLocationTable(data.byLocation));

					const overdueCount = data.overduePermits ? data.overduePermits.length : 0;
					$('#badgeOverdue').text(overdueCount).toggleClass('d-none', overdueCount === 0);

					// Destroy stale chart instances before re-drawing
					if (statusChart)   { statusChart.destroy();   statusChart = null; }
					if (monthlyChart)  { monthlyChart.destroy();  monthlyChart = null; }
					if (locationChart) { locationChart.destroy(); locationChart = null; }

					// ── Doughnut: status distribution ──────────────────
					statusChart = new Chart(document.getElementById('statusChart'), {
						type: 'doughnut',
						data: {
							labels: ['Draft', 'Pending', 'Approved', 'Rejected', 'Suspended', 'KIV', 'Closed'],
							datasets: [{
								data: [
									data.summary.draft, data.summary.pending, data.summary.approved,
									data.summary.rejected, data.summary.suspended, data.summary.kiv, data.summary.closed
								],
								backgroundColor: chartColors.statusPalette,
								borderWidth: 2,
								borderColor: chartColors.white,
								hoverBorderColor: chartColors.white,
							}]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							cutout: '65%',
							plugins: {
								legend: {
									position: 'bottom',
									labels: { font: chartFont, padding: 8, boxWidth: 12 }
								}
							}
						}
					});

					// ── Stacked bar: monthly trend ──────────────────────
					monthlyChart = new Chart(document.getElementById('monthlyChart'), {
						type: 'bar',
						data: {
							labels: data.byMonth.map(m => m.label),
							datasets: [
								{ label: 'Approved / Closed', data: data.byMonth.map(m => m.approved), backgroundColor: chartColors.approved, borderRadius: 3 },
								{ label: 'Pending',           data: data.byMonth.map(m => m.pending),  backgroundColor: chartColors.pending,  borderRadius: 3 },
								{ label: 'Other',             data: data.byMonth.map(m => m.other),    backgroundColor: chartColors.other,    borderRadius: 3 },
							]
						},
						options: {
							responsive: true,
							maintainAspectRatio: false,
							plugins: {
								legend: { position: 'bottom', labels: { font: chartFont, boxWidth: 12, padding: 8 } }
							},
							scales: {
								x: { stacked: true, grid: { display: false }, ticks: { font: chartFont } },
								y: { stacked: true, ticks: { font: chartFont, precision: 0 } }
							}
						}
					});

					// ── Horizontal bar: top locations ───────────────────
					locationChart = new Chart(document.getElementById('locationChart'), {
						type: 'bar',
						data: {
							labels: data.byLocation.map(l => l.label),
							datasets: [{
								label: 'Permits',
								data: data.byLocation.map(l => l.count),
								backgroundColor: chartColors.blue,
								borderRadius: 3,
							}]
						},
						options: {
							indexAxis: 'y',
							responsive: true,
							maintainAspectRatio: false,
							plugins: { legend: { display: false } },
							scales: {
								x: { grid: { display: false }, ticks: { font: chartFont, precision: 0 } },
								y: { grid: { display: false }, ticks: { font: chartFont } }
							}
						}
					});
				},
				complete: () => { $('#reportLoading').hide(); }
			});
		};


		$(document).ready(() => {

			gridResult = $("#gridResult").data("kendoGrid");
			dateRange = $('#dateRange').data('kendoDateRangePicker');
			dateRange.enable(false);

			gridResult.dataSource.transport.options.read.beforeSend = (req) => {
				req.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
			};

			$('.view-report').click(() => {
				$('#kpiSection, #chartsSection').hide();
				$('#reportLoading').show();

				var ddtLocation     = $('#ddtLocation').data('kendoDropDownTree');
				var ddlPermitHolder = $('#ddlPermitHolder').data('kendoDropDownList');
				var ddlCertificate  = $('#ddlCertificate').data('kendoDropDownList');
				var ddlPermitStatus = $('#ddlPermitStatus').data('kendoDropDownList');
				var ddlMonth = $('#ddlMonth').data('kendoDropDownList');
				var ddlYear  = $('#ddlYear').data('kendoDropDownList');

				// ── Grid filter (Kendo client-side) ──────────────────
				var gridFilter = { logic: 'and', filters: [] };

				if (useDateRange) {
					var range = dateRange.range();
					gridFilter.filters.push({ field: 'CreatedWhen', operator: 'gte', value: range.start });
					gridFilter.filters.push({ field: 'CreatedWhen', operator: 'lte', value: range.end });
				} else {
					if (ddlMonth.value() != '') gridFilter.filters.push({ field: 'CreatedMonth', operator: 'eq', value: ddlMonth.value() });
					if (ddlYear.value()  != '') gridFilter.filters.push({ field: 'CreatedYear',  operator: 'eq', value: ddlYear.value() });
				}
				if (ddtLocation.value()      != '') gridFilter.filters.push({ field: 'LocationId',      operator: 'eq',       value: ddtLocation.value() });
				if (ddlPermitHolder.value()  != '') gridFilter.filters.push({ field: 'PermitHolderId',  operator: 'eq',       value: ddlPermitHolder.value() });
				if (ddlCertificate.value()   != '') gridFilter.filters.push({ field: 'Certificates',    operator: 'contains', value: ddlCertificate.value() });
				if (ddlPermitStatus.value()  != '') gridFilter.filters.push({ field: 'PermitStatusEnum', operator: 'eq',      value: ddlPermitStatus.value() });

				$('.grid-result').css('display', 'block');
				gridResult.dataSource.filter(gridFilter);

				// ── Chart data (server-side aggregation) ─────────────
				var chartParams = { useDateRange: useDateRange };
				if (useDateRange) {
					var r = dateRange.range();
					if (r.start) chartParams.startDate = r.start.toISOString();
					if (r.end)   chartParams.endDate   = r.end.toISOString();
				} else {
					if (ddlMonth.value() != '') chartParams.month = ddlMonth.value();
					if (ddlYear.value()  != '') chartParams.year  = ddlYear.value();
				}
				if (ddtLocation.value()     != '') chartParams.locationId     = ddtLocation.value();
				if (ddlPermitHolder.value() != '') chartParams.holderId       = ddlPermitHolder.value();
				if (ddlCertificate.value()  != '') chartParams.certificateType = ddlCertificate.value();
				if (ddlPermitStatus.value() != '') chartParams.permitStatus    = ddlPermitStatus.value();

				loadChartData(chartParams);
			});


			$('.clear-range').click(() => {
				dateRange.range({});
			});


			$('.clear-filter').click(() => {
				var ddtLocation     = $('#ddtLocation').data('kendoDropDownTree');
				var ddlPermitHolder = $('#ddlPermitHolder').data('kendoDropDownList');
				var ddlCertificate  = $('#ddlCertificate').data('kendoDropDownList');
				var ddlPermitStatus = $('#ddlPermitStatus').data('kendoDropDownList');
				var ddlMonth = $('#ddlMonth').data('kendoDropDownList');
				var ddlYear  = $('#ddlYear').data('kendoDropDownList');

				dateRange.range({});
				ddtLocation.value('');
				ddlPermitHolder.value('');
				ddlCertificate.value('');
				ddlPermitStatus.value('');
				ddlMonth.value('');
				ddlYear.value('');

				gridResult.dataSource.filter({});
				$('#badgeOverdue').addClass('d-none');
				$('#kpiSection, #chartsSection').hide();
			});

		});


		const onOptionChange = (e) => {
			var dateRange = $('#dateRange').data('kendoDateRangePicker');
			var ddlMonth  = $('#ddlMonth').data('kendoDropDownList');
			var ddlYear   = $('#ddlYear').data('kendoDropDownList');

			ddlMonth.enable(e.sender.element[0].id == 'option1');
			ddlYear.enable(e.sender.element[0].id  == 'option1');
			dateRange.enable(e.sender.element[0].id == 'option2');

			useDateRange = e.sender.element[0].id == 'option2';
		}
	</script>
}