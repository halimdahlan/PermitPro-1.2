@using PermitPro.Core.Enums

@{
	ViewData["Title"] = "Dashboard";
	ViewData["SubTitle"] = "General";
}

@model DashboardViewModel

@* ── Stat cards ─────────────────────────────────────────── *@
<div class="row g-3 mb-4">

	<!-- Total Active -->
	<div class="col-12 col-sm-6 col-xl">
		<div class="stat-card stat-blue">
			<div class="icon-wrap"><i class="fa-solid fa-circle-check"></i></div>
			<div class="stat-value">@Model.TotalActive</div>
			<div class="stat-label">Total Active Permits</div>
			<div class="stat-change" style="color:#6b7c93;">
				<i class="fa-solid fa-address-card me-1"></i>Active permits on site
			</div>
			<i class="fa-solid fa-circle-check stat-bg-icon"></i>
		</div>
	</div>

	<!-- Total Pending -->
	<div class="col-12 col-sm-6 col-xl">
		<div class="stat-card stat-yellow">
			<div class="icon-wrap"><i class="fa-solid fa-clock"></i></div>
			<div class="stat-value">@Model.TotalPending</div>
			<div class="stat-label">Total Pending Permits</div>
			<div class="stat-change" style="color:#6b7c93;">
				<i class="fa-solid fa-hourglass-half me-1"></i>Awaiting approval
			</div>
			<i class="fa-solid fa-clock stat-bg-icon"></i>
		</div>
	</div>

	<!-- Total Approved -->
	<div class="col-12 col-sm-6 col-xl">
		<div class="stat-card stat-green">
			<div class="icon-wrap"><i class="fa-solid fa-thumbs-up"></i></div>
			<div class="stat-value">@Model.TotalApproved</div>
			<div class="stat-label">Total Approved Permits</div>
			<div class="stat-change" style="color:#6b7c93;">
				<i class="fa-solid fa-check me-1"></i>Approved and in progress
			</div>
			<i class="fa-solid fa-thumbs-up stat-bg-icon"></i>
		</div>
	</div>

	<!-- Total Closed -->
	<div class="col-12 col-sm-6 col-xl">
		<div class="stat-card stat-gray">
			<div class="icon-wrap"><i class="fa-solid fa-lock"></i></div>
			<div class="stat-value">@Model.TotalClosed</div>
			<div class="stat-label">Total Closed Permits</div>
			<div class="stat-change" style="color:#6b7c93;">
				<i class="fa-solid fa-minus me-1"></i>Completed and closed
			</div>
			<i class="fa-solid fa-lock stat-bg-icon"></i>
		</div>
	</div>

	<!-- Total Rejected -->
	<div class="col-12 col-sm-6 col-xl">
		<div class="stat-card stat-red">
			<div class="icon-wrap"><i class="fa-solid fa-circle-xmark"></i></div>
			<div class="stat-value">@Model.TotalRejected</div>
			<div class="stat-label">Total Rejected Permits</div>
			<div class="stat-change" style="color:#6b7c93;">
				<i class="fa-solid fa-triangle-exclamation me-1"></i>Requires attention
			</div>
			<i class="fa-solid fa-circle-xmark stat-bg-icon"></i>
		</div>
	</div>

</div>

@* ── Date filter ─────────────────────────────────────────── *@
<div class="card mb-4">
	<div class="card-body py-3">
		<div class="d-flex align-items-center gap-3 flex-wrap">
			<span style="font-size:.8rem;color:#4a5568;white-space:nowrap;font-weight:500;">Filter by date range</span>
			<input type="date" class="form-control" style="max-width:160px;font-size:.8rem;">
			<span style="color:#a0aec0;font-size:.8rem;">to</span>
			<input type="date" class="form-control" style="max-width:160px;font-size:.8rem;">
			<button class="btn btn-primary btn-sm">Apply</button>
			<button class="btn btn-light btn-sm">Clear</button>
		</div>
	</div>
</div>

@* ── Charts row ──────────────────────────────────────────── *@
<div class="row g-3 mb-4">

	<!-- Status Donut Chart -->
	<div class="col-12 col-lg-5">
		<div class="card h-100">
			<div class="card-header">
				<div>
					<div class="card-title">Total Permits By Status</div>
					<div class="card-subtitle">Distribution across all statuses</div>
				</div>
			</div>
			<div class="card-body d-flex flex-column align-items-center justify-content-center" style="min-height:280px;">
				@if (Model.StatusBreakdown.Any())
				{
					<!-- Donut chart visualization -->
					<svg width="200" height="200" viewBox="0 0 42 42" style="transform:rotate(-90deg);">
						<circle cx="21" cy="21" r="15.915" fill="none" stroke="#f0f4f8" stroke-width="6"/>
						@{
							decimal offset = 0;
							foreach (var item in Model.StatusBreakdown.OrderByDescending(x => x.Percentage))
							{
								decimal dasharray = (item.Percentage / 100m) * 100m;
								<circle cx="21" cy="21" r="15.915" fill="none" stroke="@item.Color" stroke-width="6" stroke-dasharray="@dasharray.ToString("F0") @(100 - dasharray).ToString("F0")" stroke-dashoffset="-@offset.ToString("F0")" />
								offset += dasharray;
							}
						}
					</svg>
					<!-- Legend -->
					<div class="row w-100 mt-3 g-2">
						@foreach (var item in Model.StatusBreakdown.OrderByDescending(x => x.Percentage))
						{
							<div class="col-6">
								<div class="d-flex align-items-center gap-2 p-2 rounded" style="background:#f8fafc;">
									<span style="width:10px;height:10px;border-radius:3px;background:@item.Color;flex-shrink:0;"></span>
									<span style="font-size:.72rem;font-weight:500;">@item.Status <strong>@item.Percentage%</strong></span>
								</div>
							</div>
						}
					</div>
				}
				else
				{
					<div style="text-align:center;color:#a0aec0;"><i class="fa-solid fa-chart-pie fa-2xl mb-3 d-block"></i>No data</div>
				}
			</div>
		</div>
	</div>

	<!-- Location Bar Chart -->
	<div class="col-12 col-lg-7">
		<div class="card h-100">
			<div class="card-header">
				<div>
					<div class="card-title">Total Permits By Location</div>
					<div class="card-subtitle">Top sites by permit volume</div>
				</div>
			</div>
			<div class="card-body">
				@if (Model.LocationBreakdown.Any())
				{
					<div style="display:flex;flex-direction:column;gap:10px;">
						@foreach (var item in Model.LocationBreakdown)
						{
							<div>
								<div class="d-flex justify-content-between mb-1" style="font-size:.75rem;font-weight:500;">
									<span>@item.SiteName</span>
									<span style="color:#2c7be5;">@item.Count</span>
								</div>
								<div style="height:8px;background:#f0f4f8;border-radius:4px;overflow:hidden;">
									<div style="height:100%;width:@(item.Percentage)%;background:linear-gradient(90deg,#2c7be5,#5a9cf5);border-radius:4px;"></div>
								</div>
							</div>
						}
					</div>
				}
				else
				{
					<div style="text-align:center;color:#a0aec0;"><i class="fa-solid fa-chart-bar fa-2xl mb-3 d-block"></i>No location data</div>
				}
			</div>
		</div>
	</div>

</div>

@* ── Recent permits + activity ───────────────────────────── *@
<div class="row g-3">

	<!-- Recent Permits Table -->
	<div class="col-12 col-xl-8">
		<div class="card">
			<div class="card-header">
				<div>
					<div class="card-title">Recent Permits</div>
					<div class="card-subtitle">Latest permit activity</div>
				</div>
				<a asp-controller="permits" asp-action="index" class="btn btn-light btn-sm">
					View all <i class="fa-solid fa-arrow-right ms-1"></i>
				</a>
			</div>
			<div class="card-body p-0">
				@if (Model.RecentPermits.Any())
				{
					<table class="table table-hover mb-0">
						<thead>
							<tr>
								<th>Permit No.</th>
								<th>Type</th>
								<th>Location</th>
								<th>Requested By</th>
								<th>Status</th>
								<th>Date</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var permit in Model.RecentPermits)
							{
								<tr>
									<td><a asp-controller="permits" asp-action="index" style="color:#2c7be5;font-weight:600;text-decoration:none;font-size:.825rem;">@permit.PermitNumber</a></td>
									<td>
										@if (permit.PermitType.Contains("Hot"))
										{
											<span class="badge-pill" style="background:#fff0e6;color:#e07b39;">@permit.PermitType</span>
										}
										else if (permit.PermitType.Contains("Confined"))
										{
											<span class="badge-pill" style="background:#fdeaea;color:#e74c3c;">@permit.PermitType</span>
										}
										else if (permit.PermitType.Contains("Excavation"))
										{
											<span class="badge-pill" style="background:#e8f0fb;color:#2c7be5;">@permit.PermitType</span>
										}
										else
										{
											<span class="badge-pill" style="background:#e6f8f1;color:#00b894;">@permit.PermitType</span>
										}
									</td>
									<td><span style="font-weight:500;">@permit.SiteName</span></td>
									<td>
										<div class="d-flex align-items-center gap-2">
											@{
												var initials = permit.RequestedByName?.Split(' ').Select(w => w.FirstOrDefault()).Take(2);
												var initStr = string.Concat(initials ?? []).ToUpper();
											}
											<div class="avatar-sm" style="background:#2c7be5;font-size:.6rem;width:28px;height:28px;">@initStr</div>
											<span style="font-size:.8rem;">@permit.RequestedByName</span>
										</div>
									</td>
									<td>
										@if (permit.Status == PermitStatusEnum.Approved)
										{
											<span class="badge-pill approved"><span class="dot"></span>Approved</span>
										}
										else if (permit.Status == PermitStatusEnum.Pending)
										{
											<span class="badge-pill pending"><span class="dot"></span>Pending</span>
										}
										else if (permit.Status == PermitStatusEnum.Rejected)
										{
											<span class="badge-pill rejected"><span class="dot"></span>Rejected</span>
										}
										else if (permit.Status == PermitStatusEnum.Closed)
										{
											<span class="badge-pill closed"><span class="dot"></span>Closed</span>
										}
										else
										{
											<span class="badge-pill inactive"><span class="dot"></span>@permit.Status.ToString()</span>
										}
									</td>
									<td style="color:#6b7c93;font-size:.78rem;">@permit.CreatedWhen.ToString("dd MMM yyyy")</td>
								</tr>
							}
						</tbody>
					</table>
				}
				else
				{
					<div class="text-center text-secondary py-5">
						<i class="fa-solid fa-inbox fa-2xl mb-3 d-block"></i>
						<p>No permits found</p>
					</div>
				}
			</div>
		</div>
	</div>

	<!-- Recent Activity -->
	<div class="col-12 col-xl-4">
		<div class="card">
			<div class="card-header">
				<div>
					<div class="card-title">Recent Activity</div>
					<div class="card-subtitle">System events</div>
				</div>
			</div>
			<div class="card-body">
				@foreach (var activity in Model.RecentActivity)
				{
					<div class="activity-item">
						<div class="activity-icon" style="background:@activity.IconBackground;"><i class="@activity.IconClass fa-sm" style="color:#2c7be5;"></i></div>
						<div>
							<div class="activity-text"><strong>@activity.Title</strong><br><span style="color:#6b7c93;">@activity.Description</span></div>
							<div class="activity-time">@activity.TimeAgo</div>
						</div>
					</div>
				}
			</div>
		</div>
	</div>

</div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/dashboard.css" />
}
