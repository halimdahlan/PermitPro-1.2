@using Kendo.Mvc.UI

@{
	ViewData["Title"] = "Companies";
	ViewData["SubTitle"] = "Manage tenant companies";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<div></div>
	<div>
		<a href="#dlgCompany" class="btn btn-primary no-loading" data-bs-toggle="modal" data-bs-target="#dlgCompany">
			<span class="px-2"><i class="fa-sharp fa-solid fa-plus me-2"></i> New company</span>
		</a>
	</div>
</div>

<div class="mt-3">
	@Html.AntiForgeryToken()
	@(Html.Kendo()
		.Grid<CompanyGridViewModel>()
		.HtmlAttributes(new { @class = "table-grid" })
		.Name("grid")
		.ToolBar(tb => tb.Search())
		.NoRecords()
		.Pageable()
		.Sortable()
		.DataSource(ds => ds
			.Custom()
			.Schema(s => s
				.Model(m => m.Id(i => i.Id))
			)
			.Transport(t =>
			{
				t.Read(r => r.Url("/companies/grid").Type(HttpVerbs.Get));
			})
			.PageSize(20)
		)
		.Columns(c =>
		{
			c.Bound(f => f.Name).ClientTemplate("<a href=\"javascript:;\" onclick=\"editCompany('#=Id#')\" class=\"text-info no-loading\">#=Name#</a>").Width(250);
			c.Bound(f => f.Description).Width(300);
			c.Bound(f => f.IsActive).Width(100).ClientTemplate("#=IsActive ? '<span class=\"badge bg-success\">Yes</span>' : '<span class=\"badge bg-secondary\">No</span>'#");
			c.Bound(f => f.CreatedWhen).Width(150).Format("{0:dd MMM yyyy}");
			c.Bound(f => f.ActionIcons).Title("Actions").Width(120).HtmlAttributes(new { @class = "text-center" });
		})
	)
</div>

<!-- Modal: New / Edit company -->
<div class="modal fade" id="dlgCompany" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgCompanyLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-scrollable modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h1 class="modal-title" id="dlgCompanyLabel">New company</h1>
				<a href="#" class="no-loading text-dark" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<form id="frmCompany" class="needs-validation" novalidate>
					<div class="form-group mb-3">
						<label class="form-label" for="frm-companyName">Company name</label>
						<input type="text" id="frm-companyName" class="form-control" required />
						<div class="invalid-feedback">Enter the company name</div>
					</div>
					<div class="form-group mb-3">
						<label class="form-label" for="frm-description">Description</label>
						<textarea id="frm-description" class="form-control" rows="3"></textarea>
					</div>
					<div class="d-flex flex-row mb-2">
						<div class="form-check me-4">
							<input class="form-check-input" type="radio" id="frm-active" name="company-status" value="true" checked>
							<label class="form-check-label" for="frm-active">Active</label>
						</div>
						<div class="form-check">
							<input class="form-check-input" type="radio" id="frm-inactive" name="company-status" value="false">
							<label class="form-check-label" for="frm-inactive">Inactive</label>
						</div>
					</div>
					<input type="hidden" id="frm-mode" value="new" />
					<input type="hidden" id="frm-id" value="" />
				</form>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
				<button type="button" class="btn btn-primary btn-save"><span class="mx-3">Save changes</span></button>
			</div>
		</div>
	</div>
</div>

<!-- Modal: Delete confirmation -->
<div class="modal fade" id="dlgConfirm" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="dlgConfirmLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header">
				<h1 class="modal-title" id="dlgConfirmLabel">Delete company?</h1>
				<a href="#" class="no-loading text-dark" data-bs-dismiss="modal" aria-label="Close"><i class="fa-sharp fa-solid fa-xmark fa-xl"></i></a>
			</div>
			<div class="modal-body">
				<p>This will soft-delete the company. Are you sure?</p>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
				<button type="button" class="btn btn-danger btn-proceed">Delete</button>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<script>
		$(function () {
			var grid = $("#grid").data("kendoGrid");

			/**
			 * Save button
			 */
			$('.btn-save').click(function () {
				var form = document.getElementById('frmCompany');

				if (!form.checkValidity()) {
					form.classList.add('was-validated');
					return;
				}

				var mode = $('#frm-mode').val();
				var id   = $('#frm-id').val();
				var name = $('#frm-companyName').val().trim();
				var desc = $('#frm-description').val().trim();
				var isActive = $('input[name="company-status"]:checked').val() === 'true';

				var formData = new FormData();
				formData.append('Id', mode == 'edit' ? id : null);
				formData.append('Name', name);
				formData.append('Description', desc);
				formData.append('IsActive', isActive);

				$('.loading').show();

				var xhr = $.ajax({
					method: 'POST',
					url: '/companies/' + mode,
					data: formData,
					contentType: false,
					processData: false,
					cache: false,
					beforeSend: function (xhr) {
						xhr.setRequestHeader('RequestVerificationToken', $('input:hidden[name="__RequestVerificationToken"]').val());
					},
				});

				xhr.done(function (response) {
					if (response.data == 'OK') {
						grid.dataSource.read();
						var dlg = bootstrap.Modal.getInstance($('#dlgCompany'));
						if (dlg) dlg.hide();
						$('.modal-backdrop').remove();
					} else {
						alert('Unable to save company. Please try again.');
					}
				});

				xhr.fail(function () {
					alert('Unable to save company. Please try again.');
				});

				xhr.always(function () {
					$('.loading').hide();
				});
			});

			/**
			 * Delete confirm
			 */
			$('.btn-proceed').click(function () {
				var companyId = $('.btn-proceed').data('companyId');

				$('.loading').show();

				var xhr = $.ajax({
					method: 'DELETE',
					url: '/companies/' + companyId,
				});

				xhr.done(function (response) {
					if (response.data == 'OK') {
						grid.dataSource.read();
						$('#dlgConfirm').modal('hide');
					}
				});

				xhr.fail(function () {
					alert('Unable to delete company. Please try again.');
				});

				xhr.always(function () {
					$('.loading').hide();
				});
			});

			/**
			 * Modal: dlgCompany – show
			 */
			$('#dlgCompany').on('show.bs.modal', function () {
				var mode = $('#frm-mode').val();

				if (mode == 'edit') {
					var companyId = $('#frm-id').val();

					$('.loading').show();

					$.ajax({
						method: 'GET',
						url: '/companies/' + companyId + '/info',
					}).done(function (response) {
						$('#frm-companyName').val(response.name);
						$('#frm-description').val(response.description);

						if (response.isActive) {
							$('#frm-active').prop('checked', true);
						} else {
							$('#frm-inactive').prop('checked', true);
						}
					}).fail(function () {
						alert('Unable to load company info.');
					}).always(function () {
						$('.loading').hide();
					});
				}
			});

			/**
			 * Modal: dlgCompany – hidden (reset)
			 */
			$('#dlgCompany').on('hidden.bs.modal', function () {
				$('#frm-companyName').val('');
				$('#frm-description').val('');
				$('#frm-active').prop('checked', true);
				$('#frmCompany').removeClass('was-validated').addClass('needs-validation');
				$('#frm-mode').val('new');
				$('#frm-id').val('');
				$('#dlgCompanyLabel').text('New company');
			});

			/**
			 * Modal: dlgConfirm – hidden (reset)
			 */
			$('#dlgConfirm').on('hidden.bs.modal', function () {
				$('.btn-proceed').data('companyId', '');
			});
		});

		// ── Global helpers ──
		const editCompany = function (id) {
			$('#frm-mode').val('edit');
			$('#frm-id').val(id);
			$('#dlgCompanyLabel').text('Edit company');
			$('#dlgCompany').modal('show');
		};

		const deleteCompany = function (id) {
			$('.btn-proceed').data('companyId', id);
			$('#dlgConfirm').modal('show');
		};
	</script>
}
