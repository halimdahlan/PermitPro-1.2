@using DocumentFormat.OpenXml.Office2010.PowerPoint
@using PermitPro.App.Controllers
@{
	Layout = "_Layout";
	ViewData["Title"] = "Recycle Bin";
	ViewData["SubTitle"] = "Summary";

	var permits = (List<DeletedItem>)ViewBag.Permits;
	var sites = (List<DeletedItem>)ViewBag.Sites;
	var workflows = (List<DeletedItem>)ViewBag.Workflows;
	var workflowSteps = (List<DeletedItem>)ViewBag.WorkflowSteps;
	var users = (List<DeletedItem>)ViewBag.Users;
	var roles = (List<DeletedItem>)ViewBag.Roles;
	var companies = (List<DeletedItem>)ViewBag.Companies;
	var isSuperUser = (bool)ViewBag.IsSuperUser;
}

<div class="recycle-bin-container">

	@if (TempData["RecycleBinMessage"] != null)
	{
		<div class="alert alert-success alert-dismissible fade show" role="alert">
			<i class="fa-solid fa-circle-check me-2"></i> @TempData["RecycleBinMessage"]
			<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
		</div>
	}

	<div class="card shadow-sm">
		<div class="card-body">
			<!-- Tab navigation -->
			<ul class="nav nav-tabs mb-3" id="recycleTabs" role="tablist">
				<li class="nav-item" role="presentation">
					<button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-permits" type="button" role="tab">
						Permits <span class="badge bg-secondary ms-1">@permits.Count</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sites" type="button" role="tab">
						Locations <span class="badge bg-secondary ms-1">@sites.Count</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-workflows" type="button" role="tab">
						Workflows <span class="badge bg-secondary ms-1">@workflows.Count</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-workflowsteps" type="button" role="tab">
						Workflow Steps <span class="badge bg-secondary ms-1">@workflowSteps.Count</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-users" type="button" role="tab">
						Users <span class="badge bg-secondary ms-1">@users.Count</span>
					</button>
				</li>
				<li class="nav-item" role="presentation">
					<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-roles" type="button" role="tab">
						Roles <span class="badge bg-secondary ms-1">@roles.Count</span>
					</button>
				</li>
				@if (isSuperUser)
				{
					<!--
					<li class="nav-item" role="presentation">
						<button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-companies" type="button" role="tab">
							Companies <span class="badge bg-secondary ms-1">@companies.Count</span>
						</button>
					</li>
					-->
				}
			</ul>

			<div class="tab-content" id="recycleTabContent">

				<!-- Permits -->
				<div class="tab-pane fade show active" id="tab-permits" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", permits },
				{ "Columns", new[] { "Permit No", "Site", "Company" } },
			})
				</div>

				<!-- Sites -->
				<div class="tab-pane fade" id="tab-sites" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", sites },
				{ "Columns", new[] { "Name", "Description", "Company" } },
			})
				</div>

				<!-- Workflows -->
				<div class="tab-pane fade" id="tab-workflows" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", workflows },
				{ "Columns", new[] { "Name", "Description", "Company" } },
			})
				</div>

				<!-- Workflow Steps -->
				<div class="tab-pane fade" id="tab-workflowsteps" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", workflowSteps },
				{ "Columns", new[] { "Name", "Workflow", "Company" } },
			})
				</div>

				<!-- Users -->
				<div class="tab-pane fade" id="tab-users" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", users },
				{ "Columns", new[] { "Name", "Email", "Company" } },
			})
				</div>

				<!-- Roles -->
				<div class="tab-pane fade" id="tab-roles" role="tabpanel">
					@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
			{
				{ "Items", roles },
				{ "Columns", new[] { "Name", "Description", "Company" } },
			})
				</div>

				<!-- Companies (Super User only) -->
				@if (isSuperUser)
				{
					<div class="tab-pane fade" id="tab-companies" role="tabpanel">
						@await Html.PartialAsync("_RecycleBinTable", new ViewDataDictionary(ViewData)
				{
					{ "Items", companies },
					{ "Columns", new[] { "Name", "Description", "" } },
				})
					</div>
				}

			</div>
		</div>
	</div>


</div>

<!-- Confirmation modal for restore and delete -->
<div class="modal fade" id="recycleBinConfirmModal" data-bs-backdrop="static" tabindex="-1" aria-labelledby="recycleBinConfirmModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header bg-warning">
				<h2 class="modal-title" id="recycleBinConfirmModalLabel" style="font-weight:600;">Confirm action</h2>
				<button type="button" class="btn btn-clear" data-bs-dismiss="modal" aria-label="Close">
					<i class="fa-regular fa-close fa-2x"></i>
				</button>
			</div>
			<div class="modal-body mb-0">
				<p class="mb-0" id="recycleBinConfirmMessage"></p>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
				<button type="button" class="btn btn-sm btn-outline-primary" id="recycleBinConfirmSubmit">Confirm</button>
			</div>
		</div>
	</div>
</div>

@section CustomCss {
	<link rel="stylesheet" href="~/css/recyclebin.css" />
}

@section Scripts {
	<script>
		// Persist active tab across restores via hash
		const tabHash = location.hash || '#tab-permits';
		const trigger = document.querySelector(`[data-bs-target="${tabHash}"]`);
		//if (trigger) $(`[data-bs-target="${tabHash}"]`).tab('show');
		//if (trigger) new bootstrap.Tab(trigger).show();

		document.querySelectorAll('[data-bs-toggle="tab"]').forEach(btn => {
			btn.addEventListener('shown.bs.tab', e => {
				history.replaceState(null, '', e.target.dataset.bsTarget);
			});
		});

		const confirmModalEl = document.getElementById('recycleBinConfirmModal');
		const confirmModal = $(confirmModalEl); //new bootstrap.Modal(confirmModalEl);
		const confirmMessage = document.getElementById('recycleBinConfirmMessage');
		const confirmSubmit = document.getElementById('recycleBinConfirmSubmit');
		let pendingForm = null;

		document.querySelectorAll('.recycle-bin-confirm-btn').forEach(button => {
			button.addEventListener('click', () => {
				const action = button.dataset.action;
				const entity = button.dataset.entity;
				const item = button.dataset.item;
				const formId = button.dataset.formId;
				pendingForm = document.getElementById(formId);

				confirmModalEl.querySelector('.modal-title').textContent = action === 'delete'
					? 'Confirm permanent delete'
					: 'Confirm restore';

				confirmMessage.textContent = action === 'delete'
					? `Permanently delete this ${entity} "${item}"? This cannot be undone.`
					: `Restore ${entity} "${item}"?`;

				confirmSubmit.classList.toggle('btn-outline-danger', action === 'delete');
				confirmSubmit.classList.toggle('btn-outline-primary', action !== 'delete');
				confirmSubmit.textContent = action === 'delete' ? 'Delete' : 'Restore';

				//confirmModal.show();
				$('#recycleBinConfirmModal').modal('show');
			});
		});

		confirmSubmit.addEventListener('click', () => {
			if (pendingForm) {
				pendingForm.submit();
			}
		});
	</script>
}
